/**
 * [관리자 하위 모듈 4] 경제 및 포인트 관리
 * 기능: 경제지표, 데이터교정, 물가조정, 포인트 지급/차감/뿌리기, 각종 초기화, 재원수정 및 충전, 자가복원
 */
function _adminEconomyLogic(msg, user, data, replier, roomName, targetUid, sender) {
// [핵심] 1:1방 또는 베릭방에서 실행 시에도 실제 은행 데이터가 있는 "내리다" 방을 참조하도록 고정
    var logicZone = (roomName === "베릭방" || ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var roomData = data.rooms[logicZone];
    
     /* * [v13.8] 지능형 원격 로그 수혈 (Time-Filter Edition)
     * 사용법: /로그원격복구 [오늘시작시간(HH:mm)] [파일URL]
     * 예시: /로그원격복구 10:30 https://cdn.discord...
     */
    if (msg.indexOf("/로그원격복구 ") === 0) {
        var ps = msg.split(" ");
        if (ps.length < 3) return replier.reply(formatAdmin("오류", "사용법: /로그원격복구 [시작시간(HH:mm)] [URL]"));

        var timeStr = ps[1]; // "10:30"
        var fileUrl = ps[2]; // "http..."
        
        // 입력받은 시간을 타임스탬프로 변환
        var now = new Date();
        var tParts = timeStr.split(":");
        var startTs = new Date(now.getFullYear(), now.getMonth(), now.getDate(), parseInt(tParts[0]), parseInt(tParts[1])).getTime();

        replier.reply("📡 [" + timeStr + "] 이후의 데이터만 선별 복구를 시작합니다...");

        Executor.execute(new java.lang.Runnable({
            run: function() {
                try {
                    var tempPath = BASE_DIR + "recovery/REMOTE_LOG_" + Date.now() + ".txt";
                    var conn = new java.net.URL(fileUrl).openConnection();
                    var is = conn.getInputStream();
                    var fos = new java.io.FileOutputStream(tempPath);
                    var buffer = java.lang.reflect.Array.newInstance(java.lang.Byte.TYPE, 4096);
                    var len;
                    while ((len = is.read(buffer)) > 0) { fos.write(buffer, 0, len); }
                    fos.close(); is.close();

                    var recoveryFile = new java.io.File(tempPath);
                    // _processLogFile에 시작 시간(startTs)을 전달하여 필터링
                    var recoveredCount = _processLogFile(recoveryFile, data, startTs);
                    
                    if (recoveredCount > 0) {
                        safeSaveData(data, true);
                        recoveryFile.delete();
                        Api.replyRoom(roomName, formatAdmin("✅ 선별 복구 완료", "분석 결과: " + recoveredCount + "건의 새로운 거래가 병합되었습니다.\n(기준 시간: " + timeStr + " 이후)"));
                    } else {
                        recoveryFile.delete();
                        Api.replyRoom(roomName, formatAdmin("❓ 결과 없음", "해당 시간 이후에 발생한 거래가 파일 내에 없습니다."));
                    }
                } catch (e) {
                    Api.replyRoom(roomName, formatAdmin("🚫 원격 복구 실패", "오류: " + e.message));
                }
            }
        }));
        return true;
    }

    /* [1] 은행 가용 재원 수동 수정 (강제 설정) */
    if (msg.indexOf("/재원수정 ") === 0) {
        var val = parseInt(msg.split(" ")[1].replace(/,/g, ""));
        if (isNaN(val)) {
            replier.reply(formatAdmin("오류", "수정할 금액을 숫자로 입력하세요.\n예) /재원수정 3000"));
            return true;
        }

        if (!roomData) return true;

        // [교정] roomName이 아닌 logicZone(내리다)의 재원을 수정함
        var currentRes = Number(roomData.bankReserve || 0);
        var delta = val - currentRes;
        util_updateReserve(roomData, delta, "재원 수정", logicZone);
        
        roomData.bankReserve = val;
        safeSaveData(data);
        
        replier.reply(formatAdmin("🏦 은행 재원 수정 완료", 
            "현재 방의 가용 재원이 수정되었습니다.\n\n" +
            "💰 설정 금액: " + fp(val) + "P\n" +
            "📢 이제 유저들이 이 금액 내에서 대출 가능합니다."));
        return true;
    }

   if (msg === "/국고로그") {
    try {
        var logs = [];
        // [교정] History(과거)를 먼저 넣고 Journal(현재)을 나중에 넣어 Newest가 배열 끝에 오게 함
        var filesToRead = [BASE_DIR + "total_history.log", JOURNAL_PATH];

        filesToRead.forEach(function(path) {
            var file = new java.io.File(path);
            if (file.exists() && file.length() > 0) {
                var content = FileStream.read(path).split("\n");
                logs = logs.concat(content);
            }
        });

        var filteredLogs = [];
        var startOfToday = new Date().setHours(0, 0, 0, 0); // 오늘 00:00:00 타임스탬프
        
        for (var i = logs.length - 1; i >= 0; i--) {
            var line = logs[i].trim();
            if (!line) continue;
            var parts = line.split("|");
            if (parts.length < 6) continue; 

            var logTime = Number(parts[0]);
            if (logTime < startOfToday) continue; // 오늘 이전 기록이면 스킵

            var logRoom = parts[2];
            if (logRoom !== "내리다" && logRoom !== roomName) continue;

            var brDelta = Number(parts[4]); 
            if (!isNaN(brDelta) && brDelta !== 0) {
                var sign = brDelta > 0 ? "➕" : "➖";
                var uName = "알 수 없음";
                
                var logUid = parts[1];
                for (var r in data.rooms) {
                    if (data.rooms[r].users[logUid]) {
                        uName = data.rooms[r].users[logUid].name;
                        break;
                    }
                }
                var timeStr = new Date(logTime).toLocaleTimeString('ko-KR', { hour12: false, hour: '2-digit', minute: '2-digit' });
                filteredLogs.push("• [" + timeStr + "] " + parts[5] + " | " + uName + " | " + sign + fp(Math.abs(brDelta)) + "P");
                
                // [안전가드] 카카오톡 텍스트 짤림 및 렉 방지를 위해 최신 내역 50건까지만 출력
                if (filteredLogs.length >= 50) break;
            }
        }

        var readMore = "\u200b".repeat(500); 
        var resultBody = "🏦 현재 금고 잔액: " + fp(roomData.bankReserve) + "P\n" +
                         "━━━━━━━━━━━━━━━" + readMore + "\n" +
                         (filteredLogs.length > 0 ? filteredLogs.join("\n") : "오늘 집계된 국고 변동 기록이 없습니다.");

        replier.reply(formatAdmin("🏛️ 오늘 국고 전체 변동 장부", resultBody));
    } catch (e) {
        replier.reply(formatAdmin("🚫 조회 실패", "로그 통합 분석 오류: " + e));
    }
    return true;
   }

    /* 은행 긴급 재원 충전 (기존 잔액에 추가 합산) */
    if (msg.indexOf("/재원충전 ") === 0) {
        var val = parseInt(msg.split(" ")[1].replace(/,/g, ""));
        if (isNaN(val) || val <= 0) {
            replier.reply(formatAdmin("오류", "충전할 금액을 양의 숫자로 입력하세요.\n예) /재원충전 100000"));
            return true;
        }
        if (!roomData) return true;

        // [교정] logicZone(내리다) 재원에 합산
        util_updateReserve(roomData, val, "재원 충전", logicZone);
        
        safeSaveData(data);
        
        var resMsg = "결과: 국고 보충 완료\n" +
                     "수혈 금액: +" + fp(val) + "P\n" +
                     "🏦 현재 금고 총액: " + fp(roomData.bankReserve) + "P";
        
        replier.reply(formatAdmin("⚙️ 중앙은행 긴급 재원 수혈", resMsg));
        return true;
    }

    /* [4] 경제 지표 상세 조회 */
    if (msg === "/경제정보") {
        // [수정] 베릭방이나 1:1방에서 조회 시, 메인 구역('내리다')의 경제 데이터를 로드
        var targetZone = (roomName === "베릭방" || ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;

        var eco = calculateEconomy(data, targetZone);
        var rData = data.rooms[targetZone];
        var base = rData.economyBase || 0;
        
        var multiplier = 1.0;
        if (base > 0) {
            var rawRatio = eco.total / base;
            var damping = (data.economyDamping !== undefined) ? data.economyDamping : 0.5;
            multiplier = 1 + (rawRatio - 1) * damping;
            if (multiplier < 0.5) multiplier = 0.5;
        }

        var gini = (typeof util_calculateGini === 'function') ? util_calculateGini(targetZone) : 0;
        var reserveRate = (eco.total > 0) ? ((Number(rData.bankReserve || 0) / eco.total) * 100).toFixed(1) : "0.0";
        var totalSocialWealth = eco.average * eco.count; // 전체 사회 자산 가치

        var statusIcon = (multiplier > 1.5) ? "⚠️ 인플레" : (multiplier < 0.8 ? "📉 디플레" : "✅ 안정");
        var giniStatus = (gini > 0.4) ? "🚨 심각" : (gini > 0.3 ? "⚠️ 주의" : "🟢 양호");

        var ecoMsg = "📊 [" + targetZone + " 경제 대시보드]\n" +
                     "━━━━━━━━━━━━━━━\n" +
                     "🔎 [시장 통화지표]\n" +
                     "• 유동성(유저자산+국고): " + fp(eco.total) + "P\n" +
                     "• 유저 실 자산: " + fp(totalSocialWealth) + "P\n\n" +
