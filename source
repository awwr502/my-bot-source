function util_checkUserState(user, uid, roomName, isJobActivity) {
    if (typeof util_scrubNativeObject === 'function') util_scrubNativeObject(user);
    var now = Date.now();
    var data = getDatabase();
    
    // 참조 변수 선언: 에러의 원인인 dData와 aThefts를 명확히 정의합니다.
    var logicRoom = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var rObj_internal = data.rooms[logicRoom] || data.rooms["내리다"];
    var activePillages = (data.rooms["내리다"].features) ? (data.rooms["내리다"].features.activePillages || {}) : {};

    // 전 구역 세션 스캔: 어느 방에서든 입력 대기 중이라면 '활동 중'으로 간주
    for (var rN in data.rooms) {
        var rObj = data.rooms[rN];
        if (rObj.features && rObj.features.states) {
            var s = rObj.features.states;
            var qKeys = ["menuWait", "bankProcess", "selectWait"];
            qKeys.forEach(function(k) {
                if (s[k] && s[k][uid]) {
                    var currentSession = s[k][uid];
                    // 세션 발생지가 현재 방이 아니라면, 차단하지 않고 해당 세션을 즉시 초기화(삭제)
                    if (currentSession.originRoom !== roomName) {
                        // [v18.2 교정] 로그만 남기던 기존 로직에서 실제 delete 문 추가
                        delete s[k][uid]; 
                        Log.info("🧹 [Session Cleanup] " + user.name + "님의 타 구역 세션 강제 초기화 (" + (currentSession.originRoom || rN) + ")");
                    }
                }
            });
        }
    }

    // 1. 해상 활동(isJobActivity: true) 검증 시: 해전 패배 타이머만 체크
    if (isJobActivity === true) {
        // [해군] 후퇴/정비 상태 체크 (15분 페널티)
        if (user.retreatEndTime && now < user.retreatEndTime) {
            var diffR = user.retreatEndTime - now;
            var remainMinR = Math.ceil(diffR / (1000 * 60));
            return { canAction: false, reason: "현재 해전 패배로 인해 후퇴 정비 중입니다. (" + remainMinR + "분 남음)" };
        }
        // [해적] 약탈 쿨타임/해상 징역 체크
        if (user.pillageCooldownEndTime && now < user.pillageCooldownEndTime) {
            var diffP = user.pillageCooldownEndTime - now;
            var remainMinP = Math.ceil(diffP / (1000 * 60));
            return { canAction: false, reason: "현재 함대 재정비(해상 징역) 중입니다. (" + remainMinP + "분 남음)" };
        }

    // 해상 교전(약탈/토벌) 진행 상태 체크 - 해상 활동 시에만 차단
        if (activePillages[uid]) return { canAction: false, reason: "현재 해적에게 습격받아 교전 중입니다!" };
        
        for (var pKey in activePillages) {
            var pEntry = activePillages[pKey];
            if (pEntry.pirateUid === uid) return { canAction: false, reason: "현재 다른 선박을 약탈 중인 상태입니다." };
        }

        // [해군] 호위 중 상태 체크 - 해상 활동 시에만 차단
        if (user.job === 'navy') {
            for (var rN in data.rooms) {
                var rO = data.rooms[rN];
                for (var uI in rO.users) {
                    var targetV = rO.users[uI].voyage;
                    if (targetV && targetV.active === true && targetV.escortUid === uid && Date.now() < targetV.arrival) {
                         return { canAction: false, reason: "현재 상선을 호위 항해 중이므로 다른 해상 임무가 불가능합니다." };
                    }
                }
            }
        }
    }

    // 2. 광산 채굴 상태 체크 (정의된 isJobActivity를 정상 참조)
    if (user.mining && user.mining.active && !isJobActivity) {
        return { canAction: false, isMining: true, reason: "현재 광산에서 채굴 작업 중입니다." };
    }

    // 3. 해상 약탈 및 교전 진행 상태 체크 (실시간 세션 감시)
    // - 내가 약탈 대상(상인)일 때
    if (activePillages[uid]) return { canAction: false, reason: "현재 해적에게 습격받아 교전 중입니다!" };
    
    for (var pKey in activePillages) {
        var pEntry = activePillages[pKey];
        if (pEntry.pirateUid === uid) return { canAction: false, reason: "현재 다른 선박을 약탈 중인 상태입니다." };
    }

    // 해군 호위 중 상태 정밀 검증 (상인 타이머 연동)
    if (user.job === 'navy') {
        for (var rN in data.rooms) {
            var rO = data.rooms[rN];
            for (var uI in rO.users) {
                var targetV = rO.users[uI].voyage;
                // 상인의 항해가 활성화 상태이고, 내가 호위함이며, 아직 도착 전(now < arrival)일 때만 '바쁨' 처리
                if (targetV && targetV.active === true && targetV.escortUid === uid && Date.now() < targetV.arrival) {
                    var remainM = Math.ceil((targetV.arrival - Date.now()) / 60000);
                    // return { canAction: false, reason: "현재 상선을 호위 항해 중입니다. (" + remainM + "분 남음)" };
                }
            }
        }
    }

    return { canAction: true, reason: "" };
}

