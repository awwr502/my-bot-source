/**
 * [v16.1] 하이브리드 지능형 소각 엔진 (Memory-Safe Deep Scrub)
 * 업그레이드: 재귀 탐색을 유지하여 자동 경로 탐지 기능을 보존하되, 
 * 임시 배열 생성을 억제하여 메모리 파편화와 CPU 부하를 원천 차단합니다.
 * 효과: 새 기능 추가 시 경로를 일일이 추가할 필요가 없으며, 노트9 CPU 부하를 방지합니다.
 */
function util_fastClean(obj, depth) {
    if (!obj || typeof obj !== 'object') return;
    var d = depth || 0;
    if (d > 4) return; // [보안] 4단계 이상 깊이 침투 차단 (CPU 보호)

    // 1단계: 고성능 타겟팅 소탕 (메모리 점유가 큰 최상위 객체 즉시 처단)
    if (d === 0) {
        if (obj.replier) obj.replier = null;
        if (obj.imageDB) obj.imageDB = null;
        if (obj.lastAction) obj.lastAction.replier = null;
        if (obj.voyage) obj.voyage.replier = null;
        if (obj.blackjackState) obj.blackjackState.replier = null;
    }

    // 2단계: 지능형 자율 수색 (for...in 루프로 임시 메모리 생성 없이 탐색)
    for (var key in obj) {
        var val = obj[key];
        
        // 기본 타입(숫자/문자/불린)은 연산 없이 패스하여 CPU 부하 절감
        if (!val || typeof val !== 'object') continue;

        // [보안] 핵심 게임 데이터 객체는 오염 방지를 위해 재귀에서 제외
        if (key === 'tempEnh' || key === 'blackjackState' || (d === 0 && key === 'rooms')) {
             // rooms는 너무 거대하므로 별도 핸들링하거나 깊이를 제한함
        }

        // 자바 네이티브 객체 또는 세션 복제본 발견 시 즉시 소각
        if (val.getClass !== undefined || (val.constructor && val.constructor.name === 'SessionCacheReplier')) {
            obj[key] = null;
            continue;
        }

        // 3단계: 배열 및 중첩 객체 내부 탐색 (자동 경로 탐지)
        util_fastClean(val, d + 1);
    }
}

/**
 * [v14.3] 하이퍼-클린 부트 엔진 (Power-Saving Edition)
 * 기능: 스레드 개수를 2개로 압축하여 발열을 잡고, 전역 변수 참조 오류를 해결합니다.
 */
(function() {
    try {
        var REG = "msgbot_thread_pool_registry_v1";
        var ACT_ID = "CURRENT_ACTIVE_ID";

        // 1. [소각] 이전 인스턴스의 좀비 자원 물리적 파괴
        if (typeof globalData !== 'undefined' && globalData[REG]) {
            var oldPools = globalData[REG];
            for (var i = 0; i < oldPools.length; i++) {
                try { if (oldPools[i]) oldPools[i].shutdownNow(); } catch (e) {}
            }
            Log.info("🗑️ [System] 이전 인스턴스 좀비 자원 소각 완료");
        }

        // 2. [중복 타이머 제거]
        var oldST = java.lang.System.getProperty(SCHEDULER_KEY);
        if (oldST) { clearInterval(parseInt(oldST)); java.lang.System.clearProperty(SCHEDULER_KEY); }
        var oldWD = java.lang.System.getProperty(WATCHDOG_KEY);
        if (oldWD) { clearInterval(parseInt(oldWD)); java.lang.System.clearProperty(WATCHDOG_KEY); }

        // 3. [최적화] 엔진 생성 및 전역 변수 할당 (var 제거)
        // ParallelPool: 메세지 로직 처리용 (노트9 코어 부하 분산 4개 고정)
        ParallelPool = java.util.concurrent.Executors.newFixedThreadPool(4); 
        LogicQueue = java.util.concurrent.Executors.newSingleThreadExecutor();
        // Executor: 디스코드 백업 및 외부 통신 전용 (느린 작업 격리 2개 고정)
        Executor = java.util.concurrent.Executors.newFixedThreadPool(2);
        // SaveExecutor: I/O 및 데이터 무결성 저장 전용 (2개 고정)
        SaveExecutor = java.util.concurrent.Executors.newFixedThreadPool(2);

        java.lang.System.setProperty(ACT_ID, MY_INSTANCE_ID);
        globalData[REG] = [ParallelPool, LogicQueue, Executor, SaveExecutor];
        
        // globalScope(this) 동기화 - 로더가 이 변수들을 찾을 수 있게 함
        this.ParallelPool = ParallelPool;
        this.LogicQueue = LogicQueue;
        this.Executor = Executor;
        this.SaveExecutor = SaveExecutor;

        // [v18.9] WakeLock 강제 점화 (화면 꺼짐 방지)
        if (!_wakeLock) {
            var pm = Api.getContext().getSystemService(android.content.Context.POWER_SERVICE);
            _wakeLock = pm.newWakeLock(android.os.PowerManager.PARTIAL_WAKE_LOCK, "NeridaBot:WakeLock");
            _wakeLock.acquire(); // CPU 잠듦 방지 시작
            Log.info("⚡ [System] WakeLock 가동: CPU 수면 방지 모드 활성화");
        }

        Log.info("♻️ [System] v14.3 최적화 엔진 점화 성공 (ID: " + MY_INSTANCE_ID + ")");
        java.lang.System.gc(); 

    } catch (e) {
        Log.error("🚨 [System] 엔진 리부트 치명적 결함: " + e);
    }
})();

