function _handleGovernorSettlement(msg, user, data, replier, roomName, targetUid) {
    var economyRoomName = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var roomData = data.rooms[economyRoomName];
    
    // 1. 세션 주머니 확보 (1:1방 동기화 대응을 위해 두 곳 모두 참조)
    var localMState = data.rooms[roomName].features.states.menuWait;
    var mainMState = data.rooms["내리다"].features.states.menuWait;
    var state = localMState[targetUid] || mainMState[targetUid];
    
    if (!state) return false;

    // 2. [네비게이션 교정] 뒤로/취소 입력 시 양쪽 세션을 모두 파기
    if (msg === "뒤로" || msg === "↩️ 뒤로" || msg === "처음으로" || msg === "🏠 처음으로" || msg === "취소" || msg === "❎취소") {
        if (localMState && localMState[targetUid]) delete localMState[targetUid];
        if (mainMState && mainMState[targetUid]) delete mainMState[targetUid];

        if (msg.indexOf("취소") === -1) {
            return _gameTradeLogic("/무역", user, data, replier, roomName, targetUid);
        }
        replier.reply(formatCommand("🏛️ 총독 집무실", user, "관세 정산 업무를 종료하고 집무실을 나왔습니다."));
        return true;
    }

    // 3. [오류 해결] portData 및 하위 국가 데이터 존재 여부 강제 검증 (사막의별 에러 원천 차단)
    if (!roomData.features.portData) roomData.features.portData = {};
    var pData = roomData.features.portData;
    var myPorts = state.myPorts || [];

    // 4. 총 가용 금액 계산 (객체 존재 확인 후 계산)
    var totalAvailable = 0;
    myPorts.forEach(function(p) { 
        if (pData[p]) totalAvailable += Number(pData[p].collectedTariff || 0); 
    });

    // 5. 수령 금액 판별
    var withdrawAmt = 0;
    if (msg === "전부") {
        withdrawAmt = totalAvailable;
    } else {
        // 숫자가 아닌 문자 제거 후 파싱
        withdrawAmt = parseInt(msg.replace(/[^0-9]/g, ""));
    }

    // 6. 유효성 검사
    if (isNaN(withdrawAmt) || withdrawAmt <= 0) return false; // 숫자가 아니면 다음 핸들러로 넘김

    if (withdrawAmt > totalAvailable) {
        replier.reply(formatError(user, "수령 불가", "정산 가능한 최대 금액(" + fp(totalAvailable) + "P)을 초과했습니다."));
        return true;
    }

    // 7. 실정산 집행 (항구별 순차 차감)
    var remaining = withdrawAmt;
    myPorts.forEach(function(p) {
        if (remaining <= 0 || !pData[p]) return;
        var pool = Number(pData[p].collectedTariff || 0);
        var take = Math.min(remaining, pool);
        pData[p].collectedTariff = pool - take;
        remaining -= take;
    });

    // 8. 포인트 지급 및 세션 종료
    user.skipHealing = true;
    util_updatePoint(user, roomData, withdrawAmt, "총독 자치령 관세 수령", economyRoomName);
    
    delete localMState[targetUid];
    delete mainMState[targetUid];
    
    replier.reply(formatCommand("✅ 관세 정산 완료", user, 
        "자치령의 관세를 국고로부터 정산받았습니다.\n\n" +
        "💰 수령 금액: +" + fp(withdrawAmt) + "P\n" +
        "🏛️ 남은 세입: " + fp(totalAvailable - withdrawAmt) + "P", 
        "내 잔액: " + fp(user.point) + "P"));
    
    safeSaveData(data, true);
    return true;
}



/**
 * 🚢 무역 하역 설정 UI 출력 함수 (디자인 가독성 강화)
 */
function _showTradeCargoSelectUI(user, replier, roomData, cfg, dest, selC, selS) {

    // 사용자가 직접 선택하거나 '전부'를 입력해야만 적재됨.

    var market = roomData.features.tradeMarket || cfg.NATIONS;
    var nInfo = (dest === "무역 지부") ? { favorite: "N/A", hate: "N/A" } : (market[dest] || { favorite: "NONE", hate: "NONE" });
    var currentLoc = user.currentLoc || "무역 지부";
    var body = "📍 목적지: [" + dest + "]\n\n" +
               "[📦 물류 창고 보유 현황]\n"; 
    
    var availableItems = []; 
    
    var availableItems = []; 
    var goodsOrder = ["식료품", "공업품", "공예품", "귀금속", "보석", "밀수품"];
    var specOrder = ["돼지고기", "강철", "도자기", "금괴", "다이아몬드"];
    
    var allWarehouse = user.warehouse || {};
    var processCargoItem = function(k) {
        var total = Number(allWarehouse[k] || 0);
        var selected = Number(selC[k] || 0);
        var remaining = total - selected;
        if (remaining > 0) {
            var avgPrice = Number((user.warehouseAvg && user.warehouseAvg[k]) || (user.cargoAvg && user.cargoAvg[k]) || cfg.GOODS_COST[k] || 10000);
            var status = "평단 " + fp(avgPrice) + "P";
            availableItems.push({ type: 'cargo', name: k, qty: remaining, status: status });
        }
    };
    
    goodsOrder.forEach(processCargoItem);
    for (var k in allWarehouse) { if (goodsOrder.indexOf(k) === -1) processCargoItem(k); }

    var allSpec = user.warehouseSpec || {};
    var processSpecItem = function(s) {
        var totalS = Number(allSpec[s] || 0);
        var selectedS = Number(selS[s] || 0);
        var remainingS = totalS - selectedS;
        if (remainingS > 0) {
            var pG = "";
            for (var rel in TRADE_RELATION) {
                if (TRADE_RELATION[rel].set === s) { pG = TRADE_RELATION[rel].produce; break; }
            }
            var sBase = cfg.SPECIALTY_COST[pG] || 20000;
            var sStatus = "평단 " + fp(sBase) + "P";
            availableItems.push({ type: 'spec', name: s, qty: remainingS, status: sStatus });
        }
    };

    specOrder.forEach(processSpecItem);
    for (var s in allSpec) {
        if (s === "_rare" || s === "_unknown" || specOrder.indexOf(s) !== -1) continue; 
        processSpecItem(s);
    }

    var unknownCount = Number(allSpec["_unknown"] || 0); 
    var selectedUnknown = Number(selS["_unknown"] || 0);
    var remainingUnknown = unknownCount - selectedUnknown;
    if (remainingUnknown > 0) {
        availableItems.push({ type: 'unknown', name: "미확인 교역품", qty: remainingUnknown, status: "🔄변환 대기" });
    }

    var rareCount = Number(allSpec["_rare"] || 0); 
    var selectedRare = Number(selS["_rare"] || 0);
    var remainingRare = rareCount - selectedRare;
    if (remainingRare > 0) {
        availableItems.push({ type: 'rare', name: "진귀한 보물", qty: remainingRare, status: "💰고정가 (10만P)" });
    }

    if (availableItems.length === 0) {
        body += "- 적재 가능한 보유 물품 없음 -\n";
    } else {
        availableItems.forEach(function(it, i) {
            var prefix = (it.type === 'spec') ? "⭐" : (it.type === 'rare' ? "💎" : (it.type === 'unknown' ? "📦" : ""));
            body += (i + 1) + ". " + prefix + it.name + " (" + it.qty + (it.type === 'rare' ? "개" : "상자") + ") - " + it.status + "\n";
        });
    }

    var selList = [];
    
    var combinedCargo = JSON.parse(JSON.stringify(user.cargo || {}));
    for (var c in selC) combinedCargo[c] = (combinedCargo[c] || 0) + Number(selC[c]);
    
    goodsOrder.forEach(function(c) {
        if (combinedCargo[c] > 0) selList.push("• " + c + " x" + combinedCargo[c] + "상자");
    });
    for (var c in combinedCargo) {
        if (goodsOrder.indexOf(c) === -1 && combinedCargo[c] > 0) selList.push("• " + c + " x" + combinedCargo[c] + "상자");
    }

    var combinedSpec = JSON.parse(JSON.stringify(user.specialties || {}));
    for (var s in selS) {
        if (s !== "_rare" && s !== "_unknown") combinedSpec[s] = (combinedSpec[s] || 0) + Number(selS[s]);
    }
    
    specOrder.forEach(function(s) {
        if (combinedSpec[s] > 0) selList.push("• ⭐" + s + " x" + combinedSpec[s] + "개");
    });
    for (var s in combinedSpec) {
        if (specOrder.indexOf(s) === -1 && combinedSpec[s] > 0) selList.push("• ⭐" + s + " x" + combinedSpec[s] + "개");
    }

    var combinedUnknown = Number(user.unknownCargo || 0) + Number(selS["_unknown"] || 0);
    if (combinedUnknown > 0) selList.push("• 📦미확인 교역품 x" + combinedUnknown + "상자 (출항 시 변환)");
    
    var combinedRare = Number(user.rareSpecialties || 0) + Number(selS["_rare"] || 0);
    if (combinedRare > 0) selList.push("• 💎진귀한 보물 x" + combinedRare + "개");

    // 선박 총 용량 및 현재 적재량 실시간 계산
    var shipCfg = cfg.SHIPS[user.shipLevel || 1];
    var totalCap = shipCfg.capacity + (Number(user.enhLimit) || 0);
    var currentLoaded = 0;
    for (var k in combinedCargo) currentLoaded += Number(combinedCargo[k]);
    for (var k in combinedSpec) currentLoaded += Number(combinedSpec[k]);
    currentLoaded += combinedUnknown + combinedRare;

    body += "\n[✅ 이번 출항 선적 리스트] (" + currentLoaded + " / " + totalCap + " 칸)\n";

    if (selList.length > 0) {
        body += selList.join("\n");
    } else {
        body += "- 적재된 물품 없음 -";
    }

    var escortLine = (user.job === 'pirate') ? "" : "• 호위 : [호위] (해군 고용)\n"; // 해적일 때 호위 멘트 제거

    body += "\n\n\n💬 [입력 방법]\n" +
            "• 판매 품목 지정: [번호] [수량]\n" +
            "• 모든 화물 선택: [전부]\n" +
            escortLine + // 가변 라인 적용
            "• 출항 : [출항]\n\n" +
            "↩️ 뒤로 / 🏠 처음으로 / ❎취소";

    var nextStep = (user.job === 'pirate') ? "[출항]을 입력하세요." : "판매할 품목을 고른 후 [호위] 또는 [출항]을 입력하세요.";
    replier.reply(formatCommand("🚢 무역 하역 설정", user, body, nextStep));
}

/**
 * 🚢 무역 하역 화물 선택 핸들러 (입력 파싱 최적화)
 */
function _handleTradeCargoSelection(msg, user, data, replier, roomName, targetUid, cfg) {
    var roomData = data.rooms[roomName];
    var state = roomData.features.states.menuWait[targetUid];
    var input = msg.trim();

    if (input === "취소" || input === "뒤로" || input === "↩️ 뒤로") {
        if (roomData.features.states.menuWait && roomData.features.states.menuWait[targetUid]) {
            delete roomData.features.states.menuWait[targetUid];
        }
        return _gameTradeLogic("/무역", user, data, replier, roomName, targetUid);
    }

    // 선박의 최대 적재량 및 현재 적재량 계산
    var shipCfg = cfg.SHIPS[user.shipLevel || 1];
    var totalCap = shipCfg.capacity + (Number(user.enhLimit) || 0);
    var currentLoaded = 0;
    
    // [Gemini 패치]: 기존 선박 보유분 합산 (용량 초과 적재 방지)
    for (var c in (user.cargo || {})) currentLoaded += Number(user.cargo[c]);
    for (var s in (user.specialties || {})) currentLoaded += Number(user.specialties[s]);
    currentLoaded += Number(user.unknownCargo || 0) + Number(user.rareSpecialties || 0);

    // 창고 하역분 합산
    for (var c in state.selCargo) currentLoaded += Number(state.selCargo[c]);
    for (var s in state.selSpec) currentLoaded += Number(state.selSpec[s]);
    
    var remainingCap = Math.max(0, totalCap - currentLoaded);

    if (input === "전부") {
        // 남은 용량(remainingCap) 내에서만 순차적으로 적재
        var loadItem = function(key, available, type) {
            if (available <= 0 || remainingCap <= 0) return;
            var loadQty = Math.min(available, remainingCap);
            if (type === 'cargo') state.selCargo[key] = (state.selCargo[key] || 0) + loadQty;
            else state.selSpec[key] = (state.selSpec[key] || 0) + loadQty;
            remainingCap -= loadQty;
        };

        // 창고(warehouse) 데이터 순회
        var w = user.warehouse || {};
        var ws = user.warehouseSpec || {};

        for (var k in w) loadItem(k, w[k], 'cargo');
        for (var s in ws) {
            if (s === "_rare" || s === "_unknown") continue;
            loadItem(s, ws[s], 'spec');
        }
        
        if (Number(ws["_rare"] || 0) > 0) loadItem("_rare", ws["_rare"], 'spec');
        if (Number(ws["_unknown"] || 0) > 0) loadItem("_unknown", ws["_unknown"], 'spec');
        
        if (remainingCap <= 0) {
            replier.reply("⚠️ 적재 공간이 한계에 도달하여 남은 공간만큼만 화물이 선적되었습니다.");
        }
        
        state.time = Date.now();
        safeSaveData(data, true);
        
        _showTradeCargoSelectUI(user, replier, roomData, cfg, state.dest, state.selCargo, state.selSpec);
        return;
    }

    // '호위' 키워드 입력 시 해군 고용 핸들러를 호출하는 로직 삽입
    if (input === "호위") {
        if (user.job === 'pirate') {
            replier.reply(formatError(user, "고용 불가", "해적은 정규 해군을 고용할 수 없습니다."));
            return;
        }
        // [증발 방지 가드] 호위 메뉴로 넘어가기 전 현재 화물 상태를 확정 보존
        safeSaveData(data, true);
        
        _handleEscortHire(input, user, data, replier, roomName, targetUid);
        return;
    }

    if (input === "출항") {

        // 1. 출항 시 부도 가드 추가
        if (typeof util_isBankruptcy === 'function' && util_isBankruptcy(roomName)) {
            replier.reply(formatError(user, "출항 불가능", "현재 국가 부도 상태이므로 모든 무역선박의 출항이 전면 금지되었습니다.\n\n⚠️ 사유: 국고 재원 부족으로 인한 항만 봉쇄"));
            return;
        }

        // 2. 엘도라도 최종 쿨타임 가드 (어뷰징 및 세션 조작 방지)
        if (state.dest === ELDORADO_CONFIG.NAME) {
            var lastHidden = Number(user.lastHiddenVoyage || 0);
            var remainMs = ELDORADO_CONFIG.COOLDOWN - (Date.now() - lastHidden);
            if (remainMs > 0) {
                var remainH = Math.floor(remainMs / 3600000);
                var remainM = Math.ceil((remainMs % 3600000) / 60000);
                replier.reply(formatError(user, "입항 거절", "항해 직전 성역의 안개가 다시 짙어졌습니다.\n(대기: " + remainH + "시간 " + remainM + "분)"));
                return;
            }
        }
     
        var hasCargo = Object.keys(state.selCargo).length > 0 || Object.keys(state.selSpec).length > 0 || Number(user.unknownCargo || 0) > 0;
        _departVoyage(user, data, replier, roomName, state.dest, cfg, state.selCargo, state.selSpec, state.escortUid, state.escortFee, null, state.isSmuggling);   
        if (data.rooms[roomName].features.states.menuWait) delete data.rooms[roomName].features.states.menuWait[targetUid];
        if (data.rooms["내리다"].features.states.menuWait) delete data.rooms["내리다"].features.states.menuWait[targetUid];
        return;
    }

   // UI에 표시된 '잔여량이 있는 목록'과 로직상의 인덱스를 완벽히 일치시킴
    var parts = input.split(/\s+/);
    var idx = parseInt(parts[0]) - 1;
    
    var availableItems = [];
    var goodsOrder = ["식료품", "공업품", "공예품", "귀금속", "보석", "밀수품"];
    var specOrder = ["돼지고기", "강철", "도자기", "금괴", "다이아몬드"];
    
    var allCargo = {};
    for (var k in (user.warehouse || {})) allCargo[k] = (allCargo[k] || 0) + Number(user.warehouse[k]);

    var processCargoIndex = function(k) {
        var rem = allCargo[k] - Number(state.selCargo[k] || 0);
        if (rem > 0) availableItems.push({ type: 'cargo', name: k, qty: rem });
    };

    goodsOrder.forEach(processCargoIndex);
    for (var k in allCargo) { if(goodsOrder.indexOf(k) === -1) processCargoIndex(k); }

    var allSpec = {};
    for (var s in (user.warehouseSpec || {})) allSpec[s] = (allSpec[s] || 0) + Number(user.warehouseSpec[s]);

    var processSpecIndex = function(s) {
        var remS = allSpec[s] - Number(state.selSpec[s] || 0);
        if (remS > 0) availableItems.push({ type: 'spec', name: s, qty: remS });
    };

    specOrder.forEach(processSpecIndex);
    for (var s in allSpec) {
        if (s === "_rare" || s === "_unknown" || specOrder.indexOf(s) !== -1) continue;
        processSpecIndex(s);
    }

    var unknownCount = Number(allSpec["_unknown"] || 0);
    var remU = unknownCount - Number(state.selSpec["_unknown"] || 0);
    if (remU > 0) availableItems.push({ type: 'unknown', name: "미확인 교역품", qty: remU });

    var rareCount = Number(allSpec["_rare"] || 0);
    var remR = rareCount - Number(state.selSpec["_rare"] || 0);
    if (remR > 0) availableItems.push({ type: 'rare', name: "진귀한 보물", qty: remR });

   if (isNaN(idx) || idx < 0 || idx >= availableItems.length) {
        if (!isNaN(parseInt(parts[0]))) {
            replier.reply(formatError(user, "번호 오류", "현재 화면에 표시된 번호를 입력하세요."));
        }
        return;
    }

    var selected = availableItems[idx];
    
    // 적재 공간 가드
    if (remainingCap <= 0) {
        replier.reply(formatError(user, "적재 공간 부족", "선박의 적재 공간이 가득 찼습니다.\n(최대 " + totalCap + "칸)"));
        return;
    }

    // 수량 입력이 없으면 '남은 용량 전체'를 지정하되, 최대 한도를 초과하지 못하게 억제
    var inputQty = parts.length > 1 ? parseInt(parts[1].replace(/[^0-9]/g, "")) : remainingCap;
    var finalQty = Math.min(inputQty, selected.qty, remainingCap);

    if (selected.type === 'rare') {
        state.selSpec["_rare"] = (state.selSpec["_rare"] || 0) + finalQty;
    } else if (selected.type === 'unknown') {
        state.selSpec["_unknown"] = (state.selSpec["_unknown"] || 0) + finalQty; // 미확인 교역품 선택 저장
    } else if (selected.type === 'cargo') {
        state.selCargo[selected.name] = (state.selCargo[selected.name] || 0) + finalQty;
    } else {
        state.selSpec[selected.name] = (state.selSpec[selected.name] || 0) + finalQty;
    }

    state.time = Date.now();
    safeSaveData(data, true);
    _showTradeCargoSelectUI(user, replier, roomData, cfg, state.dest, state.selCargo, state.selSpec);
}

function _showTradeMarket(user, replier, roomData, cfg) {
    var market = roomData.features.tradeMarket;

    // [방어] 시세 데이터가 아직 생성되지 않았다면 안내
    if (!market || Object.keys(market).length === 0) {
        replier.reply("⚠️ 세계 시세 데이터가 생성 중입니다.\n매시 30분에 첫 시세가 갱신됩니다.");
        return;
    }

    var pData = roomData.features.portData || {};
    var h = new Date().getHours();
    var investStatus = (h >= 7) ? "🟢 투자 가능" : "🔴 투자 마감";

    // [v20.5] 현재 위치 및 정박/항해 상태 실시간 계산 로직 추가
    var curLoc = user.currentLoc || "무역 지부";
    if (user.job === 'pirate' && (curLoc === "무역 지부" || !curLoc)) curLoc = "나소";
    var locStatus = (user.voyage && user.voyage.active) 
        ? (Date.now() < user.voyage.arrival ? " (항해 중 🌊)" : " (항구 도착 ⚓)") 
        : " (정박 완료 ⚓)";
    if (user.voyage && user.voyage.active) curLoc = user.voyage.dest;

    var header = "🌍 세계 무역 시세표 (갱신: 20분)\n" +
                 "━━━━━━━━━━━━━━━\n" +
                 getDisplayName(user) + "님\n" +
                 "📍 현재 위치: " + curLoc + locStatus + "\n\n";

    var list = [];
    var idx = 1;
    // 아이콘 매핑 및 순서 정의
    var goodsIcons = { "식료품":"🍎", "공업품":"⚙️", "공예품":"🏺", "귀금속":"🪙", "보석":"💎" };
    var goodsOrder = ["식료품", "공업품", "공예품", "귀금속", "보석"];

    for (var n in cfg.NATIONS) { 
        var nInfo = market[n];
        var pInfo = pData[n] || { level: 1, totalInvest: 0, governorUid: "", synergyStack: 0 };
        
        var govName = "공석";
        if (pInfo.governorUid && roomData.users[pInfo.governorUid]) {
            govName = "👑" + roomData.users[pInfo.governorUid].name;
        }

       // 1. [상태 판별] 항구의 생산 현황 및 시장 심리 분석
        var portStatusTag = "";
        var producedGood = TRADE_RELATION[n].produce;
        var currentRate = (nInfo.rates && nInfo.rates[producedGood]) ? nInfo.rates[producedGood] : 1.0;

        if (pInfo.synergyStack > 0) portStatusTag += " ✨공정가속";
        else if (currentRate <= 0.80) portStatusTag += " 📉공급과잉";
        else if (currentRate >= 1.20) portStatusTag += " 🔥공급부족";

        // 특산품 대유행 태그 추가 (기존 태그 옆에 이어서 붙음)
        if (pInfo.specialtyBoom) portStatusTag += " 🎊특산품유행";

        // 2. [시세 요약] 스마트 아이콘(✅)을 활용한 한 줄 요약 생성
        var rateLine = "";
        goodsOrder.forEach(function(gKey) {
            var rate = (nInfo.rates && nInfo.rates[gKey]) ? nInfo.rates[gKey] : 1.0;
            var pct = Math.round(rate * 100);
            
            // 특화 매입 품목(85% 이하)인 경우 ✅ 아이콘으로 강조 처리
            var deco = (gKey === producedGood && rate <= 0.85) ? "✅" : goodsIcons[gKey];
            rateLine += deco + pct + "% ";
        });

        // 3. [출력 조립] 깔끔하고 압축된 레이아웃 구성
        var entry = "📍 " + idx + ". " + n + " [Lv." + pInfo.level + "]" + portStatusTag + "\n" +
                    rateLine.trim() + "\n" +
                    "(👤 총독: " + govName + ")";
        list.push(entry);
        idx++;
    }

    var footer = "\n\n↩️ 뒤로 / 🏠 처음으로 / ❎취소\n\n" +
                 "[품목 범례]\n" +
                 "🍎식료품 ⚙️공업품 🏺공예품 🪙귀금속 💎보석\n\n" +
                 "💬 [투자 방법]\n" +
                 "• 번호 입력 시 해당 항구에 투자합니다.\n" +
                 "• 100만P당 발전 레벨이 1단계 상승합니다. (최대 Lv.30)\n" +
                 "• 최고 투자자는 해당 항구의 '총독'이 됩니다.\n" +
                 "━━━━━━━━━━━━━━━\n" +
                 "💡 [가이드]: 메뉴 번호를 입력하세요.";

    replier.reply(header + list.join("\n\n") + footer);
}

/* [서브] 🚢 출항 준비 및 화물 확인 */
function _prepareVoyage(user, replier, cfg, roomData) {
    var durability = Number(user.durability === undefined ? 100 : user.durability);
    var currentLoc = user.currentLoc || "무역 지부";
    var isPirate = (user.job === 'pirate');

    // [v19.3] 해적 전용 출항지 선택지 및 회항(0번) 통합
    if (isPirate) {
        var dest = (currentLoc === "나소") ? "포트로얄" : "나소";
        var nStr = "";
        
        // 0번 회항 메뉴 추가 (포트로얄 등 외지 고립 대비)
        if (currentLoc !== "나소") {
            nStr += "🏠 0. 나소 (회항 및 수리 가능)\n";
        }
        
        nStr += "1. 🚢 " + dest + " (밀수 항로)\n";
        nStr += "\n━━━━━━━━━━━━━━━\n" +
                "💡 해군은 항시 당신을 지켜보고 있습니다.\n" +
                "적발 시 모든 물건을 잃고 회항합니다.\n\n" +
                "↩️ 뒤로 / ❎취소";
        
        replier.reply(formatCommand("🏴‍☠️ 밀수 출항 준비", user, nStr, "번호를 입력하세요."));
        roomData.features.states.menuWait[user.uid] = { type: 'trade_depart', isSmuggling: true, dest: dest, time: Date.now() };
        return true;
    }

    // 1. 기존 내 가방 대신 물류 창고 현황을 불러오도록 변수 교체
    var cargoList = []; 
    var w = user.warehouse || {};
    var ws = user.warehouseSpec || {};
    var goodsOrder = ["식료품", "공업품", "공예품", "귀금속", "보석", "밀수품"];
    var specOrder = ["돼지고기", "강철", "도자기", "금괴", "다이아몬드"];

    goodsOrder.forEach(function(k){ if (w[k] > 0) cargoList.push("• " + k + ": " + w[k] + "상자"); });
    for (var k in w) { if (goodsOrder.indexOf(k) === -1 && w[k] > 0) cargoList.push("• " + k + ": " + w[k] + "상자"); }
    
    specOrder.forEach(function(s){ if (ws[s] > 0) cargoList.push("⭐ " + s + ": " + ws[s] + "상자"); });
    for (var s in ws) { 
        if (s === "_rare" || s === "_unknown" || specOrder.indexOf(s) !== -1) continue;
        if (ws[s] > 0) cargoList.push("⭐ " + s + ": " + ws[s] + "상자"); 
    }
    if (ws["_unknown"] > 0) cargoList.push("📦 미확인 교역품: " + ws["_unknown"] + "상자");
    if (ws["_rare"] > 0) cargoList.push("💎 진귀한 보물: " + ws["_rare"] + "개");

    if (cargoList.length === 0) cargoList.push("- 보관 중인 물자가 없습니다 -");

    var nations = Object.keys(cfg.NATIONS);
    var nStr = ""; 
    var displayIdx = 1;

    // [v19.2] 직업별 고향 항구 판별 (해적: 나소 / 상인: 무역 지부)
    var isPirate = (user.job === 'pirate');
    var homePort = isPirate ? "나소" : "무역 지부";

    // 2. [복귀 메뉴] 현재 위치가 고향이 아닐 때만 0번 노출
    if (currentLoc !== homePort) {
        nStr += "🏠 0. " + homePort + " (회항 및 수리 가능)\n";
    }

    // 3. [일반 항구] 이름만 깔끔하게 나열
    for (var i = 0; i < nations.length; i++) {
        var nName = nations[i];
        if (nName === currentLoc) continue; 
        
        nStr += displayIdx + ". " + nName + "\n";
        displayIdx++;
    }

    /* 엘도라도 */
    if (user.eldoradoUnlocked === true && currentLoc !== ELDORADO_CONFIG.NAME) {
        var lastHidden = Number(user.lastHiddenVoyage || 0);
        var isCool = (Date.now() - lastHidden < ELDORADO_CONFIG.COOLDOWN);
        if (!isCool) {
            nStr += "🌟 9. " + ELDORADO_CONFIG.NAME + " [수익 1.3배 고정]\n";
        } else {
            var remainMs = ELDORADO_CONFIG.COOLDOWN - (Date.now() - lastHidden);
            var remainH = Math.floor(remainMs / 3600000);
            var remainM = Math.ceil((remainMs % 3600000) / 60000);
            nStr += "🔒 " + ELDORADO_CONFIG.NAME + " (대기: " + remainH + "시간 " + remainM + "분)\n";
        }
    } else {
        var maps = Number(user.ancientMaps || 0);
        nStr += "🧱 9. " + ELDORADO_CONFIG.NAME + " (🔒잠김 / 지도 " + maps + "/10장)\n";
    }

    nStr += "\n━━━━━━━━━━━━━━━\n" +
            "💡 👑표시는 당신이 총독인 항구입니다.\n" +
            "도착 시 특산품을 최대 3배 획득합니다!\n\n" +
            "↩️ 뒤로 / 🏠 처음으로 / ❎취소";
            
    replier.reply(formatCommand("🚢 목적지 설정", user, "[📦 물류 창고 현황]\n" + cargoList.join("\n") + "\n\n[출항지 선택]\n" + nStr, "국가 번호를 입력하세요."));
    return true;
}

/* 🌊 항해 시작 (호위 정보 저장 및 메시지 출력 보강) */
function _departVoyage(user, data, replier, roomName, dest, cfg, selC, selS, escortUid, escortFee, extraMsg, isSmuggling) {
    var logicRoom = (roomName === "베릭방" || (typeof ALLOWED_ROOMS !== 'undefined' && ALLOWED_ROOMS.indexOf(roomName) === -1)) ? "내리다" : roomName;
    var roomData = data.rooms[logicRoom];

    // [Gemini 요청] 출항 시 창고(warehouse)에서 차감하도록 변경
    if (!user.warehouse) user.warehouse = {};
    for (var good in selC) {
        var loadQty = Number(selC[good] || 0);
        if (loadQty > 0) {
            user.warehouse[good] = Math.max(0, (Number(user.warehouse[good]) || 0) - loadQty);
            if (user.warehouse[good] <= 0) delete user.warehouse[good];
        }
    }

    if (!user.warehouseSpec) user.warehouseSpec = {};
    for (var spec in selS) {
        if (spec.indexOf("_") === 0) continue; 
        
        var loadSpecQty = Number(selS[spec] || 0);
        if (loadSpecQty > 0) {
            user.warehouseSpec[spec] = Math.max(0, (Number(user.warehouseSpec[spec]) || 0) - loadSpecQty);
            if (user.warehouseSpec[spec] <= 0) delete user.warehouseSpec[spec];
        }
    }

    // 진귀한 보물 차감 (창고 기준)
    var rareLoot = Number(selS["_rare"] || 0);
    if (rareLoot > 0) {
        user.warehouseSpec["_rare"] = Math.max(0, (Number(user.warehouseSpec["_rare"]) || 0) - rareLoot);
        if (user.warehouseSpec["_rare"] <= 0) delete user.warehouseSpec["_rare"];
    }
    
    // [Gemini 패치]: 스냅샷 생성 시 기존 선박 보유분(user.cargo)과 창고 하역분(selC)을 완벽 병합
    var finalCargoSnap = JSON.parse(JSON.stringify(user.cargo || {}));
    for (var c in selC) finalCargoSnap[c] = (finalCargoSnap[c] || 0) + Number(selC[c]);
    
    var finalSpecSnap = JSON.parse(JSON.stringify(user.specialties || {}));
    for (var s in selS) {
        if (s !== "_rare" && s !== "_unknown") {
            finalSpecSnap[s] = (finalSpecSnap[s] || 0) + Number(selS[s]);
        }
    }

    // 미확인 교역품 차감 및 변환 로직 (통합본 기준 연산)
    var totalUnknownCount = Number(user.unknownCargo || 0) + Number(selS["_unknown"] || 0);
    if (totalUnknownCount > 0) {
        var maxQty = -1;
        var maxGoodKey = "";
        for (var good in finalCargoSnap) {
            var currentQty = Number(finalCargoSnap[good] || 0);
            if (currentQty > maxQty) { maxQty = currentQty; maxGoodKey = good; }
        }

        if (maxGoodKey !== "") {
            finalCargoSnap[maxGoodKey] = (Number(finalCargoSnap[maxGoodKey]) || 0) + totalUnknownCount;
            var transformMsg = "✨ [물자 변환]: 미확인 교역품 " + totalUnknownCount + "상자가 수량이 가장 많은 [" + maxGoodKey + "](으)로 변환되어 선적되었습니다.";
            extraMsg = extraMsg ? extraMsg + "\n" + transformMsg : transformMsg;
        } else {
            var destFav = (cfg.NATIONS[dest] && cfg.NATIONS[dest].favorite) ? cfg.NATIONS[dest].favorite : "식료품";
            if (destFav === "NONE" || destFav === "N/A") destFav = "식료품"; 
            finalCargoSnap[destFav] = totalUnknownCount;
            var transformMsg = "✨ [물자 변환]: 선적된 일반 화물이 없어 미확인 교역품 " + totalUnknownCount + "상자가 목적지 선호품인 [" + destFav + "](으)로 자동 변환되었습니다.";
            extraMsg = extraMsg ? extraMsg + "\n" + transformMsg : transformMsg;
        }
        
        // 창고 하역분 차감 및 기존 선박 보유분 초기화
        var selectedUnknownCount = Number(selS["_unknown"] || 0);
        user.warehouseSpec["_unknown"] = Math.max(0, (Number(user.warehouseSpec["_unknown"]) || 0) - selectedUnknownCount);
        if (user.warehouseSpec["_unknown"] <= 0) delete user.warehouseSpec["_unknown"];
        delete selS["_unknown"];
        user.unknownCargo = 0; 
    }

    var totalRareCount = Number(user.rareSpecialties || 0) + Number(selS["_rare"] || 0);
    if (totalRareCount > 0) finalSpecSnap["_rare"] = totalRareCount;

    user.isPillaged = false;

    var mainRoom = data.rooms["내리다"];
    if (mainRoom && mainRoom.features && mainRoom.features.activePillages) {
        if (mainRoom.features.activePillages[user.uid]) {
            delete mainRoom.features.activePillages[user.uid];
        }
    }
    
    var ship = cfg.SHIPS[user.shipLevel || 1];
    
    var baseTimeSec = (60 * ship.speedMult) * 60; 
    var enhSec = Number(user.enhTime || 0);       
    var totalSec = baseTimeSec + enhSec;

    var pol = util_getActivePolicy(roomData);
    if (pol.tradeSpeedMult) {
        totalSec *= pol.tradeSpeedMult;
    }
    
    var isSmooth = Math.random() < 0.1;
    if (isSmooth) {
        totalSec *= 0.8; 
    }
    
    var finalMin = Math.floor(totalSec / 60);
    var finalSec = Math.floor(totalSec % 60);
    var arrival = Date.now() + (totalSec * 1000);

    var wear = Math.floor(Math.random() * 6) + 10; 
    if (user.pediaRewardLevel >= 2) {
        var reduce = Math.floor(Math.random() * 3) + 1;
        wear = Math.max(1, wear - reduce);
    }
    
    user.durability = Math.max(0, (user.durability || 100) - wear);
    user.skipHealing = true;
    
    var currentQuest = (roomData.features && roomData.features.activeContract) ? JSON.parse(JSON.stringify(roomData.features.activeContract)) : null;
    var prevEncountered = (user.voyage && user.voyage.hasEncountered === true);

    // 전체 항해 시간(totalSec) 기반 랜덤 스케줄링 엔진
    var voyageDurationMs = totalSec * 1000;
    
    // 1. 해양 생물 조우 (전체 70% 확률) - 항해 시간의 10% ~ 90% 사이 랜덤 발생
    var schedEncounter = 0;
    if (Math.random() < 0.70) {
        schedEncounter = Date.now() + Math.floor((Math.random() * 0.8 + 0.1) * voyageDurationMs);
    }
    
    // 2. 밀수 단속 (전체 40% 확률) - 항해 시간의 10% ~ 90% 사이 랜덤 발생
    var schedDetect = 0;
    if (isSmuggling && Math.random() < 0.40) {
        schedDetect = Date.now() + Math.floor((Math.random() * 0.8 + 0.1) * voyageDurationMs);
    }

    // 3. AI 해적 100% 확정 조우 (상인 한정, 스텔스 지역 제외) - 항해 시간의 10% ~ 90% 사이 랜덤 발생
    var schedPirate = 0;
    if (!isSmuggling && dest !== ELDORADO_CONFIG.NAME && dest !== "무역 지부" && !user.job) {
        schedPirate = Date.now() + Math.floor((Math.random() * 0.8 + 0.1) * voyageDurationMs);
    }

    // 데이터 패키징 (v.arrival에 최종 계산된 값 저장, 스냅샷에 병합본 적용)
    user.voyage = {
        active: true, 
        dest: dest, 
        origin: user.currentLoc || "무역 지부",
        arrival: arrival, 
        startTime: Date.now(),
        isSmuggling: !!isSmuggling,
        hasEncountered: prevEncountered, 
        contractSnapshot: currentQuest, 
        marketSnapshot: JSON.parse(JSON.stringify(roomData.features.tradeMarket || {})), 
        portSnapshot: JSON.parse(JSON.stringify(roomData.features.portData || {})), 
        ecoMultSnapshot: util_getEcoMultiplier(roomName),
        cargoSnapshot: finalCargoSnap, 
        specialtySnapshot: finalSpecSnap,
        escortUid: escortUid || null,
        escortFee: escortFee || 0,
        isSmooth: isSmooth,
        isProcessing: false,
        scheduledEncounterTime: schedEncounter,
        scheduledDetectTime: schedDetect,
        scheduledPirateTime: schedPirate
    };
    
    safeSaveData(data, true); 

    var msg = "목적지: " + dest + "\n" +
              "소요 시간: " + finalMin + "분 " + finalSec + "초\n" +
              "도착 예정: " + new Date(arrival).toLocaleTimeString();
              
    if (isSmooth) msg += "\n\n🌬️ [순풍] 기분 좋은 바람으로 시간이 20% 단축되었습니다!";
    
    // 호위함 동행 시 출항 메시지에 호위 해군 닉네임 표시 로직 추가
    if (escortUid) {
        var navyName = "해군 호위함";
        for (var r in data.rooms) { 
            if (data.rooms[r].users[escortUid]) { 
                navyName = data.rooms[r].users[escortUid].name; 
                break; 
            } 
        }
        msg += "\n🛡️ [호위함 동행]: " + navyName + " 함대가 선단을 보호합니다.";
    }
    
    if (extraMsg) {
        msg += "\n\n" + extraMsg;
    }
    
    replier.reply(formatCommand("🌊 출항 명령 하달", user, msg, "항해 중 타 활동이 가능합니다."));
}

/* 📦 항해 현황판 (호위함 표시 추가) */
function _showVoyageStatus(user, replier, data, roomName) {
    var msg = "";
    if (!user.voyage || user.voyage.active !== true) {
        var emptyBody = "현재 운항 중인 선박이 없습니다.\n무역 물자를 싣고 넓은 바다로 나가보세요!\n\n" +
                        "↩️ 뒤로 / 🏠 처음으로 / ❎취소";
        replier.reply(formatCommand("📦 항해 현황", user, emptyBody, "출항 준비: [2]번 메뉴를 선택하세요."));
        return;
    }
    var v = user.voyage;
    var remain = (v.arrival || 0) - Date.now();
    if (v.isPatrol) {
        var timeStr = remain > 0 ? Math.ceil(remain/60000) + "분" : "순찰 완료 (정산 대기)";
        var patrolBody = "현재 [" + v.dest + "] 해역을 순찰 중입니다.\n\n" +
                         "🛡️ 임무: 적대적 AI 해적 탐색 및 소탕\n" +
                         "🕒 남은 시간: " + timeStr + "\n\n" +
                         "👉 순찰 중에는 다른 행동이 제한됩니다.";
        replier.reply(formatCommand("🚢 해역 순찰 현황", user, patrolBody, "순찰 완료 시 자동 귀항합니다."));
        return; // 무역 계산을 하지 않고 즉시 리턴
    }

    var cfg = SYSTEM_CONFIG.TRADE;

    // roomData 변수 선언 추가 (메인방 고정 참조로 교체)
    var economyRoomName = (roomName === "베릭방" || ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var roomData = data.rooms[economyRoomName];
    
    // [v15.9] 현황판 강화 수치 연동
    var shipCapacity = cfg.SHIPS[user.shipLevel || 1].capacity + (user.enhLimit || 0);
    
    var tRev = 0; var tCost = 0;
    var currentCargoLines = [];
    var totalCargoInShip = 0;

    var nSnap = (v.marketSnapshot && v.marketSnapshot[v.dest]) ? v.marketSnapshot[v.dest] : { favorite: "N/A", hate: "N/A" };
    var pInfo = (roomData.features && roomData.features.portData && roomData.features.portData[v.dest]) 
                ? roomData.features.portData[v.dest] : { level: 1 };
    var portLevelBonus = Number((pInfo.level - 1) * (cfg.INVEST.BONUS_PER_LEVEL || 0.01));

    var goodsOrder = ["식료품", "공업품", "공예품", "귀금속", "보석", "밀수품"];
    var specOrder = ["돼지고기", "강철", "도자기", "금괴", "다이아몬드"];

    var cSnap = v.cargoSnapshot || {};
    var processCargo = function(g) {
        var qty = Number(cSnap[g]); if (qty <= 0) return;
        currentCargoLines.push("      • " + g + " " + qty + "상자");
        totalCargoInShip += qty;
        var myPurchasePrice = Number((user.cargoAvg && user.cargoAvg[g]) || cfg.GOODS_COST[g]);
        var itemCost = myPurchasePrice * qty;
        tCost += itemCost;

        var mult = (v.marketSnapshot[v.dest] && v.marketSnapshot[v.dest].rates && v.marketSnapshot[v.dest].rates[g]) 
                    ? v.marketSnapshot[v.dest].rates[g] : 1.0;

        if (pInfo && pInfo.built && pInfo.built.market) {
            mult += 0.005;
        }
        
        var baseTargetCost = cfg.GOODS_COST[g] || 10000;
        tRev += Math.floor(baseTargetCost * mult * qty);
    };

    goodsOrder.forEach(function(g) { if(cSnap[g] !== undefined) processCargo(g); });
    for(var g in cSnap) { if(goodsOrder.indexOf(g) === -1) processCargo(g); }

    var sSnap = v.specialtySnapshot || {};
    var processSpec = function(s) {
        var sQty = Number(sSnap[s]); if (sQty <= 0) return;
        currentCargoLines.push("    ⭐" + s + " " + sQty + "상자");
        totalCargoInShip += sQty;
        var pG = "";
        for (var n in TRADE_RELATION) { if (TRADE_RELATION[n].set === s) { pG = TRADE_RELATION[n].produce; break; } }
        var sBase = 20000; // 통일된 원가 적용
        var sRate = (v.marketSnapshot[v.dest] && v.marketSnapshot[v.dest].rates && v.marketSnapshot[v.dest].rates[pG])
                    ? v.marketSnapshot[v.dest].rates[pG] : 1.0;
        
        var producedByDest = (TRADE_RELATION[v.dest]) ? TRADE_RELATION[v.dest].produce : "";
        var finalSmult = (pG === producedByDest) ? 0 : (sRate * cfg.SPECIALTY_PROFIT);

        tCost += (sBase * sQty);
        tRev += Math.floor(sBase * sQty * finalSmult);
    };

    specOrder.forEach(function(s) { if(sSnap[s] !== undefined) processSpec(s); });
    for(var s in sSnap) { 
        if(s === "_rare" || s === "_unknown" || specOrder.indexOf(s) !== -1) continue; 
        processSpec(s); 
    }

    var rareQty = Number(sSnap["_rare"]);
    if (rareQty > 0) {
        currentCargoLines.push("💎 진귀한 보물 " + rareQty + "개");
        totalCargoInShip += rareQty;
        tRev += (100000 * rareQty); 
    }

    // 1. 기초 마진에 선박 효율을 먼저 곱하여 '세전 기대 수익'을 확정합니다.
    var shipEff = (user.shipLevel === 1) ? 3.5 : (user.shipLevel === 2 ? 1.5 : 1.0);
    var baseMarginWithEff = Math.floor((tRev - tCost) * shipEff);

    // 2. 항구 발전 레벨을 참조하여 보너스 금액을 산출합니다. (레벨당 1%)
    var pInfo = (data.rooms[roomName].features.portData && data.rooms[roomName].features.portData[v.dest]) ? data.rooms[roomName].features.portData[v.dest] : { level: 1 };
    var portLevelRate = Number((pInfo.level - 1) * 0.01);
    var bonusAmt = baseMarginWithEff > 0 ? Math.floor(baseMarginWithEff * portLevelRate) : 0;

   // 3. 최종 마진 = (기초 수익 * 효율) + 발전도 보너스
    var margin = baseMarginWithEff + bonusAmt;

    // [v15.9.4] 초월 강화 수익 보너스(enhProfit) 현황판 반영
    var profitBonusMult = 1 + ((user.enhProfit || 0) / 100);
    var enhancedBaseMargin = Math.floor(baseMarginWithEff * profitBonusMult); // 순수익에만 강화 적용
    var margin = enhancedBaseMargin + bonusAmt; // 발전도 보너스는 단순 합산

    var enhProfitTag = (user.enhProfit > 0) ? " (✨수익강화 +" + user.enhProfit + "%)" : "";

    var taxRate = (user.title === "기부왕") ? 0.05 : 0.10;

    /* afterTaxMargin 변수를 선언하여 정의되지 않음 에러 해결 */
    var taxAmt = margin > 0 ? Math.floor(margin * taxRate) : 0;
    var afterTaxMargin = margin - taxAmt;

    if (v.escortFee) afterTaxMargin -= v.escortFee;
    if (margin > 0) afterTaxMargin -= Math.floor(margin * 0.01); 

    var crInfo = getCreditInfo(user.creditScore, roomName);
    var creditMult = util_getTradeCreditMult(crInfo.grade);
    var estimatedNetProfit = Math.floor(afterTaxMargin * creditMult);
    var finalReceipt = tCost + estimatedNetProfit;

    // 호위 정보 텍스트 추가
    var escortText = "⚪ [단독 항해 중]";
    if (v.escortUid) {
        var nObj = null;
        for (var r in data.rooms) { if (data.rooms[r].users[v.escortUid]) { nObj = data.rooms[r].users[v.escortUid]; break; } }
        escortText = "🛡️ [호위 중]: " + (nObj ? nObj.name : "해군함");
    }

    var displayBody = "현재 [" + v.dest + "]로 항해 중\n" + escortText + "\n\n" +
                      "📦 적재함: " + totalCargoInShip + " / " + shipCapacity + " 칸\n" + currentCargoLines.join("\n") + "\n\n" +
                      "💰 예상 수령액: " + fp(finalReceipt) + "P\n" +
                      "💵 예상 순이익: " + fp(estimatedNetProfit) + "P" + enhProfitTag + "\n" +
                      "🕒 남은 시간: " + (remain > 0 ? Math.ceil(remain/60000) + "분" : "도착 완료") + "\n\n" +
                      "👉 회항: [긴급회항]";

    var nextGuide = "도착 후 정산";
    
