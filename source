    // 설명: 유저가 다른 명령어(/무역 등)를 쳐서 세션 상태표가 덮어씌워지더라도, 백그라운드에서 시간을 추적하여 무조건 알림을 띄웁니다.
    var mainRoom = data.rooms["내리다"];
