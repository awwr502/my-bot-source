                mainRoomData.features.ventureFund = { round: 1, status: 'closed', fleetName: "", survivalRate: 100, payoutMult: 0, bets: {}, totalPool: 0, lastUpdateMin: -1, lastCloseMin: -1 };
                venture = mainRoomData.features.ventureFund;
            }

            var isVentureTime = (currentHour >= vCfg.OPEN_HOUR && currentHour <= vCfg.CLOSE_HOUR) || (currentHour === 0 && currentMin === 0);

