function _applySetEffects(user) {
    var eq = user.dgnEquip;
    var s = user.dgnStat;
    
    // 기본 장비 스탯은 장착 시마다 누적되므로, 여기서는 '세트 조건'이 맞을 때만 특수 패시브(스탯 추가)를 부여합니다.
    // 기존 세트 효과 중첩 방지를 위해 임시 보너스 필드를 0으로 초기화
    s.setBonusAgi = 0;
    
    var wName = eq.weapon ? eq.weapon.name : "";
    var aName = eq.armor ? eq.armor.name : "";

    // [세트효과: 고블린 족장의 위엄] 투구 + 무기(족장의 몽둥이-예시) 등 조건 충족 시 AGI 15 증가
    // 현재 DB엔 '족장의 투구'만 있으므로, 무기가 '초보자의 검'일 때 발동하는 초보자 세트로 임시 구현
    if (wName === "초보자의 검" && aName === "가죽 갑옷") {
        s.setBonusAgi += 5; 
        // 실시간 민첩성 상승으로 회피/도망 확률이 높아집니다.
    }
}

