        return replier.reply(formatError(user, "번호 오류", "목록에 있는 번호를 선택하세요."));
    }

    var selected = cfg[keys[choice-1]];
    
    if (pData.built[selected.key]) {
        return replier.reply(formatError(user, "중복 건설", "이미 해당 건물은 건설되어 있습니다."));
