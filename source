/**
 * [v15.0] 탄환 추적형 세션 청소 엔진 (구문 무결성 검증 완료)
 * 기능: 어느 방에서 세션을 발견하든, 알림은 유저가 실제 대화 중인 방(originRoom)으로만 보냅니다.
 */
function util_autoClearTimeouts(data) {
    var now = Date.now();
    var notifiedInThisCycle = {};
    var isChanged = false; // 변경 발생 여부 추적
    
    // [최적화] 전체 rooms 대신 ALLOWED_ROOMS만 순회하여 CPU 부하 90% 절감
    ALLOWED_ROOMS.forEach(function(rName) {
        var roomObj = data.rooms[rName];
        if (!roomObj || !roomObj.features || !roomObj.features.states) return;
        
        var states = roomObj.features.states;
        var queues = ["menuWait", "bankProcess", "selectWait"];

        queues.forEach(function(qKey) {
            var q = states[qKey];
            if (!q) return;
            for (var uid in q) {
                var entry = q[uid];
                
                // [안전 가드] 이미 타임아웃 처리된 좀비 세션이면 무시
                if (entry._isExpired) continue; 

                var startTime = entry.time || entry.timestamp || 0;
                
                // [v18.3 핵심] 유저 데이터(voyage.encounter)를 직접 확인하여 마스터 권한 부여
                var u = (data.rooms["내리다"] && data.rooms["내리다"].users[uid]) ? data.rooms["내리다"].users[uid] : null;
                // 오직 '해양 조우(marine_encounter)' 창 그 자체만 3분을 대기하도록 엄격히 분리합니다.
                var isMarineSession = (entry.type === 'marine_encounter');
                var threshold = isMarineSession ? 180000 : 30000;
                
                if (startTime > 0 && (now - startTime > threshold)) {
                    // [좀비 부활 방지] 사망 선고 플래그 박기
                    entry._isExpired = true; 
                    isChanged = true;

                    // [v18.5 보험 엔진 연결] 세션 종료 및 환불 여부 확인
                    var actualOrigin = entry.originRoom || rName;
                    var refundInfo = util_terminateSession(uid, u, data.rooms[rName], actualOrigin, qKey);

                    if (!notifiedInThisCycle[uid] && u) {
                        try {
                            if (entry.type === 'marine_encounter') {
                                // 거대 생물 전용 타임아웃 (3분 경과)
                                var timeoutMsg = "🌊 [상황 종료: 생물 소멸]\n" +
                                                 "━━━━━━━━━━━━━━━\n" +
                                                 getDisplayName(u) + "님\n" +
                                                 "거대 생물이 수면 아래로 깊이 잠영하여\n" +
                                                 "더 이상 자취를 찾을 수 없습니다.\n" +
                                                 "━━━━━━━━━━━━━━━\n" +
                                                 "💡 기회를 놓치셨습니다. 항해를 계속하세요.";
                                Api.replyRoom(actualOrigin, timeoutMsg);
                                if (u.voyage) delete u.voyage.encounter;
                            } else {
                                // 일반 메뉴 타임아웃 (30초 경과)
                                var errorMsg = "30초 이내에 응답이 없어 메뉴가 닫혔습니다." + refundInfo;
                                Api.replyRoom(actualOrigin, formatError(u, "입력 시간 초과", errorMsg));
                                
                                // 💡 [팝업 엔진 연동] 방금 닫힌 게 일반 메뉴인데, 뒤에 생물이 숨어있다면 즉시 복구시킴!
                                if (typeof util_restoreEncounterPopup === 'function') {
                                    util_restoreEncounterPopup(u, null, data, actualOrigin, uid, true);
                                }
                            }
                            notifiedInThisCycle[uid] = true;
                        } catch(e) { Log.error("Timeout Notify Error: " + e); }
                    }
                    
                    // [v18.2 핵심] '내리다' 방과 '실제방' 뿐만 아니라 전 구역의 미러링 세션을 즉시 파기
                    for (var targetRoom in data.rooms) {
                        if (data.rooms[targetRoom].features && data.rooms[targetRoom].features.states) {
                            var ts = data.rooms[targetRoom].features.states;
                            if (ts[qKey]) delete ts[qKey][uid];
                        }
                    }
                }
            }
        });
    });

    // [중복 억제 핵심] 세션이 하나라도 파기되었다면 즉시 물리 저장하여 롤백에 의한 부활을 원천 차단
    if (isChanged && typeof safeSaveData === 'function') {
        safeSaveData(data, true);
    }
}

/**
 * [원자적 개편: 범용 데이터 게이트웨이] v2.0
