                    var lastAct = u.lastJobActivityTime || new Date(u.jobJoinDate).getTime() || 0;
                    if (nowTs - lastAct > oneWeekMs) {
                        var jobName = (u.job === 'pirate' ? "해적" : "해군");
                        // [v20.2 교정] 강제 박탈 시에도 함선 데이터 안전하게 스왑 백업
                        u.combatShipLevel = Number(u.shipLevel || 1);
                        u.combatEnhLimit = Number(u.enhLimit || 0);
                        u.combatEnhTime = Number(u.enhTime || 0);
