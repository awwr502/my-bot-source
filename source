}

// 🚢 AI 다국적 상단 엔진 (Real Entity Trade)
function _runAITradeScheduler(data, ctx) {
    var mainRoom = data.rooms["내리다"];
    if (!mainRoom || !mainRoom.users) return;

    var aiNames = [
        "영국 왕립 무역선", "네덜란드 동인도 회사", "스페인 무적함대 상단", "포르투갈 인도 함대", "프랑스 해운 조합",
        "베네치아 상인 길드", "제노바 해상 조합", "오스만 제국 상단", "바이킹 교역선", "명나라 정화 함대",
        "신성 로마 제국 상단", "비잔틴 해상 무역로", "카르타고 황금 함대", "피렌체 대상단", "아라비아 낙타 상단",
        "이탈리아 르네상스 상단", "스칸디나비아 개척단", "아메리카 신대륙 상단", "동양 실크로드 교역선", "아프리카 희망봉 상단"
    ];
    var nations = ["포르투", "코콜라", "나폴리", "베라크루스", "킴벌리"];
    var goods = ["식료품", "공업품", "공예품", "귀금속", "보석"];

    // 운영 개수 5개 -> 20개로 상향
    for (var i = 0; i < 20; i++) {
        var aiUid = "AI_BOT_" + i;
        var aiUser = mainRoom.users[aiUid];

        // 1. AI 계정 영구 상주화
        if (!aiUser) {
            aiUser = {
                uid: aiUid, name: "🚢 " + (aiNames[i] || "다국적 상단 " + i), point: 10000000, bank: 0,
                job: null, shipLevel: 3, // 선박 레벨은 더 이상 고정 속도에 쓰이지 않음
                enhLimit: 0, 
                enhTime: 0,
                currentLoc: nations[i % nations.length], // 초기 정박 항구 분산 배치
                cargo: {}, specialties: {},
                voyage: { active: false }
            };
            mainRoom.users[aiUid] = aiUser;
        }

        // 2. 항해 중이 아닐 때 (정박 중) -> 화물 매입 및 출항
        if (!aiUser.voyage || aiUser.voyage.active === false) {
            var pData = (mainRoom.features.portData && mainRoom.features.portData[aiUser.currentLoc]) ? mainRoom.features.portData[aiUser.currentLoc] : null;
            var buyGood = goods[Math.floor(Math.random() * goods.length)];
            
            // 적재량: 최소 40 ~ 최대 300 상자 랜덤 매입
            var buyQty = Math.floor(Math.random() * (300 - 40 + 1)) + 40;

            // [실물 경제] 출발지 항구 재고 차감 (매입으로 인한 시세 상승 효과)
            if (pData && pData.inventory && aiUser.currentLoc !== "무역 지부" && aiUser.currentLoc !== "나소") {
                var curStock = Number(pData.inventory[buyGood] || 2000);
                if (curStock >= buyQty) {
                    pData.inventory[buyGood] = curStock - buyQty;
                    if (typeof util_refreshMarketRate === 'function') util_refreshMarketRate(mainRoom, aiUser.currentLoc, buyGood);
                }
            }

            var dests = nations.filter(function(n) { return n !== aiUser.currentLoc; });
            var dest = dests[Math.floor(Math.random() * dests.length)];
            
            // 항해 속도: 최소 12분 30초(750초) ~ 최대 30분(1800초) 사이 무작위 설정
            var totalSec = Math.floor(Math.random() * (1800 - 750 + 1)) + 750;
            
            var cargoSnap = {};
            cargoSnap[buyGood] = buyQty;

            aiUser.voyage = {
                active: true, dest: dest, origin: aiUser.currentLoc,
                arrival: Date.now() + (totalSec * 1000),
                startTime: Date.now(),
                cargoSnapshot: cargoSnap, specialtySnapshot: {},
                // 모든 AI 상단은 정규 AI 해군의 철통 호위를 받음 (레벨 5~10 랜덤)
                escortUid: "AI_NAVY_ELITE", 
                escortLevel: Math.floor(Math.random() * 6) + 5,
                scheduledPirateTime: (Math.random() < 0.50) ? Date.now() + Math.floor(Math.random() * (totalSec * 0.5) * 1000) : 0
            };
            aiUser.currentLoc = dest;
            ctx.isUpdated = true;
        }

        // 3. 목적지 도착 -> 화물 매각 및 정산
        if (aiUser.voyage && aiUser.voyage.active === true && Date.now() >= aiUser.voyage.arrival) {
            var v = aiUser.voyage;
            var pDataTarget = (mainRoom.features.portData && mainRoom.features.portData[v.dest]) ? mainRoom.features.portData[v.dest] : null;

            // [실물 경제] 도착지 항구에 화물 공급 (매각으로 인한 시세 하락 효과)
            if (pDataTarget && pDataTarget.inventory && v.dest !== "무역 지부" && v.dest !== "나소") {
                for (var g in v.cargoSnapshot) {
                    var qty = Number(v.cargoSnapshot[g] || 0);
                    // 해적에게 약탈당한 경우 물건을 뺏겼으므로 시장에 풀리는 양이 절반으로 깎임
                    if (v.isPillaged) qty = Math.floor(qty * 0.5);

                    if (qty > 0) {
                        pDataTarget.inventory[g] = (Number(pDataTarget.inventory[g]) || 2000) + qty;
                        if (typeof util_refreshMarketRate === 'function') util_refreshMarketRate(mainRoom, v.dest, g);
                    }
                }
            }
            aiUser.voyage.active = false;
            aiUser.voyage.isPillaged = false;
            aiUser.isPillaged = false;
            ctx.isUpdated = true;
        }
    }
}

/**
 * 🏴‍☠️ 글로벌 AI 해적 스케줄러 (무역 항로 기반 30분 활동)
 */
function _runAIPirateScheduler(data, ctx) {
    if (!data.aiPirates) data.aiPirates = [];
    if (!data.safeRoutes) data.safeRoutes = {};
    
    var nations = ["포르투", "코콜라", "나폴리", "베라크루스", "킴벌리"];
    var now = Date.now();
    
    // 1. 20마리 개체 유지
    while(data.aiPirates.length < AI_PIRATE_CONFIG.COUNT) {
        var names = ["검은수염", "바르바로사", "붉은돛", "유령선", "카리브늑대", "바다의사신", "심해의약탈자", "크라켄의눈", "블러드마리", "해골군단"];
        data.aiPirates.push({
            uid: "AI_PIRATE_BOT_" + data.aiPirates.length,
            name: names[Math.floor(Math.random() * names.length)] + " 함대 " + (data.aiPirates.length + 1),
            shipLevel: Math.floor(Math.random() * 6) + 3, // 3~8레벨
            status: 'cooldown', // 'sailing', 'cooldown'
            route: "",
            endTime: now + Math.floor(Math.random() * 60000) // 초기 분산을 위해 랜덤 오프셋
        });
    }

    var isUpdated = false;
    // 2. 상태 갱신 및 항로 할당
    for (var i = 0; i < data.aiPirates.length; i++) {
        var p = data.aiPirates[i];
        if (now >= p.endTime) {
            if (p.status === 'cooldown') {
                var origin = nations[Math.floor(Math.random() * nations.length)];
                var dests = nations.filter(function(n) { return n !== origin; });
                var dest = dests[Math.floor(Math.random() * dests.length)];
                
                p.status = 'sailing';
                p.route = origin + "-" + dest;
                p.endTime = now + AI_PIRATE_CONFIG.SAIL_TIME_MS; // 30분 항해
                isUpdated = true;
            } else if (p.status === 'sailing') {
                // 30분 항해 끝, 바로 다른 항로로 재배치 (연속 활동)
                var origin = p.route.split("-")[1] || nations[Math.floor(Math.random() * nations.length)];
                var dests = nations.filter(function(n) { return n !== origin; });
                var dest = dests[Math.floor(Math.random() * dests.length)];
                
                p.route = origin + "-" + dest;
                p.endTime = now + AI_PIRATE_CONFIG.SAIL_TIME_MS;
                isUpdated = true;
            }
        }
    }
    
    // 3. 청정 구역(safeRoutes) 만료 체크
    for (var rKey in data.safeRoutes) {
        if (now >= data.safeRoutes[rKey]) {
            delete data.safeRoutes[rKey];
            isUpdated = true;
        }
    }
    
    if (isUpdated) ctx.isUpdated = true;
}

