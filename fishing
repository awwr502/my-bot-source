    # 텔레그램 모드가 켜져 있을 때만 원격 제어 안내 간판을 띄웁니다.
    if USE_TELEGRAM:
        bprint(f"\n>>> 원격 제어 수신 대기 시작 (명령어: {CMD_PREFIX}낚시시작, {CMD_PREFIX}릴레이시작, {CMD_PREFIX}승리시작1, {CMD_PREFIX}승리시작2, {CMD_PREFIX}정지, {CMD_PREFIX}종료, {CMD_PREFIX}보고서, {CMD_PREFIX}상태) <<<")
    
    state = -1
    # 로켓 이모지 앞에 \n(엔터키)을 추가하여 위쪽 문구와 한 줄 띄워지도록 틈을 만듭니다.
    bprint("\n🚀낚시 매크로 V2.4 가동 시작🚀")
    bprint("(작동: ] , 정지: [ , 릴레이모드: ; , 승리모드1: > , 승리모드2: ? , 동물포획: ' , 망각모드: < )")

    cast_fail_count = 0 # 연속 캐스팅 실패 감지용 카운터
    
    # [워치독] 상태 추적용 변수 초기화
    last_state = state
    state_start_time = time.time()
    force_watchdog_reason = None # [신규] 명시적 워치독 트리거 사유

    def auto_equip_rod():
        """3곳에 흩어진 낚싯대 장착 로직을 통합한 단일 모듈"""
        nonlocal force_watchdog_reason, cast_fail_count
        global check_char_popup
    
        # [초고속 레이스 컨디션 방어] 화면 캡처가 너무 빨라 파손 직후의 잔상 UI를 장착 완료 상태로 오해하는 현상을 방지하기 위해 최소 안정화 지연을 부여합니다.
        time.sleep(0.4)
    
        swap_attempts = 0
        while bot_active:
            if check_exit_notification():
                return False
                
            # 플래그가 True 일 때만 자정 팝업을 체크합니다.
            if check_char_popup and safe_find_image('popup_char.png', 0.75):
                bprint("  > 💡 [자정 팝업] 장착 중 팝업 감지! ESC 1회 입력...")
