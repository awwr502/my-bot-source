/* [상인] 호위 해군 리스트 출력 및 고용 프로세스 시작 */
function _handleEscortHire(choice, user, data, replier, roomName, targetUid) {
    var roomData = data.rooms[roomName];
    var state = roomData.features.states.menuWait[targetUid];
    var cargoSnap = state.selCargo || {};
    var specSnap = state.selSpec || {};
    var tradeCfg = SYSTEM_CONFIG.TRADE;
    var market = roomData.features.tradeMarket || tradeCfg.NATIONS;
    var nInfo = (state.dest === "무역 지부" || state.dest === "나소") ? { favorite: "N/A", hate: "N/A" } : (market[state.dest] || { favorite: "N/A", hate: "N/A" });

    // 1. 예상 마진 계산 (수익 - 원가)
    var totalEstRevenue = 0;
    var totalEstCost = 0;
    
    // 일반 화물 계산
    for (var g in cargoSnap) {
        var count = Number(cargoSnap[g]);
        var uCost = Number((user.cargoAvg && user.cargoAvg[g]) || tradeCfg.GOODS_COST[g]);
        totalEstCost += (uCost * count);
        
        var rInfo = SYSTEM_CONFIG.PROFIT_RATES[g] || { pref: 1.25, norm: 1.05, hate: 0.8 };
        var mult = (g === nInfo.favorite) ? rInfo.pref : (g === nInfo.hate ? rInfo.hate : rInfo.norm);
        totalEstRevenue += Math.floor(uCost * mult * count);
    }
    // 특산품 계산
    for (var s in specSnap) {
        var sCount = Number(specSnap[s]);
        var pG = "";
        for (var rel in TRADE_RELATION) { if (TRADE_RELATION[rel].set === s) { pG = TRADE_RELATION[rel].produce; break; } }
        var sBase = tradeCfg.SPECIALTY_COST[pG] || 10000;
        totalEstCost += (sBase * sCount);
        
        var sMult = (pG === nInfo.favorite) ? tradeCfg.SPECIALTY_PROFIT : (pG === nInfo.hate ? 0.5 : 1.0);
        totalEstRevenue += Math.floor(sBase * sCount * sMult);
    }

    var estMargin = totalEstRevenue - totalEstCost;
    // 호위 보호세를 매출 기준이 아닌 순이익(estMargin)의 5%로 변경 (최소 1,000P 보장)
    var totalTax = Math.max(1000, Math.floor(estMargin * (tradeCfg.JOBS.ESCORT_FEE_RATE || 0.05)));

    // 현재 호위 임무 중인 해군 UID 수집 (1:1 매칭 보장)
    var busyNavies = [];
    var now = Date.now();
    for (var rName in data.rooms) {
        var rObj = data.rooms[rName];
        for (var uId in rObj.users) {
            var v = rObj.users[uId].voyage;
            // 해군 가용 상태 판정: 상인이 정산 버튼을 누르지 않았더라도(active === true),
            // 항해 완료 시간(arrival)이 지났다면 해당 해군은 'Busy' 목록에서 제외 (즉시 고용 가능)
            if (v && v.active === true && v.escortUid) {
                if (now < (v.arrival || 0)) {
                    busyNavies.push(v.escortUid);
                }
            }
        }
    }

    // 2. 현재 활동 가능한(퇴각 중이 아니며, 항해 타이머가 끝난) 해군 리스트 추출
    var navyList = [];
    for (var r in data.rooms) {
        for (var uid in data.rooms[r].users) {
            var u = data.rooms[r].users[uid];
            if (u.job === 'navy' && uid !== targetUid) {
                // 퇴각(정비) 중인지 체크
                if (u.retreatEndTime && Date.now() < u.retreatEndTime) continue;
                // 이미 호위 중인 해군은 목록에서 제외
                if (busyNavies.indexOf(uid) !== -1) continue;
                
                navyList.push({ uid: uid, name: u.name, shipLevel: (u.shipLevel || 1) });
            }
        }
    }

    // [반영] 가용 해군이 5명 미만일 때 AI 해군(정규군)으로 리스트 강제 채움
    if (navyList.length < 5) {
        var aiNavyNames = [
            "영국 왕립 함대", "스페인 무적 함대", "프랑스 해상방위 함대", 
            "네덜란드 제 7함대", "포르투갈 인도 함대", "카리브 토벌함대", 
            "지중해 연합함대"
        ];

        // 이름 목록을 무작위로 섞음 (중복 느낌 방지)
        aiNavyNames.sort(function() { return Math.random() - 0.5; });

        var needed = 5 - navyList.length;
        for (var i = 0; i < needed; i++) {
            var hr = Math.random() * 100;
            var hiredAiLevel = 1;
            if (hr < 14) hiredAiLevel = 1;
            else if (hr < 27) hiredAiLevel = 2;
            else if (hr < 39) hiredAiLevel = 3;
            else if (hr < 50) hiredAiLevel = 4;
            else if (hr < 60) hiredAiLevel = 5;
            else if (hr < 69) hiredAiLevel = 6;
            else if (hr < 77) hiredAiLevel = 7;
            else if (hr < 85) hiredAiLevel = 8;
            else if (hr < 93) hiredAiLevel = 9;
            else hiredAiLevel = 10;

            navyList.push({
                uid: "AI_NAVY_BOT_" + i,
                name: aiNavyNames[i] || ("연합 보조함대 " + (i + 1)),
                shipLevel: hiredAiLevel, // 보정된 확률 적용
                isAI: true
            });
        }
    }

    // [정렬 규칙] 1. 유저 해군 우선(isAI: false) 2. 선박 레벨(ShipLevel)이 높은 순
    navyList.sort(function(a, b) {
    // 유저(false)를 AI(true)보다 우선순위로 정렬
    if (!!a.isAI !== !!b.isAI) return a.isAI ? 1 : -1;
    // 유저끼리 혹은 AI끼리는 선박 레벨이 높은 순서로 정렬
    return b.shipLevel - a.shipLevel;
});

    var body = "🛡️ [해군 호위단 모집]\n" +
               "━━━━━━━━━━━━━━━\n" +
               "현재 고용 가능한 함대 목록입니다.\n" +
               "(예상 순이익 기준 보호세: " + fp(totalTax) + "P)\n\n";

    navyList.forEach(function(n, i) {
        // [반영] AI와 유저 해군 아이콘 구분 표시
        var typeIcon = n.isAI ? "🤖" : "👮";
        body += (i + 1) + ". " + typeIcon + " " + n.name + " (선박 Lv." + n.shipLevel + ")\n";
    });

    body += "\n0. 호위 없이 단독 출항\n" +
            "━━━━━━━━━━━━━━━\n" +
            "💡 [가이드]: 고용할 해군의 번호를 입력하세요.\n" +
            "[0] 입력 시 즉시 출항합니다.";

    // 세션 상태 업데이트 (호위 고용 대기)
    state.type = 'trade_escort_confirm';
    state.extra = { navyList: navyList, totalTax: totalTax };
    state.time = Date.now();

    replier.reply(formatCommand("🛡️ 호위 해군 선택", user, body));
}

/* [상인] 호위 해군 선택 확정 및 출항 처리 (숫자 입력 핸들러) */
function _handleEscortConfirm(msg, user, data, replier, roomName, targetUid, cfg) {
    var roomData = data.rooms[roomName];
    var state = roomData.features.states.menuWait[targetUid];

    if (!state || state.type !== 'trade_escort_confirm') return false;

    // 1. 중복 진입 차단 (이미 깃발이 꽂혀있다면 무시)
    if (state.isProcessing === true) return; 

    var choice = parseInt(msg.replace(/[^0-9]/g, ""));
    if (isNaN(choice) || choice < 0 || choice > state.extra.navyList.length) {
        return replier.reply(formatError(user, "번호 오류", "0~" + state.extra.navyList.length + "번 사이를 선택하세요."));
    }

    // 2. 점유 시작 (로직 진입 전 깃발 꽂기)
    state.isProcessing = true;

    // [헬퍼] 전 구역 세션 삭제 함수
    var clearSession = function() {
        if (roomData.features.states.menuWait) delete roomData.features.states.menuWait[targetUid];
        if (data.rooms["내리다"] && data.rooms["내리다"].features.states.menuWait) {
            delete data.rooms["내리다"].features.states.menuWait[targetUid];
        }
    };

    // 0번 선택 시 단독 출항
    if (choice === 0) {
        _departVoyage(user, data, replier, roomName, state.dest, cfg, state.selCargo, state.selSpec);
        clearSession(); // 성공 시 세션 파기
        return;
    }

    // 해군 선택 및 보호세 지불
    var selectedNavy = state.extra.navyList[choice - 1];
    var tax = state.extra.totalTax;

    if (user.point < tax) {
        // [복구]: 잔액 부족 시 깃발을 내려서 다시 선택할 기회를 줌
        state.isProcessing = false; 
        return replier.reply(formatError(user, "자금 부족", "보호세(" + fp(tax) + "P)가 부족합니다."));
    }

    user.skipHealing = true;
    // [마스터 로직]: 자산 차감은 항상 메인방("내리다") 기준으로 수행
    util_updatePoint(user, data.rooms["내리다"], -tax, "해군 호위 보호세 지불", roomName);

    // 출항 시작 (호위 정보 포함)
    _departVoyage(user, data, replier, roomName, state.dest, cfg, state.selCargo, state.selSpec, selectedNavy.uid, tax);
    
    if (!selectedNavy.isAI) {
        try {
            var navyTarget = null;
            for (var rN in data.rooms) {
                if (data.rooms[rN].users && data.rooms[rN].users[selectedNavy.uid]) {
                    navyTarget = { data: data.rooms[rN].users[selectedNavy.uid], roomName: rN };
                    break;
                }
            }
        } catch(e) { Log.error("Navy Notify Error: " + e); }
    } else {
        replier.reply("🤖 [AI 함대 통신]\n\"중앙 정부의 명에 따라 귀하의 선단을 보호하겠습니다.\"");
    }

    clearSession(); // 최종 성공 시 세션 파기
    safeSaveData(data, true);
}

/* [해적] 약탈 가능한 항해 중인 유저 리스트 출력 */
function _showRaidList(user, replier, data, roomName, targetUid) {
    var sailingUsers = [];
    var now = Date.now();
    var mainRoom = data.rooms["내리다"];
    var currentPillages = mainRoom.features.activePillages || {};

    var stateRes = util_checkUserState(user, targetUid, roomName, true);
    if (!stateRes.canAction) return replier.reply(formatError(user, "탐색 불가", stateRes.reason));

    // 1. 실제 유저 탐색 (기존 로직)
    for (var r in data.rooms) {
        var roomObj = data.rooms[r];
        for (var uid in roomObj.users) {
            var u = roomObj.users[uid];
            var isSailing = (u.voyage && u.voyage.active === true);

            /* v16.7 엘도라도 및 밀수 스텔스: 레이더망 완전 제외 */
            if (isSailing && (u.voyage.dest === ELDORADO_CONFIG.NAME || u.voyage.isSmuggling === true)) continue;

            /* [v21.0] 해군 가드: 정규 해군 소속 유저는 레이더망에서 완전 제외 (토벌 역습 방지) */
            if (u.job === 'navy') continue;

            /* 귀항 가드: 목적지가 '무역 지부' 또는 '나소'인 선박은 약탈 제외 */
            if (isSailing && (u.voyage.dest === "무역 지부" || u.voyage.dest === "나소")) continue;

            var hasEnoughTime = isSailing && (u.voyage.arrival - now >= 180000);
            var alreadyTargeted = (u.isPillaged === true || (u.voyage && u.voyage.isPillaged === true));
            var isUnderAttack = (currentPillages && currentPillages[uid]); 

            if (hasEnoughTime && !alreadyTargeted && !isUnderAttack && uid !== targetUid) {
                var isBot = (uid.indexOf("AI_BOT_") === 0);
                sailingUsers.push({ uid: uid, data: u, roomName: r, isAI: isBot });
            }
        }
    }

    // [정렬]: 남은 시간이 많이 남은 순(도착 시간이 늦은 순)으로 내림차순 정렬
    sailingUsers.sort(function(a, b) {
        // 유저(false)가 AI(true)보다 앞에 오도록 정렬
        if (a.isAI !== b.isAI) return a.isAI ? 1 : -1;
        // 남은 시간이 적은(도착 예정 시간이 빠른) 유저가 상단에 오도록 정렬
        return a.data.voyage.arrival - b.data.voyage.arrival;
    });

    var listBody = "🔭 레이더에 포착된 무역선 목록입니다.\n\n";
    sailingUsers.forEach(function(target, i) {
        var v = target.data.voyage;
        var ship = SYSTEM_CONFIG.TRADE.SHIPS[target.data.shipLevel || 1];
        var protectedMark = v.escortUid ? "🛡️ [호위함 동행]" : "⚪ [무방비]";
        var remainMs = v.arrival - now;
        var timeStr = Math.floor(remainMs / 60000) + "분 " + Math.floor((remainMs % 60000) / 1000) + "초";

        listBody += (i + 1) + ". " + target.data.name + " (" + ship.name + ")\n" +
                    "    📍 목적지: " + v.dest + " | " + protectedMark + "\n" +
                    "    ⏳ 남은시간: " + timeStr + "\n";
    });

    listBody += "\n" + "↩️ 뒤로 / 🏠 처음으로 / ❎취소";
    
    // [보정]: 1:1방 숫자 인식을 위해 현재 채팅방(roomName)에 세션 직접 저장
    if (!data.rooms[roomName].features.states.menuWait) data.rooms[roomName].features.states.menuWait = {};
    data.rooms[roomName].features.states.menuWait[targetUid] = { 
        type: 'trade_raid_list', 
        time: now, 
        originRoom: roomName,
        extra: { targets: sailingUsers } 
    };

    replier.reply(formatCommand("🏴‍☠️ 약탈 대상 물색", user, listBody, "약탈할 번호를 입력하세요."));
}

// 현재 방의 menuWait를 참조하도록 핸들러 보정
function _handlePillageSelect(choice, user, data, replier, roomName, targetUid) {
    var roomData = data.rooms[roomName];
    if (!roomData || !roomData.features || !roomData.features.states.menuWait[targetUid]) return;

    var stateRes = util_checkUserState(user, targetUid, roomName, true);
    if (!stateRes.canAction) return replier.reply(formatError(user, "습격 불가", stateRes.reason));

    var state = roomData.features.states.menuWait[targetUid];
    var idx = parseInt(choice) - 1;

    if (isNaN(idx) || idx < 0 || idx >= state.extra.targets.length) {
        return replier.reply(formatError(user, "번호 오류", "목록에 있는 번호를 선택하세요."));
    }

    var target = state.extra.targets[idx];
    var victim = target.data;
    var vId = target.uid;

    if (target.isAI) {
        // [핵심] 호위함 존재 여부에 따른 분기 처리
        if (victim.voyage && victim.voyage.escortUid) {
            replier.reply("🛡️ [경보]\n습격한 '" + victim.name + "'은(는) AI 상단입니다!\n호위 중인 'AI 해군' 함대와 즉시 교전이 시작됩니다!");
            _executeSeaCombat(user, vId, "AI_NAVY_ELITE", data, roomName, "AI_COMBAT");
        } else {
            replier.reply("📦 [습격 성공]\n습격한 '" + victim.name + "'은(는) 호위함이 없는 무방비 상태였습니다!\n즉시 화물을 약탈하고 자취를 감춥니다.");
            if (typeof _processPillageSuccess === 'function') {
                _processPillageSuccess(vId, { pirateUid: targetUid, victimName: victim.name }, data, roomName);
            }
        }
        delete roomData.features.states.menuWait[targetUid];
        safeSaveData(data, true);
        return; // AI 로직 종료
    }

    // 선택 시점에 대상 유저의 최신 데이터를 다시 확인하여 이미 털린 유저인지 2차 검증
    if (victim.isPillaged === true || (victim.voyage && victim.voyage.isPillaged === true)) {
        replier.reply(formatError(user, "습격 실패", "이미 다른 해적에게 약탈당했거나 정산이 완료된 선박입니다."));
        return;
    }

    // 중복 확인 (선점 가드: 현재 공격 진행 중인지 확인)
    var mainRoom = data.rooms["내리다"];
    if (!mainRoom.features.activePillages) mainRoom.features.activePillages = {};

    if (mainRoom.features.activePillages[vId]) {
        replier.reply(formatError(user, "습격 실패", "이미 다른 해적이 공격 중인 선박입니다."));
        return;
    }

    // [핵심 패치] 약탈 시도 즉시 '타겟 제외 플래그' 부여 (스케줄러의 다중 타겟팅 원천 차단)
    victim.isPillaged = true;
    if (victim.voyage) victim.voyage.isPillaged = true;

    if (victim.job === 'navy') {
        // 1순위: 약탈 대상(A)이 해군인 경우 -> 즉시 자동 토벌 진행
        replier.reply("📡 [위기 발생]\n이런! 당신이 습격한 상인 '" + victim.name + "'님은 위장 무역 중이던 '해군'이었습니다!\n즉시 해상 교전이 시작됩니다!");
        
        // 전투 실행: 해적(user) vs 해군상인(victim)
        // mode를 "ESCORT"로 전달하면 victim이 해군측으로 자동 계산됩니다.
        _executeSeaCombat(user, vId, vId, data, roomName, "ESCORT");
    } 
    else if (victim.voyage.escortUid) {
        // 2순위: 대상은 일반인이지만 고용된 호위 해군이 있는 경우
        replier.reply("🛡️ [경보] 습격한 선박에 전용 호위함이 대기 중입니다!\n즉시 해전이 시작됩니다!");
        _executeSeaCombat(user, vId, victim.voyage.escortUid, data, roomName, "ESCORT");
    } 
    else {
        // 3순위: 대상이 일반인이고 호위도 없는 경우 -> 정상 약탈 세션(3분) 진입
        mainRoom.features.activePillages[vId] = {
            pirateUid: targetUid,
            pirateName: user.name,
            startTime: Date.now(),
            room: target.roomName
        };

        var alertMsg = "🚨 [해상 긴급 타전]\n━━━━━━━━━━━━━━━\n" +
                       "🏴‍☠️ 해적 '" + user.name + "'(이)가\n" +
                       "📦 '" + victim.name + "'님의 선박을 습격했습니다!\n\n" +
                       "⚠️ 약탈 완료까지: 3분\n" +
                       "⚔️ 해군 본부는 즉시 토벌대를 파견하십시오!";
        
        Api.replyRoom("내리다", alertMsg);
        if (ALLOWED_ROOMS.indexOf(roomName) === -1) {
            replier.reply("📡 약탈 개시 경보가 메인방('내리다')에 타전되었습니다.");
        }
    }
    
    delete roomData.features.states.menuWait[targetUid];
    safeSaveData(data, true);
}

/* [해군] 현재 진행 중인 약탈 목록 조회 (토벌 게시판) */
function _showBattleList(user, replier, roomData, targetUid, roomName) {
    // [가드] 해군 활동 가능 상태 검증 (퇴각/징역/채굴 등)
    var stateRes = util_checkUserState(user, targetUid, roomName, true);
    if (!stateRes.canAction) return replier.reply(formatError(user, "출동 불가", stateRes.reason));

    var mainRoom = globalData.rooms["내리다"];
    var pillages = mainRoom.features.activePillages || {};
    var pKeys = Object.keys(pillages);

    var availablePillageKeys = pKeys.filter(function(k) {
        var p = pillages[k];
        return p.isBattled !== true && p.isProcessing !== true;
    });

    if (availablePillageKeys.length === 0) {
        if (roomData.features.states.menuWait && roomData.features.states.menuWait[targetUid]) {
            delete roomData.features.states.menuWait[targetUid];
        }
        return replier.reply(formatSimple("⚔️ 토벌 게시판", "현재 보고된 해적 습격 사건이 없거나\n이미 모든 함대가 교전 중입니다.", "평화로운 바다입니다."));
    }

    var body = "🚨 현재 현상수배 중인 해적 습격 현황입니다.\n\n";
    var currentPillages = [];

    availablePillageKeys.forEach(function(vId, i) {
        var p = pillages[vId];
        var remainSec = Math.ceil((180000 - (Date.now() - p.startTime)) / 1000);
        if (remainSec < 0) return;

        // [v21.1] 피해자 이름 앞에 🚢 아이콘을 붙여 AI 상단임을 표시
        var victimName = (vId.indexOf("AI_BOT_") === 0) ? "🚢 " + p.victimName : p.victimName;
        if (!p.victimName) { // 이름 누락 대비
            var vObj = null;
            for(var r in globalData.rooms){ if(globalData.rooms[r].users[vId]){ vObj = globalData.rooms[r].users[vId]; break; }}
            victimName = vObj ? ((vId.indexOf("AI_BOT_") === 0 ? "🚢 " : "") + vObj.name) : "알 수 없는 상선";
        }

        body += (i + 1) + ". 🏴‍☠️ " + p.pirateName + " ➔ " + victimName + "\n" +
                "   ⏳ 남은 시간: " + remainSec + "초\n";
        currentPillages.push({ victimUid: vId, pirateUid: p.pirateUid });
    });

    body += "\n" + "↩️ 뒤로 / 🏠 처음으로 / ❎취소";
    
    if (!roomData.features.states.menuWait) roomData.features.states.menuWait = {};
    roomData.features.states.menuWait[targetUid] = { 
        type: 'trade_battle_list', 
        time: Date.now(), 
        originRoom: roomName,
        extra: { pillages: currentPillages } 
    };

    replier.reply(formatCommand("👮 토벌 작전 게시판", user, body, "개입할 사건 번호를 입력하세요."));
}

/* [해군] 토벌 번호 선택 및 전투 실행 */
function _handleCombatSelect(choice, user, data, replier, roomName, targetUid) {
    var stateRes = util_checkUserState(user, targetUid, roomName, true); 
    if (!stateRes.canAction) return replier.reply(formatError(user, "전투 불가", stateRes.reason));
    var roomData = data.rooms[roomName];
    var state = roomData.features.states.menuWait[targetUid];
    var idx = parseInt(choice) - 1;

    if (isNaN(idx) || idx < 0 || idx >= state.extra.pillages.length) {
        return replier.reply(formatError(user, "번호 오류", "목록에 있는 번호를 선택하세요."));
    }

    var targetPillage = state.extra.pillages[idx];
    
    // 전투 실행 (해군 개입 모드)
    _executeSeaCombat(user, targetPillage.victimUid, targetUid, data, roomName, "INTERVENE");
    
    delete roomData.features.states.menuWait[targetUid];
}

/* [핵심 엔진] 해상전투 집행 (Navy vs Pirate) */
function _executeSeaCombat(navyOrPirate, victimUid, navyUid, data, roomName, mode) {
    var mainRoom = data.rooms["내리다"];
    var session = (mainRoom.features && mainRoom.features.activePillages) ? mainRoom.features.activePillages[victimUid] : null;
    
    // victim 객체 식별 로직 (유저 및 AI 상단 모두 탐색 가능하도록 수정)
    var victim = null;
    if (victimUid) { 
        for (var r in data.rooms) { 
            if (data.rooms[r].users && data.rooms[r].users[victimUid]) { 
                victim = data.rooms[r].users[victimUid]; 
                break; 
            } 
        }
    }

    if (typeof util_scrubNativeObject === 'function') {
        util_scrubNativeObject(navyOrPirate);
        if (session) util_scrubNativeObject(session);
        if (victim) util_scrubNativeObject(victim);
    }

    var cfg = SYSTEM_CONFIG.TRADE.JOBS;

    if (mode === "INTERVENE") {
        if (!session || session.isBattled === true) {
            try { Api.replyRoom(roomName, "📡 [교전 불가] 이미 다른 함대가 교전 중입니다."); } catch(e) {}
            return;
        }
        session.isBattled = true; 
    }

   // navyUid 가드 및 AI 해군/전투 판별 (고용된 AI 또는 AI 상단 호위병 통합 인식)
    var isAINavy = (navyUid && typeof navyUid === 'string' && (navyUid.indexOf("AI_NAVY_") === 0 || navyUid.indexOf("AI_BOT_") === 0));
    var isAICombat = (mode === "AI_COMBAT");
    var isPatrol = (mode === "PATROL"); // 순찰 모드 추가

    var pirate = (mode === "ESCORT" || isAICombat || isPatrol) ? navyOrPirate : null;
    var navy = (mode === "INTERVENE") ? navyOrPirate : null; // isPatrol 중복 할당 제거
    
    if (isPatrol) {
        // 순찰 모드에서는 navyOrPirate가 해적 객체로 들어오므로 해군(user)을 다시 식별
        for (var r in data.rooms) { if (data.rooms[r].users[navyUid]) { navy = data.rooms[r].users[navyUid]; break; } }
    } else if (!isAICombat) {
        if (!pirate) {
            var pId = session ? session.pirateUid : null;
            if (!pId) return;
            if (session && session.isAIPirate) {
                pirate = { uid: pId, name: session.pirateName, shipLevel: session.dummyPirateLevel, job: 'pirate', isAI: true, isGlobalAI: !!session.isGlobalAI, currentBounty: SYSTEM_CONFIG.TRADE.JOBS.PIRATE.bountyBase };
            } else {
                for (var r in data.rooms) { if (data.rooms[r].users[pId]) { pirate = data.rooms[r].users[pId]; break; } }
            }
        }
        if (!navy && !isAINavy) {
            var nSearchId = navyUid || (session ? session.escortUid : null);
            for (var r in data.rooms) { if (data.rooms[r].users[nSearchId]) { navy = data.rooms[r].users[nSearchId]; break; } }
        }
    }

    if (!pirate || (!isAICombat && !isAINavy && !navy)) return;

    var nName = "AI 연합함대";
    if (isPatrol) nName = navy.name;
    else if (!isAINavy && !isAICombat && navy) nName = navy.name;
    else if (isAICombat) nName = "AI 엘리트 해군";

    var pName = (pirate) ? pirate.name : "정체불명의 해적";
    var pShip = Number(pirate.shipLevel || 1);
    var nShip = 1;
    if (isAICombat || isAINavy) {
        var eLvl = (victim && victim.voyage) ? Number(victim.voyage.escortLevel || 7) : 7;
        nShip = eLvl;
    } else {
        nShip = navy ? Number(navy.shipLevel || 1) : 1;
    }

    // [시스템 공식]: 선박 레벨 기반 기초 승률 계산 (직업 변경과 무관하게 레벨 숫자만 유지되면 정상 작동)
    var winChance = 52 + (nShip - pShip) * 5;
    
    // [해군 숙련도 반영]: 명성 100당 승률 +1% (유저 해군일 때)
    if (!isAINavy && !isAICombat && navy) {
        var fameBonus = Math.floor((navy.fame || 0) / 100);
        winChance += fameBonus;
    }

    // [해적 숙련도 반영]: 악명 100당 승률 +1% (유저 해적일 때 - 누락 로직 추가)
    if (pirate && !pirate.isAI) {
        var infamyBonus = Math.floor((pirate.infamy || 0) / 100);
        winChance -= infamyBonus; // 해군 승률을 깎아서 해적 승률을 높임
    }

    // [베테랑 예우]: 무역 횟수가 100회 이상인 베테랑은 전직 직후에도 최소 5%의 숙련 보너스 보장
    if ((navy && !isAINavy && (navy.tradeCount || 0) >= 100) || (pirate && !pirate.isAI && (pirate.tradeCount || 0) >= 100)) {
        if (isNavyWin) winChance += 5; else winChance -= 5;
    }

    winChance = Math.max(15, Math.min(95, winChance)); // 최소 15% ~ 최대 95% 캡 (명성 고려 상한 소폭 상향)
    
    var isNavyWin = (Math.random() * 100 < winChance);

    var resultMsg = "⚔️ [해상 교전 결과 보고]\n━━━━━━━━━━━━━━━\n" +
                    "👮 해군: " + nName + " (Lv." + nShip + ")\n" + 
                    "🏴‍☠️ 해적: " + pName + " (Lv." + pShip + ")\n\n";

    if (isNavyWin) {
        var piratePenaltyMs = cfg.PIRATE.jailTime || 600000; 
        pirate.pillageCooldownEndTime = Date.now() + piratePenaltyMs;
        pirate.infamy = Math.max(0, (pirate.infamy || 0) - 20);
        
        var baseReward = Math.floor(cfg.PIRATE.bountyBase * 0.3);
        var bounty = baseReward + (Number(pirate.currentBounty) || 0);
        pirate.currentBounty = Number(cfg.PIRATE.bountyBase);

        resultMsg += "🔥 [해군 승리] 해적선이 나포되었습니다!\n\n";

        if (isAINavy || isAICombat) {
            var localNavies = [];
            var totalNavyLevels = 0;
            var targetRoomObj = data.rooms[roomName];
            
            if (targetRoomObj && targetRoomObj.users) {
                for (var uId in targetRoomObj.users) {
                    var u = targetRoomObj.users[uId];
                    if (u.job === 'navy') {
                        localNavies.push(u);
                        totalNavyLevels += (u.shipLevel || 1);
                    }
                }
            }

            if (localNavies.length > 0) {
                localNavies.forEach(function(n) { 
                    var weight = (n.shipLevel || 1) / totalNavyLevels;
                    var myShare = Math.floor(bounty * weight);
                    n.claimableReward = (Number(n.claimableReward) || 0) + myShare; 
                    n.hasNotifiedReward = false;
                });
                resultMsg += "💰 AI 연합함대: 현상금 " + fp(bounty) + "P 확보 (가담 해군 분배 완료)\n";
            } else {
                resultMsg += "💰 AI 연합함대: 현상금 " + fp(bounty) + "P 획득\n";
            }
        } else {
            navy.fame = (navy.fame || 0) + 10;
            navy.claimableReward = (Number(navy.claimableReward) || 0) + bounty;
            navy.hasNotifiedReward = false;
            navy.totalCaptureSuccess = (navy.totalCaptureSuccess || 0) + 1;
            util_checkNavyTitle(navy, null, "내리다");
            
            resultMsg += "💰 " + navy.name + ": 현상금 " + fp(bounty) + "P 획득\n";
        }

        var routeClearMsg = "";
        if (pirate.isGlobalAI) {
            var ap = data.aiPirates.find(function(a) { return a.uid === pirate.uid; });
            if (ap) {
                ap.status = 'cooldown';
                ap.endTime = Date.now() + AI_PIRATE_CONFIG.COOLDOWN_MS;
                
               // [v21.2] 왕복 항로 통합 정화 엔진: 출발-도착 및 도착-출발 양방향의 모든 해적 소탕 여부 검사
                var route1 = ap.route; // 예: "나폴리-베라크루스"
                var parts = route1.split("-");
                var route2 = parts[1] + "-" + parts[0]; // 예: "베라크루스-나폴리"

                // 양방향 항로를 모두 뒤져서 현재 항해 중(sailing)인 해적이 있는지 확인
                var remP = data.aiPirates.filter(function(a) { 
                    return a.status === 'sailing' && (a.route === route1 || a.route === route2); 
                }).length;

                if (remP === 0) {
                    if (!data.safeRoutes) data.safeRoutes = {};
                    var expireTime = Date.now() + AI_PIRATE_CONFIG.SAFE_TIME_MS;
                    
                    // 양방향 모두 안전구역 데이터 등록
                    data.safeRoutes[route1] = expireTime;
                    data.safeRoutes[route2] = expireTime;
                    
                    // 정화 메시지도 왕복 항로임을 명시하여 1회만 출력
                    routeClearMsg = "🛡️ [항로 정화]: '" + parts[0] + "↔" + parts[1] + "' 왕복 항로가 20분간 안전구역으로 선포되었습니다!";
                } else if (isPatrol) {
                    routeClearMsg = "🛡️ [임무 완료]: 해적을 격퇴했습니다. 남은시간동안 순찰을 지속합니다.";
                } else {
                    routeClearMsg = "🛡️ [임무 완료]: 해적을 격퇴했습니다. 해당 상선은 보호 프로토콜에 따라 더 이상 습격받지 않습니다.";
                }
            }
        } else {
             routeClearMsg = "⚓ " + pirate.name + ": 약탈 금지 " + Math.floor(piratePenaltyMs / 60000) + "분 부과";
        }

        resultMsg += routeClearMsg;

        if (!isAICombat && !isPatrol && victim && victim.voyage) {
            victim.voyage.escortUid = null; 
            victim.voyage.escortFee = 0;
            victim.isPillaged = true; 
            if (victim.voyage) victim.voyage.isPillaged = true;
            if (!pirate.isGlobalAI) {
                resultMsg += "\n🛡️ [임무 완료]: 해적을 격퇴했습니다. 해당 상선은 보호 프로토콜에 따라 더 이상 습격받지 않습니다.";
            }
        }

        if (session) delete mainRoom.features.activePillages[victimUid];
        
        } else {

        // 해적 승리 (해군 패배) 로직 시작
        
        // 1. 습격 대상이 AI인지 여부 선행 판별 (유령 상단 및 고용된 AI 함대 포함)
        var isVictimAI = (victimUid && victimUid.indexOf("AI_BOT_") === 0);

        // 2. [즉시 완료 분기] AI 상단 습격 시 3분 대기 없이 바로 정산
        if (isAICombat || isVictimAI || isPatrol) {
            if (!isPatrol) {
                var ecoMult = util_getEcoMultiplier("내리다");
                var virtualMargin = (Math.floor(Math.random() * 100001) + 100000) * ecoMult;
                var pMin = cfg.PIRATE.pillageRateMin || 0.3;
                var pMax = cfg.PIRATE.pillageRateMax || 0.5;
                var pRate = pMin + (pMax - pMin) * (pShip - 1) / 9;
                var pAmt = Math.floor(virtualMargin * pRate);

                // 정산 함수 호출 (데이터만 업데이트)
                if (typeof _processPillageSuccess === 'function') {
                    var vName = victim ? victim.name : "유령 상단";
                    _processPillageSuccess(victimUid, { pirateUid: pirate.uid, victimName: vName, forcedAmount: pAmt, forcedRate: pRate, isSilent: true }, data, roomName);
                }
                
                // [통합] 교전 결과 보고서에 현상금 정보 추가
                resultMsg += "🏴‍☠️ [AI 상단 약탈 성공]\n" +
                             "해적 '" + pirate.name + "'이 유령 상단을 완벽히 제압했습니다!\n" +
                             "💰 이번 약탈 수익: +" + fp(pAmt) + "P (정산 대기)\n" +
                             "📈 적용 약탈률: " + (pRate * 100).toFixed(1) + "%\n" +
                             "💀 누적 현상금: " + fp(pirate.currentBounty) + "P 돌파!";
            } else {
                // 순찰(PATROL) 모드에서 해군이 패배 시
                var retreatMs = cfg.NAVY.retreatTime || 300000;
                navy.retreatEndTime = Date.now() + retreatMs;
                navy.fame = Math.max(0, (navy.fame || 0) - 10);
                resultMsg += "💀 [해군 순찰 실패] AI 해적의 맹공에 패퇴했습니다!\n\n" +
                             "📉 " + navy.name + ": 명성 -10점 하락\n" +
                             "🩹 " + navy.name + ": " + Math.floor(retreatMs/60000) + "분간 정비 돌입 (순찰 중단)\n";
            }
        }
        // 실제 유저 상단 습격 시
        else {
            var retreatMs = cfg.NAVY.retreatTime || 300000;
            var fameLoss = (mode === "INTERVENE") ? 20 : 10;
            var navyName = isAINavy ? "AI 연합함대" : (navy ? navy.name : "해군 호위함");

            if (!isAINavy && navy) {
                navy.retreatEndTime = Date.now() + retreatMs;
                navy.fame = Math.max(0, (navy.fame || 0) - fameLoss);
            }

            if (!pirate.isAI) pirate.infamy = (pirate.infamy || 0) + 5;

            resultMsg += "💀 [해적 승리] " + navyName + "가 패퇴했습니다!\n\n" +
                         (!isAINavy ? "📉 " + navyName + ": 명성 -" + fameLoss + "점 하락\n" : "") +
                         (!isAINavy ? "🩹 " + navyName + ": " + Math.floor(retreatMs/60000) + "분간 정비 돌입\n" : "");

            if (!isPatrol && victim && victim.voyage && !victim.voyage.isPatrol) {
                victim.voyage.escortUid = null; // [2번] 호위 해제 (해군은 자유)
                
                // [1번] 해적이 이겼으므로 즉시 '약탈 진행 중' 상태로 전환
                // 이 상태가 되면 _showRaidList 함수에서 자동으로 목록에서 제외됨
                if (!mainRoom.features.activePillages) mainRoom.features.activePillages = {};
                
                // 해적 UID 확보
                var pUid = pirate.uid || (mode === "ESCORT" ? navyOrPirate.uid : null);
                
                if (pUid) {
                    mainRoom.features.activePillages[victimUid] = {
                        pirateUid: pUid,
                        pirateName: pirate.name,
                        startTime: Date.now(),
                        room: roomName,
                        isBattled: true,
                        isAIPirate: !!pirate.isAI,                 // AI 해적 식별 플래그 추가
                        isGlobalAI: !!pirate.isGlobalAI,
                        dummyPirateLevel: pirate.shipLevel || 1    // AI 해적 함선 레벨 추가
                    };
                    resultMsg += "\n⏳ [약탈 개시] 방어선이 무너져 즉시 약탈(3분)이 진행됩니다!";
                }
            }
        }
    }

    Api.replyRoom((mode === "PATROL" ? roomName : "내리다"), resultMsg);
    safeSaveData(data, true);
}

function _showJobSettlementOffice(user, replier, roomName, targetUid) {
    var today = getSimpleDate();
    var multiplier = util_getEcoMultiplier(roomName);
    var isPirate = (user.job === 'pirate');
    
    // 1. 일급 계산 (미수령 시에만 표시)
    var dailyWage = 0;
    var wageBreakdown = "";
    var isWageAvailable = (isPirate ? user.lastPirateWageDate : user.lastNavyWageDate) !== today;

    if (isWageAvailable) {
        var base = 25000;
        var bonus = isPirate ? (Number(user.infamy || 0) * 100) : (Number(user.fame || 0) * 100);
        dailyWage = Math.floor((base + bonus) * multiplier);
        if (user.title === "해적왕" || user.title === "제해왕") {
            dailyWage = Math.floor(dailyWage * 1.5);
            var kingTitle = user.title;
        }
        var maxWage = SYSTEM_CONFIG.TRADE.JOBS.NAVY.maxDailyWage || 100000;
        dailyWage = Math.min(maxWage, dailyWage);
        
        wageBreakdown = "  - 기본급: " + fp(base) + "P\n" +
                        "  - " + (isPirate ? "악명" : "명성") + "수당: +" + fp(bonus) + "P\n" +
                        "  - 물가보정: x" + multiplier.toFixed(2) + "\n" +
                        "  ➔ 일급 합계: " + fp(dailyWage) + "P\n";
    }

    // 2. 누적 보상금 (토벌/약탈/호송)
    var accumulated = Number(user.claimableReward || 0);
    var totalAvailable = dailyWage + accumulated;

    var body = (isPirate ? "🏴‍☠️ 나소 장물 정산소" : "👮 해군 본부 회계실") + "\n\n" +
               "[💰 정산 가능 내역]\n" +
               (isWageAvailable ? "💵 금일 기본 일급:\n" + wageBreakdown : "✅ 금일 일급 수령 완료\n") +
               "\n📦 미수령 활동 보상: " + fp(accumulated) + "P\n" +
               "(토벌/약탈/호송 수익 포함)\n" +
               "━━━━━━━━━━━━━━━\n" +
               "💰 총 수령 가능액: " + fp(totalAvailable) + "P\n\n" +
               "💬 [수령 방법]\n" +
               "• 부분 수령: [금액] 입력\n" +
               "• 일괄 수령: [전부] 입력\n\n" +
               "↩️ 뒤로 / ❎취소";

    replier.reply(formatCommand("🏦 직업 자산 정산소", user, body));
    
    var mState = globalData.rooms[roomName].features.states.menuWait;
    mState[targetUid] = { 
        type: 'trade_job_settlement', 
        time: Date.now(), 
        extra: { wage: dailyWage, rewards: accumulated, total: totalAvailable, isWageAvailable: isWageAvailable } 
    };
}

// [추가] 직업 정산 입력 처리 핸들러 (전부/부분 수령)
function _handleJobSettlement(msg, user, data, replier, roomName, targetUid) {
    var state = data.rooms[roomName].features.states.menuWait[targetUid];
    if (!state) return false;

    var totalAvailable = Number(state.extra.total);
    var withdrawAmt = (msg === "전부") ? totalAvailable : parseInt(msg.replace(/[^0-9]/g, ""));

    if (isNaN(withdrawAmt) || withdrawAmt <= 0) return false;
    if (withdrawAmt > totalAvailable) {
        replier.reply(formatError(user, "수령 불가", "최대 " + fp(totalAvailable) + "P까지만 수령 가능합니다."));
        return true;
    }

    var today = getSimpleDate();
    var isPirate = (user.job === 'pirate');
    
    // 일급 처리: 인출액이 오늘치 일급보다 많으면 일급 수령 완료 처리
    if (state.extra.isWageAvailable && withdrawAmt >= state.extra.wage) {
        if (isPirate) user.lastPirateWageDate = today;
        else user.lastNavyWageDate = today;
    }

    // 보상금 주머니 차감
    user.claimableReward = Math.max(0, totalAvailable - withdrawAmt - (state.extra.isWageAvailable && withdrawAmt < state.extra.wage ? state.extra.wage : 0));

    user.skipHealing = true;
    var res = processRepayment(user, withdrawAmt, targetUid, roomName);
    util_updatePoint(user, data.rooms["내리다"], Number(res.actualGain), "직업 활동 자산 정산", "내리다");

    var resBody = "직업 활동 수익 정산이 완료되었습니다.\n\n" +
                  "💰 수령 금액: +" + fp(withdrawAmt) + "P\n" +
                  "🏛️ 남은 미수령액: " + fp(user.claimableReward) + "P\n" +
                  (res.repayMsg || "✅ 지갑으로 즉시 입금되었습니다.");

    delete data.rooms[roomName].features.states.menuWait[targetUid];
    replier.reply(formatCommand("✅ 정산 완료", user, resBody, "내 잔액: " + fp(user.point) + "P"));
    safeSaveData(data, true);
    return true;
}

/* [시스템] 약탈 성공 정산 (스케줄러에서 3분 만료 시 호출) */
function _processPillageSuccess(victimUid, pData, data, roomName) {
    var victim = null;
    var pirate = null;
    var isAI = (victimUid.indexOf("AI_BOT_") === 0);

    // 1. 유저 식별 및 위치 탐색
    for (var r in data.rooms) {
        if (!isAI && data.rooms[r].users[victimUid]) victim = data.rooms[r].users[victimUid];
    }

    // 해적이 AI인 경우 더미 객체 생성, 아니면 DB에서 탐색
    if (pData.isAIPirate) {
        pirate = { uid: pData.pirateUid, name: pData.pirateName, shipLevel: pData.dummyPirateLevel, isAI: true };
    } else {
        for (var r in data.rooms) {
            if (data.rooms[r].users[pData.pirateUid]) { pirate = data.rooms[r].users[pData.pirateUid]; break; }
        }
    }

    if (!pirate) return;
    if (!isAI && (!victim || !victim.voyage)) return;

    var cfg = SYSTEM_CONFIG.TRADE;
    var pName = isAI ? (pData.victimName || "유령 상단") : victim.name;

    // [v16.8] 전투 리포트에서 전달된 확정 수치(forced)를 우선 할당
    var pRate = pData.forcedRate || 0;
    var pillageAmount = pData.forcedAmount || 0;

    // 2. 확정 금액이 없을 때만(스케줄러 자동 만료 시) 아래 계산 로직을 실행
    if (!pillageAmount) {
        if (isAI) {
            // AI 상단 약탈액 밸런싱
            var ecoMult = util_getEcoMultiplier("내리다");
            var virtualMargin = (Math.floor(Math.random() * 100001) + 100000) * ecoMult;
            pRate = 0.3; 
            pillageAmount = Math.floor(virtualMargin * pRate);
        } else {
            // [유저 정산]: 기존 소스코드의 정밀 스냅샷 기반 계산 유지
            var v = victim.voyage;
            var tRev = 0; var tCost = 0;
            var nSnap = (v.marketSnapshot && v.marketSnapshot[v.dest]) ? v.marketSnapshot[v.dest] : { favorite: "NONE", hate: "NONE", rates: {} };
            var cSnap = v.cargoSnapshot || {};
            var sSnap = v.specialtySnapshot || {};
            var quest = v.contractSnapshot;

            // 일반 화물 매출/원가 계산
            for (var g in cSnap) {
                var qty = Number(cSnap[g]); if (qty <= 0) continue;
                var myPurchasePrice = Number((victim.warehouseAvg && victim.warehouseAvg[g]) || (victim.cargoAvg && victim.cargoAvg[g]) || cfg.GOODS_COST[g] || 10000);
                var rateInfo = SYSTEM_CONFIG.PROFIT_RATES[g] || { pref: 1.15, norm: 1.05, hate: 0.8 };
                // [퀘스트 정규화] 1.5배 시세 적용 여부를 출발 시간(v.startTime) 기준으로 판정
                var isPremium = (quest && v.startTime >= quest.startTime && v.startTime <= quest.endTime && v.dest === quest.nation && g === quest.item);
                var mult = isPremium ? 1.5 : ((g === nSnap.favorite) ? rateInfo.pref : (g === nSnap.hate ? rateInfo.hate : rateInfo.norm));
                
                var baseTargetCost = cfg.GOODS_COST[g] || 10000;
                tCost += (myPurchasePrice * qty);
                tRev += Math.floor(baseTargetCost * mult * qty);
            }
            // 특산품 매출/원가 계산
            for (var s in sSnap) {
                var sQty = Number(sSnap[s]); if (sQty <= 0) continue;
                var pG = "";
                for (var rel in TRADE_RELATION) { if (TRADE_RELATION[rel].set === s) { pG = TRADE_RELATION[rel].produce; break; } }
                var sBase = cfg.SPECIALTY_COST[pG] || 10000;
                var sMult = (pG === nSnap.favorite) ? cfg.SPECIALTY_PROFIT : (pG === nSnap.hate ? 0.5 : 1.0);
                tCost += (sBase * sQty);
                tRev += Math.floor(sBase * sQty * sMult);
            }

            var margin = (tRev - tCost);
            var shipEff = (victim.shipLevel === 1) ? 4.2 : (victim.shipLevel === 2 ? 1.9 : 1.15);
            
            // 1. 선박 효율이 적용된 기초 마진 계산
            var efficientMargin = Math.floor(margin * shipEff);

            // 2. 항구 발전도 보너스 계산 (기존 로직 유지, 수식 정리)
            var pInfo = (economyRoomData.features.portData && economyRoomData.features.portData[v.dest]) ? economyRoomData.features.portData[v.dest] : { level: 1 };
            var pBonus = efficientMargin > 0 ? Math.floor(efficientMargin * (pInfo.level - 1) * 0.01) : 0;
            
            // 3. 최종 세전 순이익 합산
            var totalNetMargin = efficientMargin + pBonus;

            // 4. 해적 숙련도(선박 레벨)에 따른 약탈률 계산
            var pMin = cfg.JOBS.PIRATE.pillageRateMin || 0.3;
            var pMax = cfg.JOBS.PIRATE.pillageRateMax || 0.5;
            pRate = pMin + (pMax - pMin) * (Number(pirate.shipLevel || 1) - 1) / 9;
            
            // 최종 약탈액 확정
            pillageAmount = totalNetMargin > 0 ? Math.floor(totalNetMargin * pRate) : 0;

            // 피해자 상태 업데이트
            victim.isPillaged = true;
            v.isPillaged = true;
            v.pillageRateSnapshot = pRate;
            v.pirateUid = pirate.uid;
            v.aiPirateLevel = pirate.shipLevel;
            v.aiPirateName = pirate.name;
        }
    }

    // 3. 공통 데이터 반영 및 주머니(정산소) 적립
    if (pillageAmount > 0) {
       if (pirate.isAI) {
            // [v21.1] AI vs AI 정산: 두 개체 모두 AI인 경우 결과 공지 없이 조용히 국고로 환수
            if (isAI) { 
                util_updateReserve(data.rooms["내리다"], pillageAmount, "AI 상호 약탈 국고 환수", "내리다");
                Log.info("[Pillage: AI to AI] " + pirate.name + " 성공 (국고 +" + pillageAmount + "P)");
            } else {
                // [AI 해적 ➔ 유저 상단]: 기존과 동일하게 안내 메시지 출력
                var successMsg = "⚔️ [해상 교전 결과 보고]\n" +
                                 "━━━━━━━━━━━━━━━\n" +
                                 "🙍‍♂️ 대상: " + pName + "\n" +
                                 "🏴‍☠️ 해적: " + pirate.name + " (Lv." + pirate.shipLevel + ")\n\n" +
                                 "🏴‍☠️ [상단 약탈 성공]\n" +
                                 "악명 높은 '" + pirate.name + "'이(가) 상선을 제압하고 화물을 약탈해 도주했습니다!\n" +
                                 "📈 적용 약탈률: " + (pRate * 100).toFixed(1) + "%";
                                 
                if (!pData.isSilent) {
                    Api.replyRoom(roomName || "내리다", successMsg);
                }
                Log.info("[Pillage] AI Pirate -> " + pName + " 성공 (정산 대기)");
            }
        } else {
            // [유저 해적 ➔ (유저 or AI) 상단]: 유저 해적의 수익으로 정산
            var pirateCfg = (SYSTEM_CONFIG.TRADE.JOBS && SYSTEM_CONFIG.TRADE.JOBS.PIRATE) ? SYSTEM_CONFIG.TRADE.JOBS.PIRATE : { bountyInc: 15000 };
            
            pirate.claimableReward = (Number(pirate.claimableReward) || 0) + pillageAmount;
            pirate.infamy = (pirate.infamy || 0) + 10;
            pirate.currentBounty = (Number(pirate.currentBounty) || 0) + (pirateCfg.bountyInc || 15000);
            pirate.totalPillageSuccess = (pirate.totalPillageSuccess || 0) + 1;
            
            pirate.hasNotifiedReward = false;
            pirate.pillageCooldownEndTime = Date.now() + (cfg.JOBS.PIRATE.winCooldown || 300000);
            
            util_checkPirateTitle(pirate, null, "내리다");

            var pLvl = pirate.shipLevel || 1;
            var targetTypeStr = isAI ? "AI 상단" : "상단";
            
            var successMsg = "⚔️ [해상 교전 결과 보고]\n" +
                             "━━━━━━━━━━━━━━━\n" +
                               "🙍‍♂️ 대상: " + pName + "\n" +
                               "🏴‍☠️ 해적: " + pirate.name + " (Lv." + pLvl + ")\n\n" +
                               "🏴‍☠️ [" + targetTypeStr + " 약탈 성공]\n" +
                               "해적 '" + pirate.name + "'이(가) " + pName + "을(를) 완벽히 제압했습니다!\n" +
                               "💰 이번 약탈 수익: +" + fp(pillageAmount) + "P (정산 대기)\n" +
                               "📈 적용 약탈률: " + (pRate * 100).toFixed(1) + "%\n" +
                               "💀 누적 현상금: " + fp(pirate.currentBounty) + "P 돌파!";
                               
            if (!pData.isSilent) {
                Api.replyRoom(roomName || "내리다", successMsg);
            }
            Log.info("[Pillage] " + pirate.name + " -> " + pName + " 성공 (" + pillageAmount + "P)");
        }
    }
}

// 해적 전용 보석금 납부 로직
function _processPirateBail(user, data, replier, roomName, targetUid) {
    var cfg = SYSTEM_CONFIG.TRADE.JOBS.PIRATE;
    var now = Date.now();
    
    var inPillageCooldown = (user.pillageCooldownEndTime && now < user.pillageCooldownEndTime);

    if (!inPillageCooldown) {
        return replier.reply(formatError(user, "납부 불가", "현재 제한 상태가 아닙니다."));
    }

    if (user.point < cfg.bailAmount) {
        return replier.reply(formatError(user, "자금 부족", "보석금 " + fp(cfg.bailAmount) + "P가 부족합니다."));
    }

    user.skipHealing = true;
    util_updatePoint(user, data.rooms[roomName], -cfg.bailAmount, "해적 보석금 석방", roomName);
    
    // 상태 즉시 초기화
    user.pillageCooldownEndTime = 0;

    // 석방 처리가 완료되는 즉시 메뉴 응답 대기 세션(menuWait)을 종료함
    if (data.rooms[roomName].features && data.rooms[roomName].features.states.menuWait) {
        delete data.rooms[roomName].features.states.menuWait[targetUid];
    }
    
    replier.reply(formatCommand("🔓 즉시 석방 완료", user, "보석금 " + fp(cfg.bailAmount) + "P를 지불하고 자유의 몸이 되었습니다!\n즉시 해상 활동이 가능합니다."));
    safeSaveData(data, true);
}

// === 왕실 집무실 핸들러 ===
function _showRoyalOffice(user, replier, roomName, targetUid) {
    var curRank = user.nobleRank || 0;
    var nextRank = NOBLE_RANK_CONFIG.RANKS[curRank + 1];
    var myMedals = user.royalMedals || 0;
    
    var body = "👑 [국가 왕실 집무실]\n" +
               "━━━━━━━━━━━━━━━\n" +
               "현재 계급: " + NOBLE_RANK_CONFIG.RANKS[curRank].name + "\n" +
               "보유 훈장: " + myMedals + "개\n\n" +
               "[🎖️ 작위 수여 조건]\n";
    
    NOBLE_RANK_CONFIG.RANKS.forEach(function(r, i) {
        if (i === 0) return;
        var mark = (curRank >= i) ? "✅" : (myMedals >= r.medals ? "⭕" : "❌");
        body += i + ". " + r.name + ": 훈장 " + r.medals + "개 " + mark + "\n";
    });

    body += "\n[✨ 작위별 상시 혜택]\n" +
            "• 공통: 각 단계별 특산품 발견확률 +10% 누적\n" +
            "• 공작 달성 시: 특산품 발견확률 100% 확정\n\n" +
            "💬 [승급 방법]: 원하는 작위 번호를 입력하세요.\n" +
            "↩️ 뒤로 / ❎취소";

    replier.reply(formatCommand("🏰 왕실 집무실", user, body));
    
    var logicRoom = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    globalData.rooms[logicRoom].features.states.menuWait[targetUid] = { type: 'trade_royal_office', time: Date.now() };
}

function _handleRoyalOffice(choice, user, data, replier, roomName, targetUid) {
    var idx = parseInt(choice);
    if (isNaN(idx) || idx < 1 || idx >= NOBLE_RANK_CONFIG.RANKS.length) {
        return replier.reply(formatError(user, "번호 오류", "승급을 희망하는 작위 번호를 입력하세요."));
    }

    if (user.nobleRank >= idx) return replier.reply(formatError(user, "승급 불가", "이미 해당 작위이거나 더 높은 직위를 보유 중입니다."));
    if (user.nobleRank !== idx - 1) return replier.reply(formatError(user, "승급 불가", "작위는 순차적으로만 승급할 수 있습니다."));

    var targetRank = NOBLE_RANK_CONFIG.RANKS[idx];
    if (user.royalMedals < targetRank.medals) {
        return replier.reply(formatError(user, "훈장 부족", targetRank.name + " 수여에는 훈장 " + targetRank.medals + "개가 필요합니다."));
    }

    // 승급 집행
    user.royalMedals -= targetRank.medals;
    user.nobleRank = idx;
    user.skipHealing = true;

    var winMsg = "🎊 [국가 왕실: 작위 수여식] 🎊\n" +
                 "━━━━━━━━━━━━━━━\n" +
                 "국가 발전에 헌신한 '" + user.name + "'님께\n" +
                 "왕실의 이름으로 [" + targetRank.name + "] 작위를 하사합니다.\n\n" +
                 "✨ 상시 혜택: 특산품 발견확률 " + (targetRank.bonus * 100).toFixed(0) + "% 보너스 적용\n" +
                 "━━━━━━━━━━━━━━━\n" +
                 "이제 의원님의 위상은 국가 전역에 빛날 것입니다.";
    
    replier.reply(winMsg);
    delete data.rooms[roomName].features.states.menuWait[targetUid];
    safeSaveData(data, true);
}

