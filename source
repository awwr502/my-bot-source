/**
 * [시스템 모듈] 대항해시대 무역 엔진 v1.5 (Full-Spec Edition)
 * 기능: 시세 스냅샷, 순풍, 4대 재해(10% 페널티), 지능형 누진세, 네비게이션 통합
 */

/**
 * 무역품 실시간 단가 계산기 (전역 헬퍼)
 * 기능: 특정 품목(good)을 특정 항구(dest)에 팔 때의 개당 가격을 반환
 */
function util_calcTradePrice(good, dest, roomData) {
    var cfg = SYSTEM_CONFIG.TRADE;
    var market = roomData.features.tradeMarket || {};
    var pData = roomData.features.portData || {};
    var nInfo = market[dest] || { rates: {} };
    var pInfo = pData[dest] || { level: 1 };
    
    // 1. 기초 원가 로드
    var baseCost = cfg.GOODS_COST[good] || 10000;
    
    // 2. 현재 시세(Multiplier) 로드
    var multiplier = 1.0;

    // 엘도라도는 고정 고수익 (무조건 130%)
    if (dest === ELDORADO_CONFIG.NAME) {
        multiplier = 1.3; 
    } 
    // 일반 도시는 생성된 시세(rates) 적용
    else if (nInfo.rates && nInfo.rates[good]) {
        multiplier = nInfo.rates[good];
    } 

    // 3. 발전도 보너스 (시세가 100% 이상일 때만 추가 이익으로 적용)
    var bonusAmt = 0;
    if (multiplier > 1.0) {
        var baseMargin = (baseCost * multiplier) - baseCost;
        var portLevelRate = (pInfo.level - 1) * (cfg.INVEST.BONUS_PER_LEVEL || 0.01);
        bonusAmt = Math.floor(baseMargin * portLevelRate);
    }

    return Math.floor((baseCost * multiplier) + bonusAmt);
}

