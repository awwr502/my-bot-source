 * 기능: 특정 큐(qKey)의 세션을 삭제하며, cost(보험금)가 기록되어 있다면 즉시 환불 집행
 * @return {String} 환불 발생 시 UI에 추가할 메시지 (없을 시 빈 문자열)
 */
function util_terminateSession(uid, user, roomData, roomName, qKey) {
    if (!roomData || !roomData.features || !roomData.features.states) return "";
    
    var q = roomData.features.states[qKey];
    if (!q || !q[uid]) return "";
    
    var entry = q[uid];
    var refundMsg = "";
    
    // 세션에 cost(보험금)가 존재하고 유저 객체가 확인될 때만 환불 로직 가동
    if (entry.cost && entry.cost > 0 && user) {
        var mainRoom = globalData.rooms["내리다"]; // 자산은 항상 메인방 기준
        util_updatePoint(user, mainRoom, entry.cost, "세션 중단 자동 환불", roomName);
        refundMsg = "\n💰 지불 포인트 환불: +" + fp(entry.cost) + "P";
        
        // 중복 환불 방지를 위해 즉시 cost 초기화
        entry.cost = 0; 
    }
    
    // 물리적 세션 파기
    delete q[uid];
    return refundMsg;
}

