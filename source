    }
    delete GLOBAL_STAGING.active[user.uid];
    delete GLOBAL_STAGING.cache[user.uid];
    Log.info("[Atomic Rollback] " + user.name + "님의 트랜잭션 실패로 복구되었습니다.");
}

/**
 * [v15.5] 고속 재귀 복제 엔진
 * 기능: 무거운 JSON 변환을 제거하여 핑 지연을 해결하고, 중복 구문을 제거하여 문법 오류를 수정했습니다.
 */
function util_stagingStart(user) {
    if (!user || !user.uid) return;
    
    GLOBAL_STAGING.active[user.uid] = true;

    // 내부 재귀 복사 함수 (참조 오염 방지 및 고속 처리)
    var deepCopy = function(obj) {
        if (obj === null || typeof obj !== 'object') return obj;
        if (obj.getClass !== undefined) return null; // 자바 객체 복제 차단
        var clone = Array.isArray(obj) ? [] : {};
        for (var key in obj) {
            clone[key] = deepCopy(obj[key]); 
        }
        return clone;
    };

    // 가상 주머니(Cache)에 복제본 저장
    GLOBAL_STAGING.cache[user.uid] = deepCopy(user);
}

/**
 * [원자적 개편: 포인트 게이트웨이 엔진] v7.2 (Staging 호환형)
 */
function util_updatePoint(user, roomData, delta, reason, roomName) {
    if (!user || isNaN(delta) || delta === 0) return;

    // [감시] 동일 사유로 연속 지급(delta > 0)되는 경우 체크
    if (delta > 0 && user.lastAction && user.lastAction.cmd === reason) {
        var timeGap = Date.now() - user.lastAction.time;
        
        // 무역 정산은 최소 1시간 이상 걸리는 작업이므로 10초(10000ms) 차단 적용
        if (reason.indexOf("무역 정산") !== -1 && timeGap < 10000) {
            Log.error("🚨 [무역 복사 차단] " + user.name + " (" + timeGap + "ms)");
            throw new Error("무역 정산 중복 실행 방지 작동 (5초 가드)");
        }
        
        // 그 외 일반 활동(스피또, 박스 등)은 정상적인 연속 호출을 고려해 1초(1000ms)만 방어
        else if (timeGap < 1000) {
            Log.error("🚨 [연타 과부하 차단] " + user.name + " : " + reason);
            throw new Error("시스템 과부하 방지 (연타 차단)");
        }
    }
    
