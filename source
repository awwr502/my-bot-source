/**
 * 통합 순자산 계산 엔진 (에러 로깅 및 안전성 강화)
 */
function util_calculateNetWorth(user, roomData) {
    if (!user) return 0;
    try {
        var data = getDatabase(); 
        
        // 1. 유동 자산 (현금 + 예금)
        var liquidAssets = Number(user.point || 0) + Number(user.bank || 0);
        
        // 2. 실물 자산 (무역 화물, 특산품, 진귀한 보물 가치 합산) - 기존 부동산 대체
        var physicalAssets = 0;
        for (var k in (user.cargo || {})) physicalAssets += Number(user.cargo[k] || 0) * Number((user.cargoAvg && user.cargoAvg[k]) || 10000);
        for (var k in (user.warehouse || {})) physicalAssets += Number(user.warehouse[k] || 0) * Number((user.warehouseAvg && user.warehouseAvg[k]) || 10000);
        for (var s in (user.specialties || {})) physicalAssets += Number(user.specialties[s] || 0) * 20000;
        for (var s in (user.warehouseSpec || {})) {
            if (s === "_rare") physicalAssets += Number(user.warehouseSpec[s] || 0) * 100000;
            else if (s === "_unknown") physicalAssets += Number(user.warehouseSpec[s] || 0) * 10000;
            else physicalAssets += Number(user.warehouseSpec[s] || 0) * 20000;
        }
        physicalAssets += Number(user.rareSpecialties || 0) * 100000;
        physicalAssets += Number(user.unknownCargo || 0) * 10000;

        // 3. 채권 및 채무 (은행 빚 및 사채)
        var bankDebt = (user.loan && user.loan.debt) ? Number(user.loan.debt) : 0;
        var sacheDebt = 0;
        var sacheClaims = 0; 

        if (roomData && roomData.loanContracts) {
            for (var cid in roomData.loanContracts) {
                var c = roomData.loanContracts[cid];
                if (c.borrowerUid === user.uid) sacheDebt += Number(c.currentDebt || 0);
                if (c.lenderUid === user.uid) sacheClaims += Number(c.currentDebt || 0);
            }
        }
        
        // 총 순자산 = 유동자산 + 실물자산 + 미수채권 - 은행빚 - 사채빚
        return Math.max(0, Math.floor(liquidAssets + physicalAssets + sacheClaims - bankDebt - sacheDebt));
    } catch(e) {
        Log.error("NetWorth Calculation Error for " + user.name + ": " + e);
        return Number(user.point || 0); 
    }
}

