                margin_y = int(grid_h * 0.1)
                
                left_bound = max(0, grid_w - margin_x)
                top_bound = max(0, grid_h - margin_y)
                
                fish_roi = {
                    "left": int(left_bound),
                    "top": int(top_bound),
                    "width": int(min(SCREEN_W - left_bound, grid_w + (margin_x * 2))),
