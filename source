                          "📦 상태: 모든 화물 안전하게 보존됨 (선박 적재 유지)";

            replier.reply(formatCommand("⚓ 긴급 회항 완료", user, resBody, "내 잔액: " + fp(user.point) + "P"));
            
            // 모든 연동 구역의 세션 제거 (1:1방 동기화 대응 및 명령어 먹통 방지)
            if (data.rooms[roomName].features.states.menuWait) delete data.rooms[roomName].features.states.menuWait[targetUid];
            if (data.rooms["내리다"].features.states.menuWait) delete data.rooms["내리다"].features.states.menuWait[targetUid];
            
            safeSaveData(data, true);
            return true;
        }
    }

    /* 하역 화물 선택 상태(trade_select_cargo) 처리 분기 추가 */
    if (state.type === 'trade_select_cargo') {
        _handleTradeCargoSelection(msg, user, data, replier, roomName, targetUid, tradeCfg);
        return true;
    }

    // 총독 집무실 관세 정산 핸들러 연결
    if (state.type === 'trade_governor_office') {
        _handleGovernorSettlement(msg, user, data, replier, roomName, targetUid);
        return true;
    }

    var choice = msg.replace(/[^0-9]/g, "").trim();
    
    /* [분기 3] 선박 관리 처리 (개조 및 수리 통합) */
    if (state.type === 'trade_ship') {
        var input = msg.replace(/\s/g, "");

        // [A] 수리 키워드 처리 (v16.9 신규)
        if (cleanMsg.indexOf("수리") !== -1) {
            var isPirate = (user.job === 'pirate');
            var homePort = isPirate ? "나소" : "무역 지부";
            var curLocClean = (user.currentLoc || "").replace(/\s/g, "");

            var pInfo = (roomData.features && roomData.features.portData) ? roomData.features.portData[user.currentLoc] : null;
            var hasShipyard = (pInfo && pInfo.built && pInfo.built.shipyard);

            if (curLocClean !== homePort.replace(/\s/g, "") && !hasShipyard) {
                replier.reply(formatError(user, "수리 불가", "이곳은 수리 시설이 없는 외지 항구입니다.\n조선소가 있는 자치령이나 '" + homePort + "'로 복귀하세요."));
                return true;
            }
            var curDura = Number(user.durability === undefined ? 100 : user.durability);
            if (curDura >= 100) {
                replier.reply(formatSimple("🔧 수리 불필요", "이미 선박 상태가 최상(100%)입니다."));
                return true;
            }
            var ecobase = Math.floor(util_getEcoMultiplier(logicRoom) * 100);
            var repairCost = (100 - curDura) * (300 + ecobase);
            var repairDiscount = (user.pediaRewardLevel >= 1) ? 0.95 : 1.0;
            repairCost = Math.floor(repairCost * repairDiscount);
            if (Number(user.point) < repairCost) {
                replier.reply(formatError(user, "수리비 부족", "수리비 " + fp(repairCost) + "P가 부족합니다."));
                return true;
            }
            util_updatePoint(user, roomData, -repairCost, "선박 내구도 완전 수리", roomName);
            user.durability = 100;
            user.skipHealing = true;
            var discountTag = (repairDiscount < 1.0) ? " (📘도감할인 -5%)" : "";
            replier.reply(formatCommand("🛠️ 선체 수리 완료", user, "기술자들이 밤새 매달려 배를 새것처럼 고쳤습니다!\n\n✨ 내구도: 100% 복구\n💰 소모 비용: -" + fp(repairCost) + "P" + discountTag, "내 잔액: " + fp(user.point) + "P"));
            delete menuWaitState[targetUid];
            safeSaveData(data, true);
            return true;
        }

        // [B] 기존 선박 개조 로직
        var choice = String(msg || "").replace(/[^0-9]/g, "").trim();
        if (choice === "1") {
            _processShipUpgrade(user, data, replier, roomName, tradeCfg);
            delete menuWaitState[targetUid];
        } else if (cleanMsg.indexOf("강화") !== -1) {
            _processShipEnhanceRoll(user, data, replier, roomName);
        } else {
            replier.reply(formatError(user, "입력 오류", "개조[1], 수리[수리], 강화[강화] 중 원하는 명령을 입력하세요."));
        }
        return true;
    }
    return false;
}

