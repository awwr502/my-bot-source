/* [최적화] 하이브리드 비동기 영속화(Asynchronous Persistence) 엔진 v7.0 (Multi-Gen Backup) */
/**
 * @param {Object} data - 저장할 데이터 객체
 * @param {Boolean} isForceBackup - true일 경우 3세대 순환 백업 실행
 */
function safeSaveData(data, isForceBackup) {
    if (!data) return;

    var isHealed = false; 
    var healReports = []; 

    try {
        var roomCount = Object.keys(data.rooms || {}).length;
        if (roomCount === 0) throw new Error("저장 거부: 방(rooms) 객체가 비어있습니다.");

        for (var rName in data.rooms) {
            var room = data.rooms[rName];
            
            // 검역용 기준 데이터 로드 (메인 파일이 아닌 각 방의 개별 파일을 실시간 조회)
            var safeRoomRef = null;
            var rFile = new java.io.File(BASE_DIR + "room_" + rName + ".json");
            if (rFile.exists()) {
                try { 
                    var rContent = FileStream.read(rFile.getAbsolutePath());
                    if (rContent) safeRoomRef = JSON.parse(rContent); 
                } catch(e) { Log.error(rName + " 검역 참조 실패: " + e); }
            }

            for (var uid in room.users) {
                var u = room.users[uid];
                if (u.skipHealing === true) continue; 

                // 분할된 기준 데이터(safeRoomRef)가 존재할 때만 무결성 수술 진행
                if (safeRoomRef && safeRoomRef.users && safeRoomRef.users[uid]) {
                    var safeU = safeRoomRef.users[uid];

                    var isFieldHealed = false;

                    // 파일(safeU)이 초기화된 상태일 경우, 메모리(u)의 데이터를 덮어씌우지 않도록 가드 추가
                    var filePoint = Number(safeU.point || 0);
                    var memoPoint = Number(u.point || 0);
                    if (filePoint < 1000 && memoPoint > 10000) continue; 

                    // A. 포인트 정밀 체크 (NaN 방어 및 비정상 급감 체크)
                    var lastPoint = filePoint;
                    var cr = getCreditInfo(u.creditScore || 600, rName);
                    var maxAllowDrop = Math.max(cr.limit * 1.5, lastPoint * 0.5);

                    if (isNaN(u.point) || u.point === null) {
                        u.point = lastPoint; 
                        isFieldHealed = true;
                    } else if (lastPoint > 10000 && (lastPoint - u.point) > maxAllowDrop) {
                        u.point = lastPoint;
                        isFieldHealed = true;
                    }

                    // B. 은행 잔고 정밀 체크
                    var lastBank = Number(safeU.bank || 0);
                    if (isNaN(u.bank) || u.bank === null) {
                        u.bank = lastBank;
                        isFieldHealed = true;
                    } else if (lastBank > 10000 && (lastBank - u.bank) / lastBank >= 0.8) {
                        u.bank = lastBank;
                        isFieldHealed = true;
                    }

                    // 논리적 무결성 상시 수술 (Auto-Surgical Repair)
                    // 1. 대출금 논리 체크: 잔액은 있는데 상세 내역이 증발한 경우 자동 복구
                    if (u.loan && Number(u.loan.debt) > 0) {
                        if (!Array.isArray(u.loan.items) || u.loan.items.length === 0) {
                            u.loan.items = [Number(u.loan.debt)];
                            isFieldHealed = true;
                            Log.warn("🩹 [Surgical] " + u.name + " 대출 내역 논리 복구");
                        }
                    }

                    // 2. 항해 데이터 논리 체크: 활성화 상태인데 필수 정보가 누락된 경우 강제 귀항
                    if (u.voyage && u.voyage.active === true) {
                        if (!u.voyage.dest || !u.voyage.arrival || isNaN(u.voyage.arrival)) {
                            u.voyage.active = false;
                            isFieldHealed = true;
                            Log.warn("🩹 [Surgical] " + u.name + " 비정상 항해 세션 종료");
                        }
                    }

                    // 3. 음수 자산 강제 정규화
                    if (Number(u.point) < 0) { u.point = 0; isFieldHealed = true; }
                    if (Number(u.bank) < 0) { u.bank = 0; isFieldHealed = true; }

                    // C. 부동산 지분 정밀 체크
                    if (safeU.landHoldings && u.landHoldings) {
                        for (var lName in safeU.landHoldings) {
                            var lastQty = Number(safeU.landHoldings[lName] || 0);
                            var curQty = Number(u.landHoldings[lName] || 0);
                            if (lastQty >= 10 && (lastQty - curQty) / lastQty >= 0.8) {
                                u.landHoldings[lName] = lastQty; 
                                isFieldHealed = true;
                            }
                        }
                    }

                    var lastInvCount = Array.isArray(safeU.inventory) ? safeU.inventory.length : 0;
                    var curInvCount = Array.isArray(u.inventory) ? u.inventory.length : 0;
                    if (lastInvCount >= 5 && (curInvCount / lastInvCount) <= 0.2) {
                        u.inventory = JSON.parse(JSON.stringify(safeU.inventory));
                        isFieldHealed = true;
                    }

                    if (isFieldHealed) {
                        isHealed = true;
                        healReports.push(u.name + " (무결성 정밀 수술 완료)");
                    }
                }
            } 
        } 

        // 모든 방의 검사가 끝난 시점에 한 번만 치유 보고서 발송
        if (isHealed && healReports.length > 0) {
            try {
                var reportMsg = util_formatSecurityLog(
                    "🩹 [SYSTEM: 자가 무결성 수술 보고]", 
                    "HEALER_BOT", 
                    "ALL_ROOMS", 
                    "✅ 내용: 논리적 결함 및 자산 오염 자동 수정 완료\n📊 대상: " + healReports.length + "명 추출됨",
                    "메모리 정규화 및 물리 저장 데이터 반영"
                );
                Api.replyRoom("베릭방", reportMsg);
            } catch(e) {}
        }

    } catch (validationError) {
        Log.error("!!! [데이터 오염 방지 작동] !!!: " + validationError.message);
        try { Api.replyRoom("베릭방", "🚨 [데이터 보호] 오염 감지로 자동 저장 차단: " + validationError.message); } catch (e) {}
        return; 
    }

    globalData = data;

    if (isForceBackup) {
        if (typeof _saveTimer !== 'undefined' && _saveTimer) { clearTimeout(_saveTimer); _saveTimer = null; }
        _performPhysicalSave(data, isForceBackup);
    } else {
        if (typeof _saveTimer !== 'undefined' && _saveTimer) return; 
        _saveTimer = setTimeout(function() {
            _performPhysicalSave(data, false);
            _saveTimer = null;
        }, 2000);
    }
}

var _saveTimer = null; 
function _performPhysicalSave(data, isForceBackup) {
    // 1. [준비] 실제 파일로 쓰기 위한 글자 데이터(문자열) 임시 보관소
    var shardedStrings = {};
    var systemString = "";
    var backupString = null;

    // 2. [찰나의 잠금] 데이터를 문자열로 복제하는 동안만 아주 짧게 잠급니다.
    // tryLock 대신 강제 lock을 사용하여 0.01초 내외의 순수 메모리 연산만 수행합니다.
    lock.lock(); 
    try {
        // [v16.0 지능형 소각 엔진 적용]
        if (typeof util_fastClean === 'function') util_fastClean(data, 0);

        // 모든 방의 데이터를 순식간에 문자열(JSON)로 추출하여 메모리에 임시 보관
        for (var rName in data.rooms) {
            shardedStrings[rName] = JSON.stringify(data.rooms[rName]);
        }

        // 시스템 설정 스냅샷 추출 (rooms 제외)
        var systemSnapshot = {};
        for (var key in data) {
            if (key !== 'rooms') systemSnapshot[key] = data[key];
        }
        systemString = JSON.stringify(systemSnapshot);

        if (isForceBackup) {
            backupString = JSON.stringify(data);
        }
    } catch (e) {
        Log.error("💾 스냅샷 생성 실패: " + e.message);
        return;
    } finally {
        // [중요] 문자열 추출(Snapshot)이 끝나자마자 즉시 잠금을 해제합니다!
        // 이제부터 파일 쓰기가 아무리 느려도 다른 명령어들은 락에 걸리지 않습니다.
        lock.unlock(); 
    }

    // 3. [배경 처리] 잠금이 해제된 상태에서 느린 파일 쓰기(I/O)를 비동기로 수행합니다.
    SaveExecutor.execute(new java.lang.Runnable({
        run: function() {
            try {
                // 방별 분할 파일 기록 (하드디스크 쓰기)
                for (var rName in shardedStrings) {
                    var roomFileName = BASE_DIR + "room_" + rName + ".json";
                    FileStream.write(roomFileName, shardedStrings[rName]);
                }

                // 메인 설정 파일 기록
                FileStream.write(FILE_PATH, systemString);

                // 백업 파일 기록
                if (isForceBackup && backupString) {
                    var cycle = (data._backupCycle % 3) + 1;
                    var cycleFileName = "stable_backup_" + cycle + ".json";
                    
                    // 1. 순환 백업 파일 기록 (1, 2, 3번 중 하나)
                    FileStream.write(BACKUP_DIR + cycleFileName, backupString);
                    
                    // 2. 통합 복구용 고정 파일 기록 (복원 명령어 참조용)
                    FileStream.write(BACKUP_DIR + "last_stable_backup.json", backupString);
                    
                    data._backupCycle = cycle;
                }
                
                // 가비지 컬렉션 유도 및 메모리 비우기
                shardedStrings = null; systemString = null; backupString = null;
                java.lang.System.gc();
            } catch (e) {
                Log.error("💾 배경 저장 중 오류: " + e.message);
                try { Api.replyRoom("베릭방", "🚨 [저장 엔진] 배경 쓰기 실패: " + e.message); } catch(err){}
            }
        }
    }));
}

