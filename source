/** * [B] 실제 지급 탐색 기계 (함수 바깥 - 전역 스코프)
 * 부분 일치 검색을 통해 아이템을 찾고, 중복 시 선택 창으로 유도합니다.
 */
function _executeItemGive(tUser, iName, count, replier, tRoom, adminUser, adminUid, adminRoom) {
    var cleanI = iName.replace(/\s/g,"");
    var matches = [];

    // 1. 특수 재화 매핑
    var specialNames = ["왕실 훈장", "고대 지도", "유물 조각", "미확인 교역품", "진귀한 보물"];
    specialNames.forEach(function(n) {
        if (n.indexOf(cleanI) !== -1 || cleanI.indexOf(n) !== -1) matches.push({ type: "special", name: n });
    });

    // 2. 동적 화물 (일반 교역품)
    var tradeGoods = Object.keys(SYSTEM_CONFIG.TRADE.GOODS_COST);
    if (tradeGoods.indexOf("밀수품") === -1) tradeGoods.push("밀수품");
    tradeGoods.forEach(function(n) {
        if (n.indexOf(cleanI) !== -1 || cleanI.indexOf(n) !== -1) matches.push({ type: "cargo", name: n });
    });

    // 3. 동적 특산품
    for (var n in TRADE_RELATION) {
        var sName = TRADE_RELATION[n].set;
        if (sName.replace(/\s/g,"").indexOf(cleanI) !== -1 || cleanI.indexOf(sName.replace(/\s/g,"")) !== -1) {
            matches.push({ type: "spec", name: sName });
        }
    }

    // 5. 상점 아이템 (무역 상점)
    for (var i = 0; i < SHOP_ITEMS.length; i++) {
        var shName = SHOP_ITEMS[i].name;
        if (shName.replace(/\s/g,"").indexOf(cleanI) !== -1 || cleanI.indexOf(shName.replace(/\s/g,"")) !== -1) {
            var dup = false;
            for(var j=0; j<matches.length; j++) { 
                if(matches[j].name.replace(/\s/g,"") === shName.replace(/\s/g,"")) dup=true; 
            }
            if(!dup) matches.push({ type: "shop", name: shName, item: SHOP_ITEMS[i] });
        }
    }

    // [정밀 필터] 완전히 일치하는 항목이 있다면 중복 창을 무시하고 해당 항목으로 즉시 확정
    var exactMatches = matches.filter(function(m) { return m.name.replace(/\s/g,"") === cleanI; });
    if (exactMatches.length > 0) {
        matches = exactMatches;
    }

    // 아이템 중복 발생 시 선택 핸들러 호출
    if (matches.length > 1) {
        if (typeof handleItemSelection === 'function') {
            handleItemSelection(replier, adminUid, matches, "admin_item_give_confirm", { tUserUid: tUser.uid, tRoom: tRoom, qty: count, iName: iName }, adminUser, adminRoom);
        } else {
            replier.reply("오류: 아이템 중복 선택 핸들러를 찾을 수 없습니다.");
        }
        return;
    } 
    
    // 일치하는 시스템 아이템이 없을 경우 기존처럼 수동 지급 처리 (창고 강제 선적용)
    var finalItemInfo = (matches.length === 1) ? matches[0] : { type: "manual", name: iName };
    
    _finalizeItemGive(tUser, finalItemInfo, count, replier, tRoom);
}

