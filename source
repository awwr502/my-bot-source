function _handleWarehouseAction(msg, user, data, replier, roomName, targetUid) {
    var roomData = data.rooms[roomName];
    var state = roomData.features.states.menuWait[targetUid];
    var input = msg.trim();
    var mode = state.extra.mode;
    var items = state.extra.items;
    var remCap = state.extra.remCap;

    if (remCap <= 0) return replier.reply(formatError(user, "공간 부족", "목적지에 더 이상 적재할 공간이 없습니다."));

    if (!user.warehouse) user.warehouse = {};
    if (!user.warehouseAvg) user.warehouseAvg = {};
    if (!user.warehouseSpec) user.warehouseSpec = {};
    if (!user.cargo) user.cargo = {};
    if (!user.cargoAvg) user.cargoAvg = {};
    if (!user.specialties) user.specialties = {};

    var processMove = function(item, reqQty) {
        var moveQty = Math.min(reqQty, item.qty, remCap);
        if (moveQty <= 0) return 0;

        if (mode === "deposit") {
            if (item.type === 'cargo') {
                var sAvg = Number(user.cargoAvg[item.name] || SYSTEM_CONFIG.TRADE.GOODS_COST[item.name] || 10000);
                var wQty = Number(user.warehouse[item.name] || 0);
                var wAvg = Number(user.warehouseAvg[item.name] || 0);
                user.warehouseAvg[item.name] = Math.floor(((wAvg * wQty) + (sAvg * moveQty)) / (wQty + moveQty));
                user.warehouse[item.name] = wQty + moveQty;
                user.cargo[item.name] -= moveQty;
                if (user.cargo[item.name] <= 0) delete user.cargo[item.name];
            } else {
                user.warehouseSpec[item.name] = (Number(user.warehouseSpec[item.name]) || 0) + moveQty;
                if (item.name === '_rare') user.rareSpecialties -= moveQty;
                else if (item.name === '_unknown') user.unknownCargo -= moveQty;
                else { user.specialties[item.name] -= moveQty; if (user.specialties[item.name] <= 0) delete user.specialties[item.name]; }
            }
        } else {
            if (item.type === 'cargo') {
                var wAvg = Number(user.warehouseAvg[item.name] || SYSTEM_CONFIG.TRADE.GOODS_COST[item.name] || 10000);
                var sQty = Number(user.cargo[item.name] || 0);
                var sAvg = Number(user.cargoAvg[item.name] || 0);
                user.cargoAvg[item.name] = Math.floor(((sAvg * sQty) + (wAvg * moveQty)) / (sQty + moveQty));
                user.cargo[item.name] = sQty + moveQty;
                user.warehouse[item.name] -= moveQty;
                if (user.warehouse[item.name] <= 0) delete user.warehouse[item.name];
            } else {
                if (item.name === '_rare') user.rareSpecialties = (Number(user.rareSpecialties) || 0) + moveQty;
                else if (item.name === '_unknown') user.unknownCargo = (Number(user.unknownCargo) || 0) + moveQty;
                else user.specialties[item.name] = (Number(user.specialties[item.name]) || 0) + moveQty;
                
                user.warehouseSpec[item.name] -= moveQty;
                if (user.warehouseSpec[item.name] <= 0) delete user.warehouseSpec[item.name];
            }
        }
        remCap -= moveQty;
        return moveQty;
    };

    var movedTotal = 0;
    if (input === "전부") {
        for (var i = 0; i < items.length; i++) {
            if (remCap <= 0) break;
            movedTotal += processMove(items[i], items[i].qty);
        }
    } else {
        var parts = input.split(/\s+/);
        var idx = parseInt(parts[0]) - 1;
        if (isNaN(idx) || idx < 0 || idx >= items.length) return replier.reply(formatError(user, "번호 오류", "목록에 있는 번호를 입력하세요."));
        var inputQty = parts.length > 1 ? parseInt(parts[1].replace(/[^0-9]/g, "")) : remCap;
        movedTotal = processMove(items[idx], inputQty);
    }

    user.skipHealing = true;
    safeSaveData(data, true);

    if (movedTotal > 0) replier.reply(formatCommand("✅ 이동 완료", user, "성공적으로 " + movedTotal + "상자의 물자를 " + (mode==="deposit"?"입고":"출고") + "했습니다."));
    else replier.reply(formatError(user, "이동 실패", "옮길 수 있는 물자가 없거나 공간이 부족합니다."));

    _showWarehouseUI(user, replier, roomData);
    roomData.features.states.menuWait[targetUid] = { type: 'trade_warehouse', time: Date.now(), originRoom: roomName };
}

