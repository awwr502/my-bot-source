                time.sleep(0.5)
                continue
                
            swap_attempts += 1
            if swap_attempts > 10:
                bprint("  > ❌ [장착 실패] 예비 낚싯대가 모두 소진되었거나 꼬였습니다. 스마트 복구를 호출합니다.")
