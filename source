/**
 * [시스템 모듈] 던전 탐험 엔진 (Roguelike RPG) Phase 1
 * 기능: 로비, 길드/상점 뼈대, 스탯 관리, 허기/스태미나 기반의 탐사 분기 시스템
 */

function _gameDungeonLogic(msg, user, data, replier, roomName, targetUid) {
    var logicRoom = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var roomData = data.rooms[logicRoom];

    // 던전 스키마 무결성 검사 (업데이트 전 생성된 유저 대비)
    if (!user.dgnStat) {
        user.dgnStat = { hp: 100, maxHp: 100, stam: 50, maxStam: 50, hunger: 100, maxHunger: 100, str: 10, agi: 10, int: 10 };
        user.dgnEquip = { weapon: null, armor: null, acc: null };
        user.dgnBag = [];
        user.dgnGuild = { rank: 'F', exp: 0, clearCount: 0 };
        user.dgnGold = 0;
    }

    // [세이브포인트 연동] 탐험 중이거나 휴식 중이었을 경우 자동 복구
    if (user.dgnState && user.dgnState.inProgress) {
        if (user.dgnState.isResting) {
            _processDungeonWakeUp(user, data, replier, logicRoom, targetUid);
            return true;
        }
        
        if (user.dgnState.combat) {
            roomData.features.states.menuWait[targetUid] = { type: 'dgn_combat_main', time: Date.now(), originRoom: roomName };
            _showDgnCombatMain(user, replier, "⚠️ 탐험을 재개합니다. 적이 눈앞에 있습니다!");
        } else {
            roomData.features.states.menuWait[targetUid] = { type: 'dgn_turn', time: Date.now(), originRoom: roomName };
            _showDungeonTurn(user, replier);
        }
        return true;
    }

    _showDungeonLobby(user, replier, roomData, targetUid, roomName);
    return true;
}

function _showDungeonLobby(user, replier, roomData, targetUid, roomName) {
    var s = user.dgnStat;
    var body = "어둡고 습한 해저 동굴의 입구, [탐험가 마을]에 도착했습니다.\n\n" +
               "📊 [내 상태]\n" +
               "💰 금화: " + fp(user.dgnGold || 0) + " G\n" +
               "❤️ HP: " + s.hp + " / " + s.maxHp + "\n" +
               "⚡ ST: " + s.stam + " / " + s.maxStam + " | 🍖 허기: " + s.hunger + " / " + s.maxHunger + "\n" +
               "🎒 가방: " + user.dgnBag.length + " / " + SYSTEM_CONFIG.DUNGEON.MAX_BAG_SLOTS + " 칸\n" +
               "━━━━━━━━━━━━━━━\n" +
               "1. ⚔️ 던전 진입 (입장료 10,000P 소모)\n" +
               "2. 🛡️ 길드 지부 (의뢰/창고 관리)\n" +
               "3. 🏪 상점 구역 (장비/물약 구매)\n" +
               "4. 🎒 내 정보 및 장비 세팅\n\n" +
               "↩️ 뒤로 / ❎취소";

    replier.reply(formatCommand("🏕️ 탐험가 마을 로비", user, body, "이동할 장소의 번호를 입력하세요."));
    roomData.features.states.menuWait[targetUid] = { type: 'dgn_lobby', time: Date.now(), originRoom: roomName };
}

function _handleDungeonState(msg, user, data, replier, roomName, targetUid, state) {
    var choice = msg.trim();
    var logicRoom = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var roomData = data.rooms[logicRoom];

    // [세이브포인트] 휴식 대기열 응답 (아무 채팅이나 치면 기상)
    if (state.type === 'dgn_rest') {
        return _processDungeonWakeUp(user, data, replier, logicRoom, targetUid);
    }

    if (state.type === 'dgn_lobby') {
        if (choice === "1") _startDungeon(user, data, replier, logicRoom, targetUid);
        else if (choice === "2") _showDgnGuildMain(user, replier, roomData, targetUid, logicRoom);
        else if (choice === "3") _showDgnShopMain(user, replier, roomData, targetUid, logicRoom);
        else if (choice === "4") _showDgnInfoMain(user, replier, roomData, targetUid, logicRoom);
        else replier.reply(formatError(user, "입력 오류", "정확한 번호를 입력해주세요."));
    }
    // [길드 라우터]
    else if (state.type === 'dgn_guild_main') {
        if (choice === "1") _showDgnStorage(user, replier, roomData, targetUid, logicRoom);
        else if (choice === "2") _showDgnGuildQuest(user, replier, roomData, targetUid, logicRoom);
        else replier.reply(formatError(user, "입력 오류", "정확한 번호를 입력하세요."));
    }
    else if (state.type === 'dgn_guild_storage') {
        _processDgnStorage(choice, user, data, replier, logicRoom, targetUid);
    }
    else if (state.type === 'dgn_guild_quest') {
        _processDgnGuildQuest(choice, user, data, replier, logicRoom, targetUid);
    }
    // [상점 라우터]
    else if (state.type === 'dgn_shop_main') {
        _processDgnShop(choice, user, data, replier, logicRoom, targetUid);
    }
    // [내 정보 라우터]
    else if (state.type === 'dgn_info_main') {
        if (choice === "1") _showDgnEquipMenu(user, replier, roomData, targetUid, logicRoom);
        else if (choice === "2") _processDgnUnequip(user, data, replier, logicRoom, targetUid);
        else replier.reply(formatError(user, "입력 오류", "1번(장착) 또는 2번(해제)을 선택하세요."));
    }
    else if (state.type === 'dgn_info_equip') {
        _processDgnEquip(choice, user, data, replier, logicRoom, targetUid);
    }
    // [전투 및 탐사 라우터]
    else if (state.type === 'dgn_turn') {
        _processDungeonTurn(choice, user, data, replier, logicRoom, targetUid);
    }
    else if (state.type === 'dgn_merchant') {
        if (choice === "1") {
            if ((user.dgnGold || 0) < 50000) return replier.reply(formatError(user, "금화 부족", "던전 금화가 부족합니다."));
            user.dgnGold -= 50000;
            user.ancientMaps = (user.ancientMaps || 0) + 1;
            user.skipHealing = true;
            replier.reply(formatCommand("💰 거래 완료", user, "떠돌이 상인에게서 '고대 지도' 1장을 구매했습니다!\n(50,000 G 차감)\n상인은 안개 속으로 사라집니다."));
            delete roomData.features.states.menuWait[targetUid];
            safeSaveData(data, true);
        } else {
            replier.reply(formatCommand("🚶 거래 거절", user, "상인을 무시하고 갈 길을 갑니다."));
            roomData.features.states.menuWait[targetUid] = { type: 'dgn_turn', time: Date.now(), originRoom: logicRoom };
            _showDungeonTurn(user, replier);
        }
    }
    else if (state.type === 'dgn_combat_main') {
        _processDgnCombatMain(choice, user, data, replier, logicRoom, targetUid);
    }
    else if (state.type === 'dgn_combat_dir') {
        _processDgnCombatDir(choice, user, data, replier, logicRoom, targetUid);
    }
}

function _startDungeon(user, data, replier, roomName, targetUid) {
    // 1. 입장권 검사 (현재는 임시로 10000P 차감으로 대체, 추후 인벤토리 입장권 아이템으로 변경 가능)
    var cost = SYSTEM_CONFIG.DUNGEON.TICKET_PRICE;
    if (user.point < cost) {
        return replier.reply(formatError(user, "입장 불가", "던전 탐험 허가증을 구매할 " + fp(cost) + "P가 부족합니다."));
    }

    // 2. 가방 공간 검사
    if (user.dgnBag.length >= SYSTEM_CONFIG.DUNGEON.MAX_BAG_SLOTS) {
        return replier.reply(formatError(user, "가방 포화", "가방이 꽉 찼습니다! 길드 창고에 물건을 맡기거나 버린 후 진입하세요."));
    }

    // 결제 진행 (입장권은 외부 포인트 소모)
    util_updatePoint(user, data.rooms["내리다"], -cost, "던전 입장료 지불", roomName);

    // 3. 던전 환경(State) 생성
    user.dgnState = {
        inProgress: true,
        zone: "SWAMP", // 첫 구역인 늪지대부터 시작
        depth: 1,  // 층수
        log: "축축한 냄새가 코를 찌릅니다. 동굴 내부로 발을 들였습니다.",
        loots: { points: 0, items: [] } // 이번 탐험에서 얻은 금화/전리품
    };
    user.skipHealing = true;
    safeSaveData(data, true);

    // 탐험 턴 세션으로 전환
    data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_turn', time: Date.now(), originRoom: roomName };
    _showDungeonTurn(user, replier);
}

function _showDungeonTurn(user, replier) {
    var s = user.dgnStat;
    var d = user.dgnState;
    var zInfo = SYSTEM_CONFIG.DUNGEON.ZONES[d.zone] || SYSTEM_CONFIG.DUNGEON.ZONES["SWAMP"];

    var hpBar = "🟥".repeat(Math.ceil(s.hp/s.maxHp*5)) + "⬜".repeat(5-Math.ceil(s.hp/s.maxHp*5));
    var hgBar = "🍖".repeat(Math.ceil(s.hunger/s.maxHunger*5)) + "⬜".repeat(5-Math.ceil(s.hunger/s.maxHunger*5));

    // [특성: 동굴 암흑 가드] 횃불 유무 확인
    var hasTorch = user.dgnBag.some(function(it) { return it.name === "횃불"; });
    var isDark = (d.zone === "CAVE" && !hasTorch);

    var lootsText = "없음";
    if ((d.loots.points && d.loots.points > 0) || (d.loots.items && d.loots.items.length > 0)) {
        var itmCnt = {};
        d.loots.items.forEach(function(it) { itmCnt[it] = (itmCnt[it] || 0) + 1; });
        var itmStrArr = [];
        for (var k in itmCnt) itmStrArr.push(k + "x" + itmCnt[k]);
        
        lootsText = (d.loots.points > 0 ? d.loots.points + " G" : "") + 
                    (d.loots.points > 0 && itmStrArr.length > 0 ? " / " : "") + 
                    itmStrArr.join(", ");
    }

    var body = "📍 구역: [" + zInfo.name + "] - " + d.depth + "층\n" +
               "✨ 특성: " + zInfo.trait + " (" + zInfo.desc + ")\n" +
               "❤️ HP: " + hpBar + " (" + s.hp + "/" + s.maxHp + ")\n" +
               "🥩 허기: " + hgBar + " (" + s.hunger + "/" + s.maxHunger + ")\n" +
               "━━━━━━━━━━━━━━━\n" +
               "📜 [진행 상황]\n" + d.log + "\n\n" +
               "🎁 [획득 전리품]\n" + lootsText + "\n" +
               "━━━━━━━━━━━━━━━\n" +
               "앞으로 나아갈 길을 선택하세요.\n\n";

    if (isDark) {
        body += "1. 🚶 [암흑] 보이지 않는 길을 걷는다.\n" +
                "   └ (횃불 없음! 50% 확률 조우 / 50% 확률 하강, 🍖허기 -10)\n";
    } else {
        body += "1. 🔍 꼼꼼하게 탐사한다.\n" +
                "   └ (적/이벤트/채집 조우 100%, 🍖허기 -5)\n" +
                "2. ⏩ 하강을 서두른다.\n" +
                "   └ (적 조우 20% / 다음 층 패스 80%, 🍖허기 -15)\n";
    }

    body += "3. ⛺ 텐트를 치고 휴식한다.\n" +
            "4. 🎒 물약/가방 열기\n" +
            "5. 🏃 귀환 주문서 사용 (마을로 도망)";

    replier.reply(formatCommand("🗺️ 미궁 탐험 중", user, body, "행동 번호를 입력하세요."));
}

function _processDungeonTurn(choice, user, data, replier, roomName, targetUid) {
    var s = user.dgnStat;
    var d = user.dgnState;

    var hasTorch = user.dgnBag.some(function(it) { return it.name === "횃불"; });
    var isDark = (d.zone === "CAVE" && !hasTorch);

    if (choice === "1" || choice === "2") {
        if (isDark && choice === "2") {
            return replier.reply(formatError(user, "명령 거부", "암흑 속에서는 방향을 알 수 없어 하강(2번)을 선택할 수 없습니다.\n1번을 선택해 감에 의존하여 전진하세요."));
        }

        var isExplore = (choice === "1");
        var hungerCost = isExplore ? 5 : 10;
        if (isDark) hungerCost = 10; // 암흑 패널티

        // 허기 계산 및 아사(조난) 판정
        s.hunger -= hungerCost;
        if (s.hunger < 0) {
            var starveDmg = Math.abs(s.hunger) * 2; 
            s.hp -= starveDmg;
            s.hunger = 0;
            d.log = "⚠️ 극심한 굶주림으로 인해 체력이 깎입니다! (-" + starveDmg + " HP)\n";
        } else {
            d.log = "";
        }

        if (s.hp <= 0) return _handlePlayerDeath(user, data, replier, roomName, targetUid);

        var movedDown = false;
        var encounterProb = isExplore ? 1.0 : 0.20; // 탐사 100%, 하강 20% 조우율

        // 행동 판정 (조우 여부 결정)
        if (Math.random() < encounterProb) {
            // [무한의 탑 스폰 로직] 10층마다 엘리트, 50층마다 보스 확정 출현
            var isBossEncounter = (d.depth % 50 === 0); 
            var isEliteEncounter = (!isBossEncounter && d.depth % 10 === 0);
            
            var encounterType = Math.random() * 100;
            
            if (encounterType < 60 || !isExplore || isBossEncounter || isEliteEncounter) {
                var targetMonster;
                var monList = DGN_MONSTER_DB[d.zone] || DGN_MONSTER_DB["SWAMP"];
                
                if (isBossEncounter) {
                    var bosses = monList.filter(function(m) { return m.type === "boss"; });
                    targetMonster = bosses[Math.floor(Math.random() * bosses.length)] || monList[0];
                } else if (isEliteEncounter) {
                    var elites = monList.filter(function(m) { return m.type === "elite"; });
                    targetMonster = elites[Math.floor(Math.random() * elites.length)] || monList[0];
                } else {
                    var normals = monList.filter(function(m) { return m.type === "normal"; });
                    targetMonster = normals[Math.floor(Math.random() * normals.length)];
                }

                // [무한의 탑 난이도 스케일링] 10층을 넘길 때마다 몬스터 스탯 50%씩 누적 증가
                var scaleMult = 1 + Math.floor((d.depth - 1) / 10) * 0.5;
                var scaledMob = JSON.parse(JSON.stringify(targetMonster));
                scaledMob.maxHp = Math.floor(scaledMob.maxHp * scaleMult);
                scaledMob.hp = scaledMob.maxHp;
                scaledMob.atk = Math.floor(scaledMob.atk * scaleMult);
                scaledMob.gold[0] = Math.floor(scaledMob.gold[0] * scaleMult);
                scaledMob.gold[1] = Math.floor(scaledMob.gold[1] * scaleMult);

                d.combat = {
                    mob: scaledMob,
                    turn: 1
                };
                user.skipHealing = true;

                data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_combat_main', time: Date.now(), originRoom: roomName };
                var hintObj = d.combat.mob.hints[Math.floor(Math.random() * d.combat.mob.hints.length)];
                d.combat.bossHintText = hintObj.text;
                d.combat.bossAtkDirs = hintObj.attacks;
                
                safeSaveData(data, false);
                var encounterTitle = isBossEncounter ? "👑 [보스 출현]" : (isEliteEncounter ? "👹 [엘리트 출현]" : "⚠️ [적 출현]");
                return _showDgnCombatMain(user, replier, encounterTitle + " " + scaledMob.name + "이(가) 앞을 가로막습니다!");
            }

            // [25% 확률: 채집물 발견]
            else if (encounterType < 85) {
                var isOre = Math.random() < 0.5;
                var reqTool = isOre ? "낡은 곡괭이" : "채집용 낫";
                var rewardItem = isOre ? "철광석" : "마력 깃든 약초";
                
                var toolIdx = -1;
                for (var i = 0; i < user.dgnBag.length; i++) {
                    if (user.dgnBag[i].name === reqTool) { toolIdx = i; break; }
                }

                if (toolIdx !== -1) {
                    user.dgnBag[toolIdx].usage = (user.dgnBag[toolIdx].usage || 5) - 1;
                    if (user.dgnBag[toolIdx].usage <= 0) user.dgnBag.splice(toolIdx, 1); 
                    
                    if (user.dgnBag.length < SYSTEM_CONFIG.DUNGEON.MAX_BAG_SLOTS) {
                        user.dgnBag.push({ name: rewardItem, type: "mat", rank: (isOre ? "일반" : "희귀") });
                        d.log += "⛏️ [" + reqTool + "]를 사용하여 [" + rewardItem + "]을(를) 채집했습니다!";
                    } else {
                        d.log += "⛏️ 채집에 성공했으나 가방이 꽉 차서 챙기지 못했습니다.";
                    }
                } else {
                    d.log += "🌿 신비한 자원을 발견했으나 [" + reqTool + "] 도구가 없어 채집하지 못했습니다.";
                }
                movedDown = true;
            } 

            // [15% 확률: 랜덤 이벤트 (제단/미믹 등)]
            else {
                var evtRand = Math.random();
                if (evtRand < 0.2) {
                    data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_merchant', time: Date.now(), originRoom: roomName };
                    return replier.reply(formatCommand("💰 떠돌이 상인", user, "어둠 속에서 떠돌이 상인을 만났습니다!\n\"진귀한 '고대 지도'를 50,000 G에 사겠나?\"\n\n1. 구매한다 (5만 금화 차감)\n2. 무시한다", "번호를 입력하세요."));
                } else if (evtRand < 0.5) {
                    var healAmt = Math.floor(s.maxHp * 0.3);
                    s.hp = Math.min(s.maxHp, s.hp + healAmt);
                    d.log += "⛲ [여신의 제단] 맑은 샘물을 마시고 체력을 " + healAmt + " 회복했습니다!";
                } else if (evtRand < 0.8) {
                    var dropGold = Math.floor(Math.random() * 5000) + 1000;
                    d.loots.points += dropGold;
                    d.log += "🏺 [오래된 상자] 먼지 쌓인 상자에서 " + dropGold + " G를 발견했습니다!";
                } else {
                    var trapDmg = Math.floor(s.maxHp * 0.2);
                    s.hp -= trapDmg;
                    d.log += "💥 [미믹의 함정] 보물상자인 줄 알았으나 함정이었습니다! (-" + trapDmg + " HP)";
                }
                if (s.hp <= 0) return _handlePlayerDeath(user, data, replier, roomName, targetUid);
                movedDown = true;
            }
        } else {
            // 조우하지 않았을 경우
            if (!isExplore) {
                d.log += "⏩ 몬스터를 피해 빠르게 다음 층 계단을 찾아 내려갔습니다!";
            } else {
                d.log += "🔍 바닥을 샅샅이 뒤졌으나 별다른 소득이 없었습니다. 더 깊이 전진합니다.";
            }
            movedDown = true;
        }

        // 층수 이동 시 구역 루프 및 특성 발동
        if (movedDown) {
            d.depth++;
            
            // [무한의 탑 맵 루프] 10층마다 다음 구역으로 배경 순환 변경
            var zones = SYSTEM_CONFIG.DUNGEON.ZONE_ORDER;
            var zoneIdx = Math.floor((d.depth - 1) / 10) % zones.length;
            var prevZone = d.zone;
            d.zone = zones[zoneIdx];
            
            if (prevZone !== d.zone) {
                d.log += "\n\n✨ 주변 환경이 [" + SYSTEM_CONFIG.DUNGEON.ZONES[d.zone].name + "](으)로 변했습니다!";
            }

            if (d.zone === "DESERT" && Math.random() < 0.15) {
                var stormDmg = Math.floor(s.maxHp * 0.1);
                s.hp -= stormDmg;
                d.log += "\n🌪️ [모래폭풍] 거친 모래바람에 휩싸여 체력을 잃었습니다! (-" + stormDmg + " HP)";
            }
            if (d.zone === "CANYON") {
                var fillRatio = user.dgnBag.length / SYSTEM_CONFIG.DUNGEON.MAX_BAG_SLOTS;
                if (fillRatio >= 0.7) {
                    var fallProb = 0.20 + (fillRatio - 0.70); 
                    fallProb = Math.min(0.50, fallProb);
                    if (Math.random() < fallProb) {
                        var fallDmg = Math.floor(s.maxHp * 0.15);
                        s.hp -= fallDmg;
                        var loseCount = Math.floor(user.dgnBag.length * 0.25);
                        for (var i = 0; i < loseCount; i++) user.dgnBag.pop(); 
                        d.log += "\n💥 [추락] 무게를 이기지 못하고 협곡 다리에서 굴러 떨어졌습니다!\n(-" + fallDmg + " HP, 가방 물품 " + loseCount + "개 유실)";
                    }
                }
            }
        }

        if (s.hp <= 0) return _handlePlayerDeath(user, data, replier, roomName, targetUid);

        user.skipHealing = true;
        safeSaveData(data, false);
        data.rooms[roomName].features.states.menuWait[targetUid].time = Date.now();
        _showDungeonTurn(user, replier);
    } 
    else if (choice === "3") {
        // [실시간 캠핑 시스템 도입]
        var hasTent = user.dgnBag.some(function(it) { return it.name === "휴식용 텐트"; });
        
        d.isResting = true;
        d.restStartTime = Date.now();
        d.hasTent = hasTent;
        
        user.skipHealing = true;
        data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_rest', time: Date.now(), originRoom: roomName };
        safeSaveData(data, false);
        
        return replier.reply(formatCommand("⛺ 캠프 구축", user, "동굴 한켠에 자리를 잡고 휴식에 들어갑니다.\n(최대 30분간 분당 HP/ST/허기가 지속 회복됩니다.)\n\n탐험을 재개하려면 준비가 끝난 후 아무 채팅이나 입력하세요."));
    }
    else if (choice === "4") {
        // 가방 열기 (턴 소모 안함, 메뉴만 이동)
        data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_info_main', time: Date.now(), originRoom: roomName };
        return _showDgnInfoMain(user, replier, data.rooms[roomName], targetUid, roomName);
    }
    else if (choice === "5") {
        // [임시 귀환 로직] 아이템이 아직 없으므로 무조건 성공
        d.inProgress = false;
        var earnedGold = d.loots.points || 0;
        user.dgnGold = (user.dgnGold || 0) + earnedGold;
        
        user.dgnState = null;
        s.hp = s.maxHp; // 마을 귀환 시 풀피 (임시)
        s.hunger = s.maxHunger;
        delete data.rooms[roomName].features.states.menuWait[targetUid];
        safeSaveData(data, true);
        
        replier.reply(formatCommand("🏃 무사 귀환", user, "무사히 던전을 빠져나왔습니다.\n(체력과 허기가 회복되었습니다.)\n\n💰 탐험 획득 금화: +" + earnedGold + " G"));
    } else {
        replier.reply(formatError(user, "명령 거부", "현재는 1번, 2번, 5번만 선택 가능합니다."));
    }
}

function _handlePlayerDeath(user, data, replier, roomName, targetUid) {
    // [데스 페널티 엔진]
    var s = user.dgnStat;
    var d = user.dgnState;
    
    // 1. 현재 탐험 중 얻은 전리품 전량 증발
    d.loots = { points: 0, items: [] };

    // 2. 가방(dgnBag)에 있던 기존 아이템 절반 소실 로직
    if (user.dgnBag.length > 0) {
        var loseCount = Math.ceil(user.dgnBag.length / 2);
        user.dgnBag.splice(0, loseCount);
    }

    // 부활 처리 (마을 귀환)
    s.hp = Math.floor(s.maxHp * 0.1); // 체력 10%로 부활
    s.hunger = 30; // 빈사 상태의 허기
    
    user.dgnState = null;
    delete data.rooms[roomName].features.states.menuWait[targetUid];
    safeSaveData(data, true);

    var deathMsg = "💀 [사망: 심연에 먹히다]\n━━━━━━━━━━━━━━━\n" +
                   "체력을 모두 소진하여 쓰러졌습니다...\n" +
                   "길드 구조대에 의해 마을로 실려 왔습니다.\n\n" +
                   "⚠️ [페널티 발생]\n" +
                   "• 이번 탐험에서 얻은 전리품 100% 유실\n" +
                   "• 가방에 보관 중이던 기존 아이템 50% 유실\n\n" +
                   "💡 길드 창고에 귀중품을 보관하는 습관을 들이세요.";
                   
    replier.reply(formatCommand("🪦 탐험 실패", user, deathMsg));
}

function _showDgnCombatMain(user, replier, extraMsg) {
    var c = user.dgnState.combat;
    var s = user.dgnStat;
    
    // 몬스터 아이콘 판별 (보스/엘리트면 왕관, 일반이면 칼)
    var mIcon = (c.mob.type === "boss" || c.mob.type === "elite") ? "👑" : "🗡️";

    var body = (extraMsg ? extraMsg + "\n\n" : "") +
               mIcon + " [" + c.mob.name + "] (HP: " + c.mob.hp + ")\n" +
               "👤 내 체력: " + s.hp + " / " + s.maxHp + " | ST: " + s.stam + "\n" +
               "━━━━━━━━━━━━━━━\n" +
               "어떻게 대처하시겠습니까?\n" +
               "1. ⚔️ 공격 (방향 선택)\n" +
               "2. 🛡️ 방어 (방향 선택)\n" +
               "3. ✨ 스킬 (ST 소모, 방향 선택)\n" +
               "4. 🧪 포션 (가방 사용)\n" +
               "5. 🏃 도망가기 (확률 낮음)\n\n" +
               "입력: [번호]";

    replier.reply(formatCommand("⚔️ 전투 진행 중 (턴 " + c.turn + ")", user, body));
}

function _processDgnCombatMain(choice, user, data, replier, roomName, targetUid) {
    var c = user.dgnState.combat;
    var s = user.dgnStat;

    if (c.mob.name.indexOf("맹독 슬라임") !== -1 && Math.random() < 0.3 && !c.ailment) {
        c.ailment = "poison";
        replier.reply("☠️ 슬라임의 점액에 닿아 [맹독] 상태에 빠졌습니다! (매턴 체력 감소)");
    }

    if (choice === "1" || choice === "3") {
        if (choice === "3" && s.stam < 15) {
            return replier.reply(formatError(user, "스태미나 부족", "스킬을 사용할 수 없습니다."));
        }
        c.nextAction = choice === "1" ? "atk" : "skill";
        data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_combat_dir', time: Date.now(), originRoom: roomName };
        return replier.reply(formatCommand("⚔️ 전투 - 타격 부위 선택", user, "어느 방향을 노리시겠습니까?\n\n1. 상단\n2. 하단\n3. 좌측\n4. 우측\n\n입력: [번호]"));
    } 
    else if (choice === "2") {
        c.nextAction = "def";
        data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_combat_dir', time: Date.now(), originRoom: roomName };
        return replier.reply(formatCommand("🛡️ 전투 - 방어 위치 선택", user, "어느 방향을 방어하시겠습니까?\n\n1. 상단\n2. 하단\n3. 좌측\n4. 우측\n\n입력: [번호]"));
    }
    else if (choice === "4") {
        var potionIdx = -1;
        for (var i = 0; i < user.dgnBag.length; i++) {
            if (user.dgnBag[i].name.indexOf("체력 포션") !== -1) { potionIdx = i; break; }
        }
        if (potionIdx !== -1) {
            var pName = user.dgnBag[potionIdx].name;
            var healAmt = DGN_ITEM_DB[pName].stat.hp;
            s.hp = Math.min(s.maxHp, s.hp + healAmt);
            user.dgnBag.splice(potionIdx, 1);
            _resolveCombatTurn(user, data, replier, roomName, targetUid, "🧪 [" + pName + "] 사용! 체력을 " + healAmt + " 회복했습니다.\n", false, 0);
        } else {
            return replier.reply(formatError(user, "아이템 없음", "가방에 체력 포션이 없습니다."));
        }
    }
    else if (choice === "5") {
        var runProb = (c.mob.type === "boss") ? (s.agi) : (s.agi * 2);
        if (Math.random() * 100 < runProb) { 
            user.dgnState.combat = null;
            user.dgnState.log = "🏃 구사일생으로 몬스터에게서 도망쳤습니다.";
            data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_turn', time: Date.now(), originRoom: roomName };
            safeSaveData(data, false);
            return _showDungeonTurn(user, replier);
        } else {
            _resolveCombatTurn(user, data, replier, roomName, targetUid, "🏃 도망에 실패했습니다!\n", false, 0);
        }
    } else {
        replier.reply(formatError(user, "명령 거부", "1~5 사이의 번호를 입력해주세요."));
    }
}

function _processDgnCombatDir(choice, user, data, replier, roomName, targetUid) {
    var pDir = parseInt(choice);
    if (isNaN(pDir) || pDir < 1 || pDir > 4) return replier.reply(formatError(user, "방향 오류", "1~4번 중 하나를 선택하세요."));

    var c = user.dgnState.combat;
    var isDefending = (c.nextAction === "def");

    _resolveCombatTurn(user, data, replier, roomName, targetUid, "", isDefending, pDir);
}

function _resolveCombatTurn(user, data, replier, roomName, targetUid, prevLog, isDefending, pDir) {
    var c = user.dgnState.combat;
    var s = user.dgnStat;
    var logMsg = prevLog + ""; 

    var calcDmg = function(base) {
        var variance = base * 0.1;
        var finalDmg = base - variance + (Math.random() * variance * 2);
        var isCrit = Math.random() < 0.2;
        if (isCrit) finalDmg *= 1.5;
        return { dmg: Math.max(1, Math.floor(finalDmg)), crit: isCrit };
    };

    // 몬스터 3턴 행동 패턴 엔진 (공격 1회, 방어 2회 랜덤 배치)
    if (!c.mobPattern || c.mobPattern.length === 0) {
        c.mobPattern = ["atk", "def", "def"];
        c.mobPattern.sort(function() { return Math.random() - 0.5; });
    }
    var curMobAct = c.mobPattern.shift(); // "atk" 또는 "def" 추출
    var mDir = Math.floor(Math.random() * 4) + 1; // 몬스터가 선택한 무작위 방향
    var opposites = { 1:2, 2:1, 3:4, 4:3 }; 

    // 1. 플레이어 공격 페이즈 (포션/도망 등 pDir이 0이 아닐 때만 실행)
    if (pDir > 0 && !isDefending) {
        var pBaseAtk = s.str * 10; 
        if (c.nextAction === "skill") {
            s.stam -= 15;
            pBaseAtk = pBaseAtk * 1.5 + (s.int * 5);
        }
        var pAtkRes = calcDmg(pBaseAtk);
        var pAtk = pAtkRes.dmg;
        var cStr = pAtkRes.crit ? " ⚡[기본치명타!]" : "";

        logMsg += "당신은 " + _getDirStr(pDir) + "을(를) 향해 " + (c.nextAction === "skill" ? "스킬을 " : "") + "공격했습니다!\n";

        if (curMobAct === "def") {
            logMsg += "적은 " + _getDirStr(mDir) + "을(를) 방어했습니다.\n";
            if (pDir === mDir) {
                pAtk = Math.floor(pAtk * 0.1);
                logMsg += "🛡️ 적이 공격을 막아냈습니다! (" + pAtk + " 데미지)\n";
            } else if (pDir === opposites[mDir]) {
                pAtk = Math.floor(pAtk * 1.5);
                logMsg += "💥 방어의 허점을 완벽히 찔렀습니다! (" + pAtk + " 데미지)" + cStr + " 🎯[약점공격!]\n";
            } else {
                logMsg += "💥 유효타를 입혔습니다! (" + pAtk + " 데미지)" + cStr + "\n";
            }
        } else {
            // 적이 이번 턴에 공격을 선택해 방어를 하지 않았을 때
            logMsg += "적이 방어하지 않아 공격이 온전히 들어갔습니다!\n";
            logMsg += "💥 (" + pAtk + " 데미지)" + cStr + "\n";
        }
        c.mob.hp -= pAtk;
    } else if (pDir > 0 && isDefending) {
        logMsg += "당신은 " + _getDirStr(pDir) + " 방향을 철저히 방어합니다.\n";
    }

    if (c.mob.hp <= 0) {
        if (user.dgnGuild.quest && user.dgnGuild.quest.type === "hunt" && user.dgnGuild.quest.targetMob === c.mob.name) {
            user.dgnGuild.quest.current++;
        }
        return _winDgnCombat(user, data, replier, roomName, targetUid, logMsg);
    }

    // 2. 몬스터 반격 페이즈
    if (curMobAct === "atk") {
        logMsg += "적이 " + _getDirStr(mDir) + "(으)로 반격했습니다!\n";
        var bBase = c.mob.atk;
        if (c.mob.type === "boss" && c.mob.hp < (c.mob.maxHp || 600) * 0.3) {
            bBase = Math.floor(bBase * 1.5); 
        }
        var mAtkRes = calcDmg(bBase);
        var mAtk = mAtkRes.dmg;
        var cStr2 = mAtkRes.crit ? " ⚡[치명타!]" : "";

        if (isDefending && pDir === mDir) {
            mAtk = Math.floor(mAtk * 0.1);
            logMsg += "🛡️ 정확히 막아냈습니다! 피해를 최소화합니다. (" + mAtk + " 피해)\n";
        } else {
            var pDef = Math.floor(s.str * 0.5);
            var taken = Math.max(1, mAtk - pDef);
            logMsg += "🩸 타격을 입습니다! (" + taken + " 피해)" + cStr2 + "\n";
            s.hp -= taken;
        }
    } else {
        if (isDefending || pDir === 0) {
            logMsg += "적은 이번 턴에 공격하지 않았습니다.\n";
        }
    }

    if (c.ailment === "poison") {
        var poisonDmg = Math.floor(s.maxHp * 0.05);
        s.hp -= poisonDmg;
        logMsg += "🟢 [맹독] 독이 퍼져 체력이 깎입니다. (-" + poisonDmg + " HP)\n";
    }

    if (s.hp <= 0) return _handlePlayerDeath(user, data, replier, roomName, targetUid);

    c.turn++;
    data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_combat_main', time: Date.now(), originRoom: roomName };
    safeSaveData(data, false);
    _showDgnCombatMain(user, replier, logMsg);
}

/* 헬퍼 함수: 방향 문자열 반환 */
function _getDirStr(num) {
    var dirs = {1:"상단", 2:"하단", 3:"좌측", 4:"우측"};
    return dirs[num] || "알수없음";
}

/* 전투 승리 통합 처리 */
function _winDgnCombat(user, data, replier, roomName, targetUid, combatLog) {
    var c = user.dgnState.combat;
    var d = user.dgnState;
    
    var gold = Math.floor(Math.random() * (c.mob.gold[1] - c.mob.gold[0])) + c.mob.gold[0];
    d.loots.points += gold;

    var logMsg = combatLog + "\n🎉 [" + c.mob.name + "] 토벌 성공!\n💰 획득 금화: +" + gold + " G\n";
    
    // [무한의 탑 드랍 스케일링] 20층을 돌파할 때마다 드랍 기회(주사위)가 1번씩 늘어남
    var dropChances = 1 + Math.floor((d.depth - 1) / 20);
    
    for (var i = 0; i < dropChances; i++) {
        if (c.mob.drop && Math.random() < 0.6) { 
            var dropInfo = DGN_ITEM_DB[c.mob.drop];
            var itemColor = (dropInfo && dropInfo.rank === "희귀") ? "🔵" : "⚪";
            d.loots.items.push(c.mob.drop);
            
            if (user.dgnBag.length < SYSTEM_CONFIG.DUNGEON.MAX_BAG_SLOTS) {
                user.dgnBag.push({ name: c.mob.drop, type: dropInfo.type, rank: dropInfo.rank });
                logMsg += "🎁 전리품 획득: " + itemColor + "[" + c.mob.drop + "]\n";
            } else {
                logMsg += "⚠️ 전리품(" + c.mob.drop + ")을 발견했으나 가방이 가득 차 버렸습니다.\n";
            }
        }
    }

    d.combat = null;
    d.log = logMsg;
    
    user.skipHealing = true;
    data.rooms[roomName].features.states.menuWait[targetUid] = { type: 'dgn_turn', time: Date.now(), originRoom: roomName };
    safeSaveData(data, false);
    _showDungeonTurn(user, replier);
}

/* -----------------------------------------
   [던전] 길드 지부 (창고 시스템)
----------------------------------------- */
function _showDgnGuildMain(user, replier, roomData, targetUid, roomName) {
    if (!user.dgnStorage) user.dgnStorage = []; // 창고 초기화 가드
    var body = "🛡️ [탐험가 길드 지부]\n\n" +
               "\"오셨군요. 귀중품은 창고에 맡기고 출발하십시오.\"\n\n" +
               "1. 📦 길드 창고 (보관/찾기)\n" +
               "2. 📜 의뢰 게시판 (토벌/수집)\n\n" +
               "↩️ 뒤로 / ❎취소";
    replier.reply(formatCommand("🛡️ 길드 메인", user, body, "번호를 선택하세요."));
    roomData.features.states.menuWait[targetUid] = { type: 'dgn_guild_main', time: Date.now(), originRoom: roomName };
}

function _showDgnStorage(user, replier, roomData, targetUid, roomName) {
    var bag = user.dgnBag || [];
    var strg = user.dgnStorage || [];
    var maxBag = SYSTEM_CONFIG.DUNGEON.MAX_BAG_SLOTS;
    var maxStrg = 50; // 기본 창고 50칸

    var body = "📦 [길드 창고 현황]\n" +
               "🎒 내 가방: " + bag.length + "/" + maxBag + "칸\n" +
               "🗃️ 창고: " + strg.length + "/" + maxStrg + "칸\n\n" +
               "[가방 아이템]\n";
    
    var idx = 1;
    if (bag.length === 0) body += "- 없음 -\n";
    bag.forEach(function(it) { body += (idx++) + ". " + it.name + "\n"; });
    
    body += "\n[창고 아이템]\n";
    if (strg.length === 0) body += "- 없음 -\n";
    strg.forEach(function(it) { body += (idx++) + ". " + it.name + "\n"; });

    body += "\n💬 보관하려면 가방 번호를, 찾으려면 창고 번호를 입력하세요.\n↩️ 뒤로 / ❎취소";
    replier.reply(formatCommand("📦 길드 창고", user, body, "아이템 번호를 입력하세요."));
    roomData.features.states.menuWait[targetUid] = { type: 'dgn_guild_storage', time: Date.now(), originRoom: roomName };
}

function _processDgnStorage(choice, user, data, replier, roomName, targetUid) {
    var idx = parseInt(choice) - 1;
    var bag = user.dgnBag;
    var strg = user.dgnStorage;
    var maxBag = SYSTEM_CONFIG.DUNGEON.MAX_BAG_SLOTS;
    var maxStrg = 50;

    if (isNaN(idx) || idx < 0 || idx >= (bag.length + strg.length)) {
        return replier.reply(formatError(user, "번호 오류", "정확한 아이템 번호를 입력하세요."));
    }

    if (idx < bag.length) {
        // 보관 (가방 -> 창고)
        if (strg.length >= maxStrg) return replier.reply(formatError(user, "공간 부족", "창고가 가득 찼습니다."));
        var it = bag.splice(idx, 1)[0];
        strg.push(it);
        replier.reply(formatCommand("보관 완료", user, "[" + it.name + "]을(를) 창고에 보관했습니다."));
    } else {
        // 찾기 (창고 -> 가방)
        if (bag.length >= maxBag) return replier.reply(formatError(user, "공간 부족", "가방이 가득 찼습니다."));
        var sIdx = idx - bag.length;
        var it = strg.splice(sIdx, 1)[0];
        bag.push(it);
        replier.reply(formatCommand("인출 완료", user, "[" + it.name + "]을(를) 가방으로 꺼냈습니다."));
    }
    user.skipHealing = true;
    safeSaveData(data, false);
    _showDgnStorage(user, replier, data.rooms[roomName], targetUid, roomName);
}

