                if (uid.indexOf("AI_") === 0) continue; // AI는 이미 포함됨
                var tu = mainRoomData.users[uid];
                
                // 최근 1일 내 접속 & 무역을 1회 이상 해본 실유저 카운트
                var lastLogTs = new Date(tu.lastDate || 0).getTime() || 0;
                if ((tu.tradeCount || 0) > 0 && (nowTs - lastLogTs < 1 * 86400000)) {
                    activeTraders++;
                }
            }

            // 25명 기준(AI 20 + 유저 5)일 때의 완벽한 밸런스를 1인당 계수로 분해하여 자동 스케일업
            var dynBaseline = activeTraders * 800;        // 1인당 800 (25명 = 20000 기준점)
            var dynProd = activeTraders * 24;             // 1인당 24 (25명 = 600 생산)
            var dynSynergyCap = activeTraders * 48;       // 1인당 48 (25명 = 1200 시너지 상한)
            var dynConsumpMin = activeTraders * 4;        // 1인당 4 (25명 = 최소 소비 100)
            var dynConsumpRange = activeTraders * 8 + 1;  // 1인당 8 (25명 = 추가 소비 폭 200)

            // 실시간 시세 갱신 엔진(Sector 11)이 이 값을 참조하도록 저장
            mainRoomData.features.tradeMarket.currentBaseline = dynBaseline;

            // 순환 매칭을 위한 표준 배열 정의 (생산품 기준)
            var nations = ["포르투", "코콜라", "나폴리", "베라크루스", "킴벌리"];
            var goods = ["식료품", "공업품", "공예품", "귀금속", "보석"];
            
            // 20분마다 1개의 항구를 무작위로 선정하여 특산품 대유행(Boom) 상태 부여
            var boomNation = nations[Math.floor(Math.random() * nations.length)];

            for (var i = 0; i < nations.length; i++) {
                var nName = nations[i];
                var rates = {}; 
                
                // 기존 방 데이터 안전 연동 가드
                var pData = mainRoomData.features.portData[nName];
                if (pData && !pData.inventory) {
                    pData.inventory = {"식료품":dynBaseline/2, "공업품":dynBaseline/2, "공예품":dynBaseline/2, "귀금속":dynBaseline/2, "보석":dynBaseline/2};
                }
                
                // 유행 상태 갱신 (선정된 항구만 true, 나머지는 false)
                if (pData) pData.specialtyBoom = (nName === boomNation);
                
                var inv = pData ? pData.inventory : {"식료품":dynBaseline/2, "공업품":dynBaseline/2, "공예품":dynBaseline/2, "귀금속":dynBaseline/2, "보석":dynBaseline/2};

                for (var j = 0; j < goods.length; j++) {
                    var gName = goods[j];
                    
                    var currentStock = Number(inv[gName] || dynBaseline/2);

                    // 1. 도시의 기본 생산 및 자연 소비 (동적 스케일링 변수 적용)
                    if (TRADE_RELATION[nName].produce === gName) {
                        var synergyBonus = 0;
                        if (pData.synergyStack > 0) {
                            synergyBonus = Math.min(dynSynergyCap, Math.floor(pData.synergyStack * 0.5));
                            pData.synergyStack = 0; 
                        }
                        currentStock += (dynProd + synergyBonus);
                    } else {
                        // 타국 물품 자연 소비량 자동 조절
                        currentStock -= (Math.floor(Math.random() * dynConsumpRange) + dynConsumpMin); 
                    }

                    // 재고 회복력(Elasticity): 동적 Baseline으로 회귀 (7% 유지)
                    currentStock = currentStock + (dynBaseline - currentStock) * 0.07; 

                    // 최종 재고 저장 범위 조정 (10% ~ 400% 자동 연동)
                    var minInv = Math.floor(dynBaseline * 0.10);
                    var maxInv = Math.floor(dynBaseline * 4.0);
                    inv[gName] = Math.max(minInv, Math.min(maxInv, currentStock));

                    // 3. 시장 노이즈 반영 (85% ~ 115%)
                    var baseRate = 0.85 + (Math.random() * 0.30); 
                    if (TRADE_RELATION[nName].produce === gName) {
                        baseRate -= (Math.random() * 0.05 + 0.05); 
                    }

                    // 4. 실물 재고 비례 계수 적용 (가중치 0.9)
                    var scarcityMult = 1 + ((dynBaseline - inv[gName]) / dynBaseline) * 0.9;
                    scarcityMult = Math.max(0.6, Math.min(1.6, scarcityMult)); 
                    
                    var finalRate = baseRate * scarcityMult;

                    // 5. 최종 시세 상/하한선 제한 (70% ~ 130%)
                    finalRate = Math.max(0.70, Math.min(1.30, finalRate));

                    // 누락되었던 괄호 복구 및 rates 배열 저장
                    rates[gName] = Number(finalRate.toFixed(2));
                }

                // 기존 favorite/hate 구조 대신 rates 객체를 저장
                mainRoomData.features.tradeMarket[nName] = {
                    rates: rates, 
                    specialty: tradeCfg.NATIONS[nName].specialty
                };
            }

            var pData = mainRoomData.features.portData || {};
            var goodsIcons = { "식료품":"🍎", "공업품":"⚙️", "공예품":"🏺", "귀금속":"🪙", "보석":"💎" };
            var goodsOrder = ["식료품", "공업품", "공예품", "귀금속", "보석"];
            
            var noticeLines = [];
            for (var i = 0; i < nations.length; i++) {
                var n = nations[i];
                var nInfo = mainRoomData.features.tradeMarket[n];
                var pInfo = pData[n] || { level: 1, governorUid: "" };

                // 1. [상태 판별 로직] 가독성을 위해 짧은 키워드로 조립
                var portStatusTag = "";
                var producedGood = TRADE_RELATION[n].produce;
                var currentRate = (nInfo.rates && nInfo.rates[producedGood]) ? nInfo.rates[producedGood] : 1.0;

                if (pInfo.synergyStack > 0) portStatusTag += " ✨공정가속";
                else if (currentRate <= 0.80) portStatusTag += " 📉공급과잉";
                else if (currentRate >= 1.20) portStatusTag += " 🔥공급부족";

                // 특산품 대유행 태그 추가 (기존 태그 옆에 이어서 붙음)
                if (pInfo.specialtyBoom) portStatusTag += " 🎊특산품유행";

        var govName = "공석";
                if (pInfo.governorUid && mainRoomData.users[pInfo.governorUid]) {
                    govName = "👑" + mainRoomData.users[pInfo.governorUid].name;
                }

                var rateLine = "";
                goodsOrder.forEach(function(gKey) {
                    var rate = (nInfo.rates && nInfo.rates[gKey]) ? nInfo.rates[gKey] : 1.0;
                    var pct = Math.round(rate * 100);
                    // 자국 생산품(producedGood)이면서 시세가 낮을 때 강조 아이콘 표시
                    var deco = (gKey === producedGood && rate <= 0.85) ? "✅" : goodsIcons[gKey];
                    rateLine += deco + pct + "% ";
                });

                noticeLines.push("📍 " + (i + 1) + ". " + n + " [Lv." + pInfo.level + "]\n" +
                                 rateLine.trim() + "\n" +
                                 "(👤 총독: " + govName + ")");
            }

            var tradeNotice = "🌍 세계 무역 시세표 (갱신: 20분)\n" +
                              "━━━━━━━━━━━━━━━\n" +
                              noticeLines.join("\n\n") + "\n" +
                              "━━━━━━━━━━━━━━━\n" +
                              "💡 ✅아이콘은 해당 항구의 특화 매입 품목입니다.";
            
            var investCfg = tradeCfg.INVEST;
            if (currentHour >= investCfg.OPEN_HOUR && currentHour <= investCfg.CLOSE_HOUR) {
                Api.replyRoom(ctx.targetRoom, tradeNotice);
                util_stamp("tradeMarketLogic");
            } else {
                Log.info("[Trade] 야간 항만 폐쇄로 인해 시세 알림 발송을 생략합니다.");
            }
            ctx.isUpdated = true;
            util_stamp("tradeMarketLogic");
        }
    } catch (e) { Log.error("Trade Market Update Error: " + e); }

    /* [1. 사채 및 경제 감시 엔진] (보존 구역) */
    // 설명: 국가 부도, 사채 이자, 강제 추심 등 시스템 안정성을 위한 핵심 로직입니다.
    try {
        for (var rName in data.rooms) {
            if (ALLOWED_ROOMS.indexOf(rName) === -1) continue;
            var roomData = data.rooms[rName];
            if (!roomData.loanContracts) roomData.loanContracts = {};

            if (roomData.bankReserve !== undefined) {
                var reserve = roomData.bankReserve;
                if (!roomData.lastBankAlert) roomData.lastBankAlert = "normal";

                var roomBase = roomData.economyBase || 3500000;
                var dangerLimit = Math.floor(roomBase * 0.3);
                var disasterLimit = Math.floor(roomBase * 0.1);
                var normalLimit = Math.floor(roomBase * 0.5);

                if (reserve < disasterLimit && roomData.lastBankAlert !== "disaster") {
                    roomData.lastBankAlert = "disaster";
                    var disasterMsg = "🚨 [국가 부도 선포] 🚨\n━━━━━━━━━━━━━━━\n중앙은행의 국고가 바닥났습니다(10% 미만).\n\n🚫 동결: 펀드 투자 등 모든 경제 활동이 전면 금지됩니다.\n🏥 제한: 각종 복지 및 지원금이 삭감되거나 제한됩니다.\n\n⚠️ 해제 조건: 국고가 기준점의 50%(" + fp(normalLimit) + "P) 이상 충전되어야 합니다.";
                    Api.replyRoom(rName, disasterMsg);
                    ctx.isUpdated = true;
                }
                else if (reserve < dangerLimit && reserve >= disasterLimit && roomData.lastBankAlert === "normal") {
                    roomData.lastBankAlert = "warning";
                    var warningMsg = "⚠️ [국가 부도 위험 알림]\n━━━━━━━━━━━━━━━\n중앙은행 재원이 위험 수준(30% 미만)에 도달했습니다.\n\n🏦 현재 금고: " + fp(reserve) + "P\n💡 지속적인 국고 유출 시 부도가 선포되어 모든 경제 활동이 동결될 수 있습니다.";
                    Api.replyRoom(rName, warningMsg);
                    ctx.isUpdated = true;
                }
                else if (reserve >= normalLimit && (roomData.lastBankAlert === "warning" || roomData.lastBankAlert === "disaster")) {
                    roomData.lastBankAlert = "normal";
                    var normalMsg = "✅ [국가 부도 해제]\n━━━━━━━━━━━━━━━\n국고가 안정권(50% 이상)으로 복구되어 모든 경제 활동이 정상화되었습니다.\n\n🔓 해제: 펀드 및 투자 시스템 재가동\n💰 복지: 모든 보상이 정상 지급으로 전환됩니다.";
                    Api.replyRoom(rName, normalMsg);
                    ctx.isUpdated = true;
                }
            }

            var loanCfg = SYSTEM_CONFIG.ECO.PRIVATE_LOAN;
            var intPeriodMs = (loanCfg.INTEREST_PERIOD || 3) * 60 * 60 * 1000;
            var overdueLimit = (loanCfg.COLLECTION_LIMIT || 24) * 60 * 60 * 1000;

            for (var cid in roomData.loanContracts) {
                var c = roomData.loanContracts[cid];
                var periodsPassed = Math.floor((nowTs - c.startTime) / intPeriodMs); 
                
                if (c.appliedPeriods === undefined) c.appliedPeriods = 0;
                
                if (periodsPassed > c.appliedPeriods) {
                    var pendingPeriods = periodsPassed - c.appliedPeriods;
                    var totalNewInterest = 0;
                    for (var i = 0; i < pendingPeriods; i++) {
                        var currentDebt = Number(c.currentDebt || 0);
                        var interest = Math.floor(currentDebt * (Number(c.rate) / 100));
                        c.currentDebt = currentDebt + interest;
                        totalNewInterest += interest;
                    }
                    c.appliedPeriods = periodsPassed;
                    ctx.isUpdated = true;
                    
                    try {
                        var interestMsg = "🚬 [사채 이자 갱신]\n━━━━━━━━━━━━━━━\n👤 대상: " + c.borrowerName + "님\n🤝 채권자: " + c.lenderName + "\n🕒 경과: " + (periodsPassed * (loanCfg.INTEREST_PERIOD || 3)) + "시간\n💰 추가 이자: +" + fp(totalNewInterest) + "P\n📉 현재 채무: " + fp(c.currentDebt) + "P\n━━━━━━━━━━━━━━━";
                        Api.replyRoom(rName, interestMsg);
                    } catch(e) {}
                }

                var duration = nowTs - c.startTime;
                var bankTakeoverLimit = overdueLimit + (12 * 60 * 60 * 1000); // 연체 후 12시간 뒤 대납

                if (c.status === 'active' && duration > overdueLimit && duration <= bankTakeoverLimit) {
                    c.status = 'overdue'; ctx.isUpdated = true;
                    try { Api.replyRoom(rName, "🚨 [강제 추심 집행 알림]\n대상: " + c.borrowerName + "님\n사유: 상환 기한(" + (loanCfg.COLLECTION_LIMIT || 24) + "시간) 초과\n\n지금부터 수익의 50%가 채권자에게 자동 귀속됩니다."); } catch(e){}
                }
                else if (duration > bankTakeoverLimit) {
                    var amountToPay = Number(c.currentDebt);
                    var lender = roomData.users[c.lenderUid];
                    var borrower = roomData.users[c.borrowerUid];

                    if (lender && borrower) {
                        util_updatePoint(lender, roomData, amountToPay, "사채 은행 대납 회수 (" + c.borrowerName + ")", rName);
                        if (!borrower.loan) borrower.loan = { debt: 0, items: [] };
                        borrower.loan.debt = Number(borrower.loan.debt) + amountToPay;
                        borrower.loan.items.push(amountToPay);
                        borrower.isTransferred = true; 
                        borrower.creditScore = Math.max(0, (borrower.creditScore || 600) - 120);
                        checkAndHandleDefaulter(borrower, rName);
                        
                        var takeoverMsg = "🏛️ [중앙은행 대환 집행]\n━━━━━━━━━━━━━━━\n👤 대상: " + c.borrowerName + "님\n내용: 사채 연체 36시간 경과로 은행이 대납 처리하였습니다.\n\n⚠️ [페널티]: 신용점수 -120점 강등\n⚠️ 해당 채무는 [은행 대환 대출]로 전환되었으며, 모든 수익의 70%가 강제 상환됩니다.\n━━━━━━━━━━━━━━━";
                        Api.replyRoom(rName, takeoverMsg);
                        delete roomData.loanContracts[cid];
                        ctx.isUpdated = true;
                    }
                }
            }
        }
    } catch (e) { Log.error("Loan/Bank Logic Error: " + e); }
}
// 엔진 가동
runScheduler();

//==========섹터17==========

/**
 * 섹터 17 로직 함수: 부동산 시장 마감, 일일 데이터 초기화 및 시즌 리셋 관리
 * [v11.0] Landmark & Property Tax System
 */
function _runSector17Logic(data, ctx) {
    var currentHour = ctx.now.getHours();
    var currentMin = ctx.now.getMinutes();

    if (data.lastDailyReset === ctx.today) return;
    
    // [보안] 로직 시작 즉시 날짜 갱신하여 1초 내 중복 실행 방지
    data.lastDailyReset = ctx.today;
    Log.info("📅 [System] " + ctx.today + " 일일 데이터 초기화 및 경제 정산을 시작합니다.");

    // [1] 자동 물가 기준점 보정 시스템 및 하이프 카운트 초기화
    for (var rName in data.rooms) {
        var rObj = data.rooms[rName];
        var eco = calculateEconomy(data, rName);

        // 00시 기준 유저 평균 순자산 확정 (내일 대출 한도의 기준이 됨)
        if (rObj.features && rObj.features.government) {
            rObj.features.government.dailyAvgAsset = eco.average;
            Log.info("[" + rName + "] 내일자 대출 유동 한도 기준점 설정: " + fp(eco.average) + "P");
        }
        
        if (eco.total > 0) {
            var oldBase = rObj.economyBase || eco.total;
            var currentBase = rObj.economyBase || 1;
            var rawRatio = eco.total / currentBase;
            
            if (eco.total > oldBase) {
                var weight = 0.6;
                rObj.economyBase = Math.floor((oldBase * (1 - weight)) + (eco.total * weight));
            } else {
                rObj.economyBase = Math.floor(Math.sqrt(oldBase * eco.total));
            }
            Log.info("[" + rName + "] 경제 기준점 자동 조정 완료: " + fp(rObj.economyBase) + "P");
        }

        // 하이프 카운트(채팅량) 초기화
        if (rObj.features) rObj.features.msgCount = 0;
    }

    // [3] 모든 방 유저 스탯 초기화 (지능형 금리 엔진 적용)
    for (var rName in data.rooms) {
        var roomObj = data.rooms[rName];
        if (!roomObj.features) continue;

        var dynMult = 1.0;
        if (typeof util_getDynamicRateMultiplier === 'function') {
            dynMult = util_getDynamicRateMultiplier(rName);
        }

        for (var id in roomObj.users) {
            var u = roomObj.users[id];

            u.dailyLoanCount = 0; 
            u.dailyStimulusCount = 0; 
            u.dailyCreditRestoreCount = 0; 
            
            // [보안강화] 시간 비례 적립 이자 정산 (0시 정각)
            var now = Date.now();
            if (u.lastBankUpdateTime > 0 && Number(u.bank) > 0) {
                var timePassed = now - u.lastBankUpdateTime;
                var dayMs = 24 * 60 * 60 * 1000;
                var lastMinuteEarned = Number(u.bank) * SYSTEM_CONFIG.ECO.BANK.INTEREST_RATE * (timePassed / dayMs);
                u.accruedInterest = (u.accruedInterest || 0) + lastMinuteEarned;
            }

            var emergencyMult = util_getEmergencyMultiplier(rName);
            var wealthBonus = (u.title === "자산왕") ? 1.5 : 1.0;
            var finalInterest = Math.floor((u.accruedInterest || 0) * emergencyMult * wealthBonus);

            if (finalInterest > 0) {
                if (util_isBankSolvent(rName, finalInterest)) {
                    util_updateBank(u, roomObj, finalInterest, "은행 예금 이자 지급", rName);
                    util_updateReserve(roomObj, -finalInterest, "은행 예금 이자 지급", rName);

                    if (roomObj.features.dailyPools) {
                        var accumRate = SYSTEM_CONFIG.ECO.ACTIVITY_ACCUM_RATES.BANK || 0.05;
                        roomObj.features.dailyPools.bank += Math.floor(finalInterest * accumRate);
                    }
                    u.accruedInterest = 0; 
                } else {
                    Log.info("[Bank Default] " + u.name + "님 국고 고갈로 이자 지급 보류 및 이월");
                }
            }

            u.lastBankUpdateTime = now;
            
            // 대출 이자 가산
            if (u.loan && Number(u.loan.debt) > 0) { 
                u.creditScore = Math.max(0, Number(u.creditScore) - 5); 
                var cr = getCreditInfo(u.creditScore);
                var dailyRate = (cr.rate - 1) * dynMult;
                var dailyInterest = Math.floor(Number(u.loan.debt) * dailyRate);
                
                var preDebt = Number(u.loan.debt);
                var expectedDebt = preDebt + dailyInterest;
                u.loan.debt = expectedDebt;
                
