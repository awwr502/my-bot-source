            tUser.unknownCargo = (Number(tUser.unknownCargo) || 0) + count;
            matchedItem = "미확인 교역품";
            isSpec = true;
        }
        else {
            // 2. 동적 특산품 자동 판별
            for (var n in TRADE_RELATION) { 
                if (TRADE_RELATION[n].set.replace(/\s/g,"") === cleanI || itemName.indexOf(TRADE_RELATION[n].set) !== -1) { 
                    isSpec = true; 
                    matchedItem = TRADE_RELATION[n].set;
                    break; 
                } 
            }

            if (isSpec) {
                if (!tUser.specialties) tUser.specialties = {};
                tUser.specialties[matchedItem] = (Number(tUser.specialties[matchedItem]) || 0) + count;
            } else {
                // 3. 동적 일반 화물 판별 (시스템 설정 스캔)
                var tradeGoods = Object.keys(SYSTEM_CONFIG.TRADE.GOODS_COST);
                if (tradeGoods.indexOf("밀수품") === -1) tradeGoods.push("밀수품");
                
                var isValidCargo = false;
                for (var i = 0; i < tradeGoods.length; i++) {
                    if (itemName.indexOf(tradeGoods[i]) !== -1 || cleanI.indexOf(tradeGoods[i].replace(/\s/g,"")) !== -1) {
                        isValidCargo = true;
                        matchedItem = tradeGoods[i];
                        break;
                    }
                }

                if (!isValidCargo) matchedItem = itemName; // 목록에 없어도 관리자 강제 주입 허용

                if (!tUser.cargo) tUser.cargo = {};
                if (!tUser.cargoAvg) tUser.cargoAvg = {};
                var oldQty = Number(tUser.cargo[matchedItem] || 0);
                var oldAvg = Number(tUser.cargoAvg[matchedItem] || 0);
                var basePrice = SYSTEM_CONFIG.TRADE.GOODS_COST[matchedItem] || 10000;
                if (matchedItem === "밀수품") basePrice = 10000;

                tUser.cargo[matchedItem] = oldQty + count;
                tUser.cargoAvg[matchedItem] = Math.floor(((oldAvg * oldQty) + (basePrice * count)) / (oldQty + count));
            }
        }
        
        tUser.skipHealing = true;
        safeSaveData(data, true);
        replier.reply(formatAdmin("📦 선박 화물 강제 복구", "대상: " + tUser.name + "\n품목: " + (isSpec ? "[특수] " : "[일반] ") + matchedItem + "\n수량: " + count + "개 선적 완료"));
        return true;
    }

/* 무역 시간 강제 가속 명령어 */
    if (msg.indexOf("/무역즉시완료 ") === 0) {
        var tn = msg.substring(8).trim();
        var found = findUserGlobal(tn, roomName);

        if (found.length === 0) return replier.reply(formatAdmin("🚫 대상 없음", "[" + tn + "] 유저를 찾을 수 없습니다."));
        if (found.length > 1) {
            handleUserSelection(replier, targetUid, found, "admin_trade_speedup", null, user, roomName);
            return true;
        }

        var tUser = found[0].data;
        if (!tUser.voyage || tUser.voyage.active !== true) {
            return replier.reply(formatAdmin("❌ 명령 무효", tUser.name + "님은 현재 항해 중이 아닙니다."));
        }

        // 도착 시간을 현재 시간보다 1초 전으로 설정하여 즉시 도착 판정 유도
        tUser.voyage.arrival = Date.now() - 1000;
        tUser.skipHealing = true;

        safeSaveData(data, true);
        replier.reply(formatAdmin("⚓ 항해 가속 완료", tUser.name + "님의 선박이 목적지에 즉시 도착했습니다.\n\n💡 해당 유저가 채팅을 입력하면 즉시 정산됩니다."));
        return true;
    }

// 전 서버 직업 초기화 (직업 미활동 유저 정리용)
    if (msg === "/전체직업초기화") {
        var count = 0;
        for (var r in data.rooms) {
            for (var uid in data.rooms[r].users) {
                var u = data.rooms[r].users[uid];
                if (u.job) {
                    u.job = null;
                    u.infamy = 0;
                    u.fame = 0;
                    u.currentBounty = 0;
                    u.jobJoinDate = "";
                    u.skipHealing = true;
                    count++;
                }
            }
        }
        safeSaveData(data, true);
        replier.reply(formatAdmin("🧹 전 서버 직업 정화 완료", "총 " + count + "명의 직업 데이터를 초기화했습니다."));
        return true;
    }

    // 기존 버그로 인해 이름이 바뀌지 않은 정령들의 이름을 일괄 교정
    if (msg === "/정령이름복구") {
        var fixCount = 0;
        for (var r in data.rooms) {
            for (var uid in data.rooms[r].users) {
                var u = data.rooms[r].users[uid];
                if (u.spiritData && u.spiritData.roster && u.spiritData.roster.length > 0) {
                    var isFixed = false;
                    u.spiritData.roster.forEach(function(sp) {
                        var correctName = SPIRIT_CONFIG.DB[sp.id].name;
                        if (sp.name !== correctName) {
                            sp.name = correctName;
                            isFixed = true;
                            fixCount++;
                        }
                    });
                    if (isFixed) u.skipHealing = true;
                }
            }
        }
        safeSaveData(data, true);
        replier.reply(formatAdmin("🐾 정령 이름 동기화 완료", "총 " + fixCount + "마리의 오류난 정령 이름을 시스템 도감 기준으로 일괄 교정했습니다."));
        return true;
    }

    return false;
}

