function _processDgnEquip(choice, user, data, replier, roomName, targetUid) {
    var state = data.rooms[roomName].features.states.menuWait[targetUid];
    var idx = parseInt(choice) - 1;
    var list = state.extra.list;

    if (isNaN(idx) || idx < 0 || idx >= list.length) return replier.reply(formatError(user, "번호 오류", "올바른 번호를 선택하세요."));

    var target = list[idx];
    var iInfo = DGN_ITEM_DB[target.item.name];

    // 포션 사용 로직
    if (target.item.type === "potion") {
        if (iInfo.stat.hp) user.dgnStat.hp = Math.min(user.dgnStat.maxHp, user.dgnStat.hp + iInfo.stat.hp);
        if (iInfo.stat.stam) user.dgnStat.stam = Math.min(user.dgnStat.maxStam, user.dgnStat.stam + iInfo.stat.stam);
        
        if (iInfo.stat.hunger) user.dgnStat.hunger = Math.min(user.dgnStat.maxHunger, user.dgnStat.hunger + iInfo.stat.hunger);
        
        var cureMsg = "";
        if (iInfo.stat.cure) {
            if (user.dgnState && user.dgnState.combat && user.dgnState.combat.ailment === iInfo.stat.cure) {
                user.dgnState.combat.ailment = null;
                cureMsg = "\n✨ [상태이상] 상태가 치료되었습니다!";
            }
        }
        
        user.dgnBag.splice(target.bagIdx, 1);
        replier.reply(formatCommand("🧪 아이템 사용", user, "[" + target.item.name + "]을(를) 사용했습니다!" + cureMsg));
    }

    // 장비 장착 로직
    else {
        var slot = target.item.type; // "weapon", "armor", "acc"
        var oldEquip = user.dgnEquip[slot];
        
        // 1. 기존 장비 해제 및 스탯 롤백
        if (oldEquip) {
            var oldInfo = DGN_ITEM_DB[oldEquip.name];
            if (oldInfo && oldInfo.stat) {
                for (var key in oldInfo.stat) user.dgnStat[key] -= oldInfo.stat[key];
            }
            user.dgnBag.push(oldEquip); // 기존 템 가방으로
        }

        // 2. 새 장비 착용 및 스탯 적용
        user.dgnBag.splice(target.bagIdx, 1); // 가방에서 제거
        user.dgnEquip[slot] = target.item;
        if (iInfo && iInfo.stat) {
            for (var key in iInfo.stat) user.dgnStat[key] += iInfo.stat[key];
        }
        replier.reply(formatCommand("✨ 장비 장착", user, "[" + target.item.name + "]을(를) 장착했습니다."));
    }

    user.skipHealing = true;
    safeSaveData(data, false);
    _showDgnInfoMain(user, replier, data.rooms[roomName], targetUid, roomName);
}

function _processDgnUnequip(user, data, replier, roomName, targetUid) {
    var eq = user.dgnEquip;
    var slots = ["weapon", "armor", "acc"];
    var unequipped = false;

    slots.forEach(function(slot) {
        if (eq[slot]) {
            if (user.dgnBag.length >= SYSTEM_CONFIG.DUNGEON.MAX_BAG_SLOTS) return; // 가방 꽉차면 중단
            
            var oldInfo = DGN_ITEM_DB[eq[slot].name];
            if (oldInfo && oldInfo.stat) {
                for (var key in oldInfo.stat) user.dgnStat[key] -= oldInfo.stat[key];
            }
            user.dgnBag.push(eq[slot]);
            eq[slot] = null;
            unequipped = true;
        }
    });

    if (unequipped) {
        replier.reply(formatCommand("⏬ 장비 해제", user, "모든 장비를 해제하여 가방에 넣었습니다."));
    } else {
        replier.reply(formatError(user, "해제 실패", "장착 중인 장비가 없거나 가방이 꽉 찼습니다."));
    }
    
    user.skipHealing = true;
    safeSaveData(data, false);
    _showDgnInfoMain(user, replier, data.rooms[roomName], targetUid, roomName);
}

