                // 1. [0분, 5분, 10분...] 이전 회차 100% 확정 정산 및 새로운 모집 오픈
                if (currentMin % 5 === 0 && venture.lastUpdateMin !== currentMin) {
                    venture.lastUpdateMin = currentMin;

                    // 이전 회차 정산 (참여자가 있을 때만 알림 발송)
                    if (Object.keys(venture.bets).length > 0) {
                        // 1. [협동형] 마일스톤 시너지 (20만부터 10만 단위로 +0.5%씩, 최대 100만 +4.5%)
                        var poolBonus = 0;
                        if (venture.totalPool >= 200000) {
                            var tier = Math.floor(venture.totalPool / 100000);
                            tier = Math.min(10, tier); // 최대 100만(tier 10)
                            poolBonus = (tier - 1) * 0.005;
                        }

