    try {
        var vCfg = SYSTEM_CONFIG.ECO.VENTURE;
        var mainRoomData = data.rooms[ctx.targetRoom];
        if (mainRoomData && mainRoomData.features) {
            var venture = mainRoomData.features.ventureFund;
