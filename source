                        u.fame = 0;
                        u.currentBounty = 0;
                        
                        try {
                            Api.replyRoom(r, "📢 [인사 행정 알림]\n유저 '" + u.name + "'님은 7일간 해상 활동이 없어 [" + jobName + "] 직위에서 자동 해임되었습니다.");
