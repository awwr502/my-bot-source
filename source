/**
 * [신설: 지능형 빈부격차 교정 배율] v1.0
 * 기능: 지니 계수에 따라 자산가에게는 누진세를, 서민에게는 보너스를 부여하는 지능형 수치를 반환
 */
function util_getGiniCorrection(user, roomName) {
    var data = getDatabase(); // 데이터 로드를 최상단으로 이동
    if (!data || !data.rooms || !data.rooms[roomName]) return { tax: 1.0, reward: 1.0, level: "안정" };

    var logicRoom = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    if (!data.rooms[logicRoom]) return { tax: 1.0, reward: 1.0, level: "안정" };

    var gini = util_calculateGini(logicRoom);
    var conf = INTELLIGENT_CONFIG.ECONOMY;
    
    if (gini < conf.GINI_CRITICAL) return { tax: 1.0, reward: 1.0, level: "안정" };

    var today = getSimpleDate();
    if (data.lastGiniAlertDate !== today) {
        data.lastGiniAlertDate = today; 
        var alertMsg = util_formatSecurityLog("🚨 [ECONOMY: 빈부격차 경보]", "SYSTEM", logicRoom, 
            "📊 지니계수: " + gini.toFixed(3), "3단계 계층별 차등 수칙 가동");
        try { Api.replyRoom("베릭방", alertMsg); } catch(e) {}
    }

    var percentile = util_getNetWorthPercentile(user, logicRoom);
    var intensity = (gini - conf.GINI_CRITICAL) / (1 - conf.GINI_CRITICAL);
    
    // 기본값 (중산층)
    var res = { tax: 1.0, reward: 1.0, level: "중산층" };

    if (percentile <= 15) {
        // 상류층 (엘리트): 누진세 적용 (최대 +50%)
        res.tax = 1.0 + (conf.MAX_PROGRESSIVE_TAX * intensity);
        res.level = "상류층(누진)";
    } else if (percentile >= 70) {
        // 부양층 (서민): 보상 강화 (최대 1.5배)
        res.reward = 1.0 + ((conf.REWARD_BOOST_LIMIT - 1.0) * intensity);
        res.level = "부양층(지원)";
    }
    
    return res;
}

/**
 * [공통 함수: 물가 배율 통합 엔진] v5.9
 * 기능: 특정 방의 경제 지표를 분석하여 현재의 최종 물가 배율(Multiplier)을 반환합니다.
 * 용도: 상점가 조절, 출석 보상 조절, 채굴 효율 조절 등
 */
function util_getEcoMultiplier(roomName) {
    var data = getDatabase();
    var roomData = data.rooms[roomName];
    if (!roomData || !roomData.economyBase || roomData.economyBase <= 0) return 1.0;

    // 섹터 8의 통합 경제 지표 호출 (채권/부채 반영 수치)
    var currentEco = calculateEconomy(data, roomName);
    var rawRatio = currentEco.total / roomData.economyBase; 
    
    var damping = (data.economyDamping !== undefined) ? data.economyDamping : 0.3;
    
    // 물가 배율이 1.2배를 초과할 경우, 완충력을 조정하여 상승 억제
    if (rawRatio > 1.2) {
        damping = Math.min(0.5, damping + (rawRatio - 1.2) * 0.5);
    }
    var multiplier = 1 + (rawRatio - 1) * damping;
    
    if (multiplier > 2.0) {
        var now = Date.now();
        // 마지막 알림 후 1시간(3,600,000ms)이 지났을 때만 알림 발송
        if (!data.lastInflationAlertTime || now - data.lastInflationAlertTime > 3600000) {
            data.lastInflationAlertTime = now;
            var inflationBody = "📈 내용: 하이퍼 인플레이션 징후 감지\n" +
                                "💰 현재 물가 배율: x" + multiplier.toFixed(2);
            var inflationMsg = util_formatSecurityLog("🚨 [ECONOMY: 물가 폭등 위험]", "MARKET", roomName, inflationBody, "물가 완충 엔진 점검 (1시간 내 재알림 방지)");
            try { Api.replyRoom("베릭방", inflationMsg); } catch(e) {}
        }
    }

    // 최소 배율 제한 (하한선 0.5배) 및 최대 상한선 (3.0배) 안전장치 추가
    return Math.max(0.5, Math.min(3.0, multiplier));
}

/**
 * [시스템] 아이템 가격 계산 함수
 * 기능: 통합 엔진 배율을 적용하여 실시간 단품가(1개 가격)를 산출합니다.
 */
function getItemPrice(item, user, roomName) {
    var logicRoom = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var multiplier = util_getEcoMultiplier(logicRoom);
    var giniCorr = util_getGiniCorrection(user, logicRoom);

    // [정부 정책 연동] 현재 시행 중인 정책 로드
    var data = getDatabase();
    var pol = util_getActivePolicy(data.rooms[logicRoom]);

    // 기초가(Base) 설정: 무역 물품일 경우 섹터 1의 상수를 우선 참조
    var rawPrice = Number(item.price);
    var basePrice = 0; // 변수 초기화 위치 교정

    if (item.effect === "trade_cargo" && item.value) {
        var tradeCfg = SYSTEM_CONFIG.TRADE;
        rawPrice = (tradeCfg.GOODS_COST && tradeCfg.GOODS_COST[item.value]) ? tradeCfg.GOODS_COST[item.value] : rawPrice;
        
        // [양방향 시세 적용] 매입 시 현재 정박 중인 항구의 개별 시세 반영
        var curLoc = user.currentLoc || "무역 지부";
        var market = data.rooms[logicRoom].features.tradeMarket;
        if (curLoc !== "무역 지부" && curLoc !== "나소" && curLoc !== "엘도라도: 잊혀진 성역" && market && market[curLoc] && market[curLoc].rates) {
            var localRate = market[curLoc].rates[item.value] || 1.0;
            rawPrice = Math.floor(rawPrice * localRate);
        }
        
        // [패치] 무역품은 전역 물가(multiplier) 및 지니누진세를 면제하고 순수 시세만 적용
        basePrice = rawPrice;
    } else {
        // 무역품 외 일반 상점 아이템은 물가, 지니계수, 정부정책 모두 정상 적용
        basePrice = Math.floor(rawPrice * multiplier * giniCorr.tax * (pol.shopPriceMult || 1.0));
    }

    // [v18.0] 도감 100% 보상 (포세이돈): 무역품 구매 25% 할인
    if (user.pediaRewardLevel >= 5 && item.cat === 6) { // cat 6 = 무역물품
        basePrice = Math.floor(basePrice * 0.75);
    }

    // [승급권 누적 할증] 구매할 때마다 기본가의 10%씩 영구 할증
    if (item.id === 8) { 
        var boughtCount = Number(user.purchasedPromotionAttempts || 0);
        var surchargeUnit = Math.floor(basePrice * 0.10); // 기본가의 10% 산출
        return basePrice + (surchargeUnit * boughtCount); 
    }

    return basePrice;
}

/**
 * [Gemini 정밀 교정] 경제 부양 지원금 체크 함수 (중복 선언 제거 및 통합)
 */
function checkEconomicStimulus(user, roomName, isManual) {
    if ((user.totalAttendance || 0) < 2) return;
    
    var currentCount = user.dailyStimulusCount || 0;
    if (currentCount >= 1) return;

    var data = getDatabase();
    if (!data) return;
    
    var eco = calculateEconomy(data, roomName);
    var avgAsset = eco.average;
    var roomData = data.rooms[roomName];
    var myNetWorth = util_calculateNetWorth(user, roomData);

    // 1. 지급 기준선: 평균 순자산의 70% 미만으로 완화 (기존 40%)
    var targetLine = Math.floor(avgAsset * 0.7);
    
    if (myNetWorth < targetLine) {
        var multiplier = util_getEcoMultiplier(roomName);
        var giniCorr = util_getGiniCorrection(user, roomName);
        var gap = targetLine - myNetWorth;
        var emergencyMult = util_getEmergencyMultiplier(roomName);

        // [정부 정책 연동] 인플레이션 억제 정책 로드
        var pol = util_getActivePolicy(roomData);

        // 2. 지원금액: 평균 순자산의 10%를 기본 지급액으로 설정 (기존 10,000P 고정)
        var baseRewardAmount = Math.floor(avgAsset * 0.1);
        
        // 각종 경제 승수(물가, 긴급상황, 지니계수, 정부정책)를 적용하여 최종 금액 산출
        var baseGive = Math.floor(baseRewardAmount * multiplier * emergencyMult * giniCorr.reward * (pol.globalRewardMult || 1.0));
        
        // 기준선(70%)을 초과하여 지급되지 않도록 보정
        var giveAmount = Math.min(baseGive, gap);

        // 신용불량자 페널티: 민생지원금 20% 삭감
        if (Number(user.creditScore || 600) < 500) {
            giveAmount = Math.floor(giveAmount * 0.8);
        }
        
        if (giveAmount < 100 || !util_isBankSolvent(roomName, giveAmount)) return;

        util_updatePoint(user, roomData, giveAmount, "민생지원금 지급", roomName);
        user.dailyStimulusCount = currentCount + 1;

        var msg = "\n경제 위기 극복을 위한 긴급 민생지원금이 지급되었습니다.\n" +
                  "💰 지원금액: +" + fp(giveAmount) + "P";

        Api.replyRoom(roomName, formatCommand("🎁 민생지원금 안내", user, msg, "내 잔액: " + fp(user.point) + "P"));
        safeSaveData(data);
    }
}


