function _showDgnGuildQuest(user, replier, roomData, targetUid, roomName) {
    var g = user.dgnGuild;
    
    // 1. 현재 진행 중인 의뢰가 있는 경우 (달성 여부 판정)
    if (g.quest) {
        var isClear = false;
        
        if (g.quest.type === "hunt" && g.quest.current >= g.quest.target) isClear = true;
        if (g.quest.type === "collect") {
            var count = 0;
            user.dgnBag.forEach(function(it) { if (it.name === g.quest.targetItem) count++; });
            if (count >= g.quest.target) isClear = true;
        }

        if (isClear) {
            var rwd = g.quest.reward;
            user.dgnGold = (user.dgnGold || 0) + rwd;
            g.exp += 10;
            g.clearCount++;
            
            // 수집 퀘스트일 경우 가방에서 아이템 삭제
            if (g.quest.type === "collect") {
                var removed = 0;
                for (var i = user.dgnBag.length - 1; i >= 0; i--) {
                    if (user.dgnBag[i].name === g.quest.targetItem && removed < g.quest.target) {
                        user.dgnBag.splice(i, 1);
                        removed++;
                    }
                }
            }
            g.quest = null;
            user.skipHealing = true;
            safeSaveData(data, true);
            replier.reply(formatCommand("✨ 의뢰 달성", user, "길드의 의뢰를 성공적으로 완수했습니다!\n\n💰 보상: +" + fp(rwd) + " G\n📈 길드 경험치: +10"));
        } else {
            var curStat = (g.quest.type === "hunt") ? g.quest.current : "가방 소지품 확인";
            replier.reply(formatCommand("🏃 진행 중인 의뢰", user, "목표: " + g.quest.desc + "\n현황: " + curStat + " / " + g.quest.target + "\n\n(조건을 달성한 후 다시 길드를 방문하세요.)", "길드 지부 메인: [뒤로]"));
        }
        return;
    }

    // 2. 의뢰가 없을 경우 AI 무작위 퀘스트 생성 (F랭크 기준)
    var qList = [
        { id: 1, type: "hunt", target: 3, targetMob: "맹독 슬라임", desc: "늪지대 맹독 슬라임 3마리 토벌", reward: 15000 },
        { id: 2, type: "collect", target: 2, targetItem: "고블린의 뼈", desc: "고블린의 뼈 2개 수집", reward: 10000 },
        { id: 3, type: "hunt", target: 1, targetMob: "거대 고블린 족장", desc: "[보스 토벌] 거대 고블린 족장 처치", reward: 50000 }
    ];

    var body = "게시판에 새로운 의뢰가 3건 등록되어 있습니다.\n\n";
    qList.forEach(function(q, i) { body += (i+1) + ". " + q.desc + " (보상: " + fp(q.reward) + "P)\n"; });
    body += "\n수주할 의뢰 번호를 입력하세요.\n↩️ 뒤로 / ❎취소";

    roomData.features.states.menuWait[targetUid] = { type: 'dgn_guild_quest', time: Date.now(), extra: { quests: qList }, originRoom: roomName };
    replier.reply(formatCommand("📜 AI 의뢰 게시판", user, body));
}

