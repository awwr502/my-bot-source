/**
 * 🌐 [블랙마켓] 중앙 상태 분배기 (Dispatcher)
 * 섹터 24에 연동될 핸들러
 */
function _handleBMStep(msg, user, data, replier, roomName, targetUid) {
    var roomData = data.rooms[roomName];
    if (!roomData || !roomData.features || !roomData.features.states.menuWait) return false;

    var state = roomData.features.states.menuWait[targetUid];
    if (!state || !state.type.startsWith('bm_')) return false;

    var NAV_BAR = "\n\n↩️ 뒤로 / 🏠 처음으로 / ❎취소";
    var input = msg.trim();

    // (통합 네비게이션은 섹터 23-4 및 24의 마스터 라우터가 전담하므로 여기서는 명령어 가드만 수행)
    if (input.startsWith("/")) return false;

    var choice = parseInt(input.replace(/[^0-9]/g, ""));

    /* 1. 가입 등록 */
    if (state.type === 'bm_register') {
        if (choice === 1) {
            user.bm.isRegistered = true;
            user.bm.krw = BM_CONFIG.START_KRW;
            user.skipHealing = true;
            safeSaveData(data, true);
            replier.reply(formatCommand("✅ 브로커망 등록 완료", user, "어둠의 세계에 오신 것을 환영합니다.\n초기 자금 " + fp(BM_CONFIG.START_KRW) + " 원화가 입금되었습니다."));
            _gameBlackMarketLogic("/블랙마켓", user, data, replier, roomName, targetUid);
        } else {
            delete roomData.features.states.menuWait[targetUid];
            replier.reply("등록을 거절하셨습니다.");
        }
        return true;
    }

    /* 2. 메인 분기 */
    if (state.type === 'bm_main') {
        if (choice === 1) { // 무기상
            var sBody = "원화(KRW)로 납품할 무기를 매입합니다.\n\n";
            var idx = 1;
            var wKeys = Object.keys(BM_CONFIG.WEAPONS);
            wKeys.forEach(function(k) {
                sBody += idx + ". " + BM_CONFIG.WEAPONS[k].name + " : " + fp(BM_CONFIG.WEAPONS[k].price) + " 원\n";
                idx++;
            });
            sBody += "\n입력: [번호] [수량] (예: 1 10)" + NAV_BAR;
            state.type = 'bm_shop';
            state.time = Date.now();
            replier.reply(formatCommand("🛒 딥웹 무기 거래소", user, sBody, "내 자금: " + fp(user.bm.krw) + " 원"));
        } else if (choice === 2) { // 브로커 의뢰소
            if (user.bm.delivery && user.bm.delivery.active) {
                replier.reply(formatError(user, "수주 불가", "현재 진행 중인 납품 작전이 있습니다.\n배송이 완료된 후 다시 시도하세요."));
                return true;
            }

            var cBody = "현재 암시장에 등록된 납품 의뢰입니다.\n(성공 시 현지 비밀 금고로 외화가 입금됩니다)\n\n";
            var contracts = data.bmWorld.contracts;
            if (contracts.length === 0) cBody += "- 현재 등록된 의뢰가 없습니다. (10분마다 갱신) -\n";
            
            contracts.forEach(function(c, i) {
                var wName = BM_CONFIG.WEAPONS[c.item].name;
                var rName = BM_CONFIG.REGIONS[c.region].name;
                // 현재 환율을 바탕으로 원화(KRW) 환산 가치 계산
                var curRate = data.bmWorld.rates[c.region] || 1;
                var krwEquiv = Math.floor(c.reward * curRate);

                cBody += (i+1) + ". [" + rName + "]\n" +
                         "   └ 납품: " + wName + " x" + c.qty + "개\n" +
                         "   └ 보상: " + fp(c.reward) + " " + c.region + " (약 " + fp(krwEquiv) + " 원)\n" +
                         "   └ ⚠️ 적발 위험: " + c.risk + "%\n\n";
            });
            cBody += "수행할 의뢰 번호를 입력하세요." + NAV_BAR;
            state.type = 'bm_broker';
            state.time = Date.now();
            replier.reply(formatCommand("📡 글로벌 브로커 네트워크", user, cBody));
        } else if (choice === 3) { // 외환 금고 (환전)
            var vBody = "현지 화폐를 원화(KRW)로 환전하여 스위스 계좌로 송금합니다.\n\n";
            var idx = 1;
            var cKeys = Object.keys(BM_CONFIG.REGIONS);
            cKeys.forEach(function(cur) {
                var rate = data.bmWorld.rates[cur];
                var amt = user.bm.vaults[cur];
                vBody += idx + ". " + BM_CONFIG.REGIONS[cur].icon + " " + cur + "\n" +
                         "   └ 현재 환율: 1 " + cur + " = " + fp(rate) + " 원\n" +
                         "   └ 보유 외환: " + fp(amt) + " " + cur + " (환전 시 +" + fp(amt * rate) + " 원)\n\n";
                idx++;
            });
            vBody += "입력: [번호] [수량 또는 '전부'] (예: 1 전부)" + NAV_BAR;
            state.type = 'bm_vault';
            state.time = Date.now();
            replier.reply(formatCommand("💼 스위스 비밀 금고", user, vBody));
        } else {
            replier.reply(formatError(user, "번호 오류", "1~3번을 선택하세요."));
        }
        return true;
    }

    /* 3. 무기상 (매입) */
    if (state.type === 'bm_shop') {
        var parts = input.split(/\s+/);
        var idx = parseInt(parts[0]) - 1;
        var qty = parts.length > 1 ? parseInt(parts[1]) : 1;
        var wKeys = Object.keys(BM_CONFIG.WEAPONS);

        if (isNaN(idx) || idx < 0 || idx >= wKeys.length) return replier.reply(formatError(user, "번호 오류", "정확한 번호를 입력하세요."));
        if (isNaN(qty) || qty <= 0) return replier.reply(formatError(user, "수량 오류", "정확한 수량을 입력하세요."));

        var wKey = wKeys[idx];
        var cost = BM_CONFIG.WEAPONS[wKey].price * qty;

        var curWeapons = 0;
        for (var k in user.bm.weapons) curWeapons += Number(user.bm.weapons[k]);

        if (curWeapons + qty > BM_CONFIG.MAX_CAPACITY) {
            return replier.reply(formatError(user, "공간 부족", "무기고 최대 적재량(" + BM_CONFIG.MAX_CAPACITY + "개)을 초과할 수 없습니다."));
        }
        if (user.bm.krw < cost) {
            return replier.reply(formatError(user, "자본 부족", "원화가 부족합니다. (필요: " + fp(cost) + " 원)"));
        }

        user.bm.krw -= cost;
        user.bm.weapons[wKey] = (Number(user.bm.weapons[wKey]) || 0) + qty;
        user.skipHealing = true;
        safeSaveData(data, true);

        replier.reply(formatCommand("✅ 매입 완료", user, BM_CONFIG.WEAPONS[wKey].name + " " + qty + "개를 무기고에 입고했습니다.\n(지불: -" + fp(cost) + " 원)", "뒤로가기: [뒤로]"));
        state.time = Date.now();
        return true;
    }

    /* 4. 브로커 의뢰 (납품) */
    if (state.type === 'bm_broker') {
        var idx = parseInt(input) - 1;
        var contracts = data.bmWorld.contracts;
        
        if (isNaN(idx) || idx < 0 || idx >= contracts.length) return replier.reply(formatError(user, "번호 오류", "목록에 있는 의뢰 번호를 선택하세요."));
        
        var c = contracts[idx];
        if (Number(user.bm.weapons[c.item] || 0) < c.qty) {
            return replier.reply(formatError(user, "무기 부족", "무기고에 [" + BM_CONFIG.WEAPONS[c.item].name + "]이(가) 부족합니다."));
        }

        // 무기 선차감 및 10분 배송 상태로 전환
        user.bm.weapons[c.item] -= c.qty; 
        
        user.bm.delivery = {
            active: true,
            arrival: Date.now() + 600000, // 10분 대기 (600,000ms)
            contract: JSON.parse(JSON.stringify(c)), // 수주 시점의 보상/위험 스냅샷 박제
            isProcessing: false
        };

        var startMsg = "🚚 [납품 작전 개시]\n\n" +
                       "📍 목적지: " + c.region + "\n" +
                       "📦 품목: " + BM_CONFIG.WEAPONS[c.item].name + " x" + c.qty + "\n" +
                       "⏳ 소요 시간: 10분\n\n" +
                       "💡 국경을 넘기 위해 출발했습니다. 도착 후 첫 채팅 시 결과가 보고됩니다.";
        replier.reply(formatCommand("✅ 의뢰 수주 완료", user, startMsg, "대시보드로 복귀: [뒤로]"));

        // 해당 의뢰는 수주되었으므로 시장에서 삭제 (경쟁 시스템 유지)
        data.bmWorld.contracts.splice(idx, 1);
        user.skipHealing = true;
        safeSaveData(data, true);
        state.time = Date.now();
        return true;
    }

    /* 5. 비밀 금고 (환전) */
    if (state.type === 'bm_vault') {
        var parts = input.split(/\s+/);
        var idx = parseInt(parts[0]) - 1;
        var qtyStr = parts.length > 1 ? parts[1] : "";
        var cKeys = Object.keys(BM_CONFIG.REGIONS);

        if (isNaN(idx) || idx < 0 || idx >= cKeys.length) return replier.reply(formatError(user, "번호 오류", "정확한 국가 번호를 입력하세요."));
        if (!qtyStr) return replier.reply(formatError(user, "수량 누락", "환전할 수량을 함께 입력하세요. (예: 1 전부)"));

        var cur = cKeys[idx];
        var maxAmt = Number(user.bm.vaults[cur] || 0);
        var qty = (qtyStr === "전부" || qtyStr === "올인") ? maxAmt : parseInt(qtyStr.replace(/[^0-9]/g, ""));

        if (isNaN(qty) || qty <= 0) return replier.reply(formatError(user, "수량 오류", "정확한 환전 수량을 입력하세요."));
        if (qty > maxAmt) return replier.reply(formatError(user, "외환 부족", "해당 국가의 외환이 부족합니다. (보유: " + fp(maxAmt) + " " + cur + ")"));

        var rate = data.bmWorld.rates[cur];
        var convertedKrw = Math.floor(qty * rate);

        user.bm.vaults[cur] -= qty;
        user.bm.krw += convertedKrw;
        user.skipHealing = true;
        safeSaveData(data, true);

        safeSaveData(data, true);

        var exMsg = "현지 화폐를 원화(KRW)로 안전하게 세탁하여 본국으로 송금했습니다.\n\n" +
                    "📉 사용 외환: -" + fp(qty) + " " + cur + "\n" +
                    "📈 적용 환율: " + fp(rate) + "\n" +
                    "💰 송금 완료: +" + fp(convertedKrw) + " 원";
        replier.reply(formatCommand("💼 자금 세탁 및 송금 완료", user, exMsg, "뒤로가기: [뒤로]"));
        state.time = Date.now();
        return true;
    }

    return false;
}

/**
 * 🌐 [블랙마켓] 정산 시스템: 10분 뒤 유저가 채팅을 쳤을 때 결과 판독
 */
function _processBMArrival(user, data, replier, roomName) {
    if (!user || !user.bm || !user.bm.delivery || !user.bm.delivery.active) return;
    
    var d = user.bm.delivery;
    if (d.isProcessing) return;
    d.isProcessing = true;

    try {
        var c = d.contract;
        var wName = BM_CONFIG.WEAPONS[c.item].name;
        // 출발 시점에 박제된 risk 기반 롤 굴림
        var isCaught = (Math.random() * 100) < c.risk;

        var resMsg = "📍 목적지: " + c.region + "\n" +
                     "📦 품목: " + wName + " x" + c.qty + "\n\n";

        if (isCaught) {
            resMsg += "🚨 [긴급 상황: 인터폴 적발]\n" +
                      "국경을 넘는 도중 세관에 적발되었습니다!\n" +
                      "납품하려던 물건을 전량 압수당하고 빈손으로 도주했습니다.\n\n" +
                      "❌ 작전 실패 (보상금 소실)";
            replier.reply(formatError(user, "납품 실패 보고", resMsg));
        } else {
            user.bm.vaults[c.region] = (Number(user.bm.vaults[c.region]) || 0) + c.reward;
            resMsg += "✅ [작전 성공]\n" +
                      "포위망을 뚫고 무사히 물건을 전달했습니다.\n" +
                      "대금은 현지 비밀 금고에 안전하게 보관되었습니다.\n\n" +
                      "💰 획득: +" + fp(c.reward) + " " + c.region;
            replier.reply(formatCommand("🚚 무기 납품 완료", user, resMsg));
        }

        // 정산 완료 후 상태 완전 초기화 (쿨타임 없음)
        d.active = false;
        user.skipHealing = true;
        safeSaveData(data, true);
    } catch(e) {
        d.isProcessing = false;
        Log.error("BM Arrival Error: " + e);
    }
}
