function _gameActionLogic_Fund(msg, user, data, replier, roomName, targetUid) {
    var roomData = data.rooms[(ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName];
    var venture = roomData.features.ventureFund;
    var vCfg = SYSTEM_CONFIG.ECO.VENTURE;

    if (!venture || venture.status !== 'open') {
        return replier.reply(formatError(user, "투자 불가", "현재 펀드 모집 기간이 아닙니다.\n(매 5분 주기 모집: 0~4분 사이)"));
    }

    var parts = msg.split(" ");
    if (parts.length < 2) return replier.reply(formatError(user, "입력 오류", "투자할 금액을 입력하세요. (예: /펀드 10000)"));

    // 서버 물가 배율 연동 한도 계산: 10만P * 물가배율 (1만P 단위 절사)
    var ecoMult = util_getEcoMultiplier(roomName);
    var baseMax = vCfg.MAX_BET || 100000;
    var maxLimit = Math.floor((baseMax * ecoMult) / 10000) * 10000;
    var minLimit = vCfg.MIN_BET || 1000;
    
    var amtStr = parts[1].replace(/,/g, "");
    var amt = 0;
    if (amtStr === "전부" || amtStr === "올인" || amtStr === "최대") {
        amt = Math.min(Number(user.point), maxLimit);
    } else {
        amt = parseInt(amtStr);
    }

    if (isNaN(amt) || amt < minLimit) {
        return replier.reply(formatError(user, "금액 오류", "최소 " + fp(minLimit) + "P 이상 투자 가능합니다."));
    }

    // 기존 투자금이 있다면 합산해서 한도 체크
    var currentBet = Number(venture.bets[targetUid] || 0);
    if (currentBet + amt > maxLimit) {
        return replier.reply(formatError(user, "한도 초과", "현재 서버 물가가 반영된 최대 투자 한도는 " + fp(maxLimit) + "P 입니다.\n\n잔여 한도: " + fp(Math.max(0, maxLimit - currentBet)) + "P"));
    }

    if (Number(user.point) < amt) {
        return replier.reply(formatError(user, "자금 부족", "보유 포인트가 부족합니다."));
    }

    util_updatePoint(user, roomData, -amt, "왕립 상선단 펀드 투자", roomName);
    venture.bets[targetUid] = currentBet + amt;
    venture.totalPool += amt;
    user.skipHealing = true;
    safeSaveData(data);

    var tierMsgs = "";
    if (venture.totalPool >= 1000000) tierMsgs = " (MAX 시너지 달성!)";
    else if (venture.totalPool >= 200000) tierMsgs = " (시너지 +" + ((Math.floor(venture.totalPool/100000) - 1) * 0.5).toFixed(1) + "% 가동 중)";
    else tierMsgs = " (20만P 돌파 시 보너스 가동)";

    var resMsg = venture.fleetName + " 펀드에 " + fp(amt) + "P를 투자했습니다.\n\n" +
                 "📈 기본 수익률: +" + ((venture.payoutMult - 1) * 100).toFixed(1) + "%\n" +
                 "🤝 현재 총 모금액: " + fp(venture.totalPool) + "P" + tierMsgs + "\n" +
                 "💵 나의 총 투자금: " + fp(venture.bets[targetUid]) + "P";
    replier.reply(formatCommand("💰 펀드 투자 완료", user, resMsg, "내 잔액: " + fp(user.point) + "P"));
    return true;
}

function _gameActionLogic_Work(msg, user, data, replier, roomName, targetUid) {
    var roomData = data.rooms[(ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName];
    
    // 상태 검증 (활동 가능한지)
    var stateRes = util_checkUserState(user, targetUid, roomName, false);
    if (!stateRes.canAction) return replier.reply(formatError(user, "작업 불가", stateRes.reason));

    var now = Date.now();
    var conf = SYSTEM_CONFIG.ECO.WORK || { COOLDOWN_MIN: 5, MIN_REWARD: 2000, MAX_REWARD: 5000 };
    var cdMs = conf.COOLDOWN_MIN * 60 * 1000;

    if (user.lastWorkTime && now - user.lastWorkTime < cdMs) {
        var remain = cdMs - (now - user.lastWorkTime);
        var rm = Math.floor(remain / 60000);
        var rs = Math.floor((remain % 60000) / 1000);
        return replier.reply(formatError(user, "피로 누적", "아직 체력이 회복되지 않았습니다.\n" + rm + "분 " + rs + "초 뒤에 다시 하역 작업을 할 수 있습니다."));
    }

    user.lastWorkTime = now;
    var ecoMult = util_getEcoMultiplier(roomName);
    var baseReward = Math.floor(Math.random() * (conf.MAX_REWARD - conf.MIN_REWARD + 1)) + conf.MIN_REWARD;
    var finalReward = Math.floor(baseReward * ecoMult);

    util_updatePoint(user, roomData, finalReward, "부두 하역 알바", roomName);

    var bonusMsg = "";
    // 5% 확률로 식료품 1개 획득 (물류 창고로 지급)
    if (Math.random() < 0.05) {
        if (!user.warehouse) user.warehouse = {};
        user.warehouse["식료품"] = (Number(user.warehouse["식료품"]) || 0) + 1;
        bonusMsg = "\n🎁 상단 주인이 수고했다며 팁으로 [식료품 상자] 1개를 창고에 넣어주었습니다!";
    }

    var loc = user.currentLoc || "무역 지부";
    var body = loc + " 항구 부두에서 열심히 화물을 날랐습니다.\n\n" +
               "💰 품삯: +" + fp(finalReward) + "P" + bonusMsg;

    user.skipHealing = true;
    safeSaveData(data);
    replier.reply(formatCommand("💦 부두 하역 작업", user, body, "5분 뒤에 다시 작업할 수 있습니다."));
    return true;
}

