/**
 * 항구 발전 보너스 계산기
 */
function util_getPortLevelBonus(portName, roomData) {
    if (!roomData || !roomData.features || !roomData.features.portData || !roomData.features.portData[portName]) return 0;
    var level = roomData.features.portData[portName].level || 1;
    var cfg = SYSTEM_CONFIG.TRADE.INVEST;

    // (레벨 - 1) * 1% 보너스 적용
    return (level - 1) * (cfg.BONUS_PER_LEVEL || 0.01);
}

/**
 * 거래 발생 후 항구의 재고 비례 시세를 즉시 갱신합니다.
 * @param {Object} roomData - 해당 방 데이터
 * @param {String} portName - 항구 이름
 * @param {String} goodName - 품목 이름
 */
function util_refreshMarketRate(roomData, portName, goodName) {
    if (!roomData.features.tradeMarket || !roomData.features.tradeMarket[portName]) return;
    if (!roomData.features.portData || !roomData.features.portData[portName]) return;

    var market = roomData.features.tradeMarket[portName];
    var inv = roomData.features.portData[portName].inventory;
    if (!inv || inv[goodName] === undefined) return;

    // 1. 현재 재고 확인 및 희소성 계수 계산 (동적 Baseline 연동)
    // 섹터 16-2에서 스케줄러가 저장한 동적 Baseline이 있으면 우선 사용하고, 없으면 상수의 값을 사용
    var fallbackBaseline = (SYSTEM_CONFIG.TRADE && SYSTEM_CONFIG.TRADE.BASELINE) ? SYSTEM_CONFIG.TRADE.BASELINE : 20000;
    var currentBaseline = (roomData.features.tradeMarket.currentBaseline) ? roomData.features.tradeMarket.currentBaseline : fallbackBaseline;
    
    // 최하 10% 밑으로는 재고가 떨어지지 않도록 방어하여 희소성 폭주 차단
    var currentInv = Math.max(Math.floor(currentBaseline * 0.1), Number(inv[goodName])); 
    var scarcityMult = currentBaseline / currentInv; 
    
    // 민감도 조정 (동적 시장폭에 맞게 0.6 ~ 1.6으로 넓힘)
    scarcityMult = Math.max(0.6, Math.min(1.6, scarcityMult));

    // 2. 기존 마켓의 기본 흐름(baseRate) 유지하며 재고 비율만 즉시 반영
    var baseRate = 1.0; 
    if (TRADE_RELATION[portName] && TRADE_RELATION[portName].produce === goodName) baseRate = 0.9;

    var newRate = baseRate * scarcityMult;

    // 3. 시세 제한선(70% ~ 130%) 적용 후 시세표 업데이트
    newRate = Math.max(0.70, Math.min(1.30, newRate));
    market.rates[goodName] = Number(newRate.toFixed(2));
}

