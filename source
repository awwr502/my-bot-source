}

/* [서브] 🛠️ 선박 관리 및 개조 */
function _manageShip(user, replier, cfg) {
    var curLevel = user.shipLevel || 1;
    var maxLevel = user.job ? 10 : 3; 
    var cur = cfg.SHIPS[curLevel];
    var next = cfg.SHIPS[curLevel + 1];
    // [v16.9] 내구도 및 수리비 계산
    var durability = Number(user.durability === undefined ? 100 : user.durability);
    var currentLoc = (user.currentLoc || "무역 지부").replace(/\s/g, "");
    var logicRoom = "내리다"; // 데이터 기준방
    var roomData = globalData.rooms[logicRoom];
    var pInfo = (roomData && roomData.features && roomData.features.portData) ? roomData.features.portData[user.currentLoc] : null;
    var hasShipyard = (pInfo && pInfo.built && pInfo.built.shipyard);

    var isRepairPort = (currentLoc.indexOf("무역지부") !== -1 || currentLoc.indexOf("나소") !== -1 || hasShipyard);
    var dIcon = durability > 50 ? "🟢" : (durability >= 20 ? "🟡" : "🔴");
    
    var body = "등급: " + cur.name + " (Lv." + curLevel + ")\n" +
               "적재량: " + (cur.capacity + (user.enhLimit || 0)) + "칸\n" +
               "내구도: " + dIcon + " " + durability + "%\n";

    // 1. 현재 적용 중인 강화 수치가 있다면 먼저 표시 (상한선 도달 시 MAX 태그 표기)
    if ((user.enhLimit || 0) !== 0 || (user.enhTime || 0) !== 0 || (user.enhProfit || 0) !== 0) {
        var maxLimitTag = ((user.enhLimit || 0) >= 260) ? " (MAX)" : "";
        var maxTimeTag = ((user.enhTime || 0) <= -1050) ? " (MAX)" : "";
        var maxProfitTag = ((user.enhProfit || 0) >= 300) ? " (MAX)" : "";

        body += "\n[✨ 초월 강화 적용 현황]\n" +
                "• 적재량 보정: " + (user.enhLimit >= 0 ? "+" : "") + user.enhLimit + "칸" + maxLimitTag + "\n" +
                "• 항해시간 보정: " + (user.enhTime >= 0 ? "+" : "") + user.enhTime + "초" + maxTimeTag + "\n" +
                "• 정산수익 보정: " + (user.enhProfit >= 0 ? "+" : "") + user.enhProfit + "%" + maxProfitTag + "\n";
    }
    body += "━━━━━━━━━━━━━━━\n";

    // [v16.9] 수리 안내문 동적 삽입
    if (durability < 100) {
        if (isRepairPort) { // 수리 가능 항구 체크로 변경
            var ecobase = Math.floor(util_getEcoMultiplier(currentLoc) * 100);
            var repairCost = (100 - durability) * (300 + ecobase);
            var repairDiscount = (user.pediaRewardLevel >= 1) ? 0.95 : 1.0;
            repairCost = Math.floor(repairCost * repairDiscount);

            var discountTag = (repairDiscount < 1.0) ? " (📘도감할인 -5%)" : "";

            body += "🔧 [선박 수리 서비스 가동]\n" +
                    "• 비용: " + fp(repairCost) + "P" + discountTag + " (전액 수리)\n" +
                    "👉 수리 진행: [수리] 입력\n\n";
        } else {
            body += "⚠️ [주의] 선체 파손 상태입니다.\n" +
                    "수리는 '무역 지부'에서만 가능합니다.\n\n";
        }
    }

    // [v18.9] 초월 강화 UI 격리: 오직 [상인(!user.job)] 신분이며 3레벨 도달 시에만 해금
    if (!user.job && curLevel >= 3) {
        var ec = SHIP_ENHANCE_CONFIG; // 설정 객체 참조
        body += "🔥 [최고 레벨 도달: 초월 강화 해금]\n" +
                fp(ec.COST) + "P를 사용하여 아래 3종 옵션을\n" +
                "랜덤하게 재설정(리롤) 할 수 있습니다.\n\n" +
                "[🎲 강화 가능 범위]\n" +
                "• 📦 적재량: " + ec.LIMIT.min + "칸 ~ " + (ec.LIMIT.max >= 0 ? "+" : "") + ec.LIMIT.max + "칸\n" +
                "• 🕒 항해시간: " + ec.TIME.min + "초 ~ " + (ec.TIME.max >= 0 ? "+" : "") + ec.TIME.max + "초\n" +
                "• 💰 정산보너스: " + ec.PROFIT.min + "% ~ " + (ec.PROFIT.max >= 0 ? "+" : "") + ec.PROFIT.max + "%\n\n" +
                "👉 강화 시도: [강화] 입력";
    }
    // 3. 레벨업 가능 시 기존 개조 로직 (직업군은 10레벨까지 개조만 가능)
    else if (next) {
        // 상인인데 3레벨인 경우 위에서 강화창이 떴으므로, 이 블록은 직업군이나 저레벨 상인만 진입함
        if (!user.job && curLevel >= 3) {
            body += "⚠️ [개조 한계]\n상인 신분으로는 3단계(갤리온)가 한계입니다.\n추가 개조는 해군/해적 전직 후 가능합니다.";
        } else {
            body += "[다음 단계 개조]\n• 대상: " + next.name + "\n• 적재: " + next.capacity + "칸\n• 비용: " + fp(next.upgradeCost) + "P\n\n(개조 시 1번 입력)";
        }
    } 
    // 직업군이 10레벨에 도달하여 next가 없는 경우
    else {
        body += "🎉 이미 최고등급 단계 함선을 보유 중입니다.";
    }

    body += "\n\n💰 보유 포인트: " + fp(user.point) + "P\n\n↩️ 뒤로 / 🏠 처음으로 / ❎취소";
    replier.reply(formatCommand("🛠️ 선박 관리소", user, body, "강화 시도 시 [강화]를 입력하세요."));
}

/**
 * [v16.8] 선박 등급 업그레이드 엔진
 * 기능: 상인(Lv.3 제한) 및 직업군(Lv.10 제한) 선박 등급 상승 처리
 */
function _processShipUpgrade(user, data, replier, roomName, cfg) {
    var curLevel = Number(user.shipLevel || 1);
    var maxLevel = user.job ? 10 : 3;
    var next = cfg.SHIPS[curLevel + 1];

    if (!next || curLevel >= maxLevel) {
        var limitMsg = user.job ? "현재 함선이 도달 가능한 최종 등급입니다." : "상인 신분으로는 3단계까지만 개조 가능합니다.\n추가 개조는 해군/해적 전직이 필요합니다.";
        return replier.reply(formatError(user, "개조 불가", limitMsg));
    }

    if (Number(user.point) < next.upgradeCost) {
        return replier.reply(formatError(user, "자금 부족", "개조 비용 " + fp(next.upgradeCost) + "P가 부족합니다."));
    }

    var logicRoom = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var roomData = data.rooms[logicRoom];

    // 1. 포인트 게이트웨이 정산
    util_updatePoint(user, roomData, -next.upgradeCost, "선박 등급 업그레이드: " + next.name, roomName);

    // 2. 레벨업 반영 및 보안 면제
    user.shipLevel = curLevel + 1;
    user.skipHealing = true;

    var resMsg = "함선 설계도를 갱신하고 개조를 완료했습니다!\n\n" +
                 "🚢 새로운 등급: [" + next.name + "]\n" +
                 "📦 기본 적재량: " + next.capacity + "칸\n" +
                 "💰 소모 비용: -" + fp(next.upgradeCost) + "P";

    replier.reply(formatCommand("🏗️ 선박 등급 업그레이드 완료", user, resMsg, "내 잔액: " + fp(user.point) + "P"));
    
    // 3. 즉시 영속화
    safeSaveData(data, true);
}

// [신설] 강화 주사위 로직 (섹터 51 하단 추가)
function _processShipEnhanceRoll(user, data, replier, roomName) {
    if (user.job) {
        return replier.reply(formatError(user, "강화 불가", 
            "초월 강화는 [상인] 신분 전용 시스템입니다.\n" +
            "해적/해군은 이용하실 수 없습니다."));
    }

    var ec = SHIP_ENHANCE_CONFIG;
    var cost = ec.COST;
    if (Number(user.point) < cost) {
        return replier.reply(formatError(user, "자금 부족", "강화 시도에는 " + fp(cost) + "P가 필요합니다."));
    }

    util_updatePoint(user, data.rooms["내리다"], -cost, "함선 초월 강화 시도", roomName);

    /**
     * [v15.8] 지능형 확률 보정 엔진 (Subtle Skew Logic)
     * 가중치(skew)가 1.0보다 크면 낮은 값(Bad)이, 1.0보다 작으면 높은 값(Good)이 더 잘 나옵니다.
     * 1.2 정도의 수치는 수백 번 이상 수행해야 체감될 정도로 매우 정교하고 티가 나지 않습니다.
     */
    var skew = (user.isManipulated === true) ? 0.6 : 1.1; 

    // 1. 적재량/수익: 높은 수치가 '좋음' -> skew가 낮을수록(0.6) 높은 값 확률 증가
    var randLimit = Math.pow(Math.random(), skew);
    var rLimit = Math.floor(randLimit * (ec.LIMIT.max - ec.LIMIT.min + 1)) + ec.LIMIT.min;

    var randProfit = Math.pow(Math.random(), skew);
    var rProfit = Math.floor(randProfit * (ec.PROFIT.max - ec.PROFIT.min + 1)) + ec.PROFIT.min;

    // 2. 항해시간: 낮은 수치가 '좋음' -> 높은 쪽(max)으로 확률을 밀어내거나 당김
    var randTimeRaw = Math.random();
    var randTime = (user.isManipulated === true) 
                   ? Math.pow(randTimeRaw, 2.0)  // 해제 유저는 낮은 시간(-초) 확률 증폭
                   : 1 - Math.pow(randTimeRaw, 1.1); // 일반 유저는 높은 시간(+초) 확률 증폭
    
    var rTime = Math.floor(randTime * (ec.TIME.max - ec.TIME.min + 1)) + ec.TIME.min;

    // [v16.0] 초월 강화 시스템 최대 상한선(Cap) 밸런스 패치
        var nextLimit = Math.min(260, (user.enhLimit || 0) + rLimit);
        var nextTime = Math.max(-1050, (user.enhTime || 0) + rTime);
        var nextProfit = Math.min(300, (user.enhProfit || 0) + rProfit);

        rLimit = nextLimit - (user.enhLimit || 0);
        rTime = nextTime - (user.enhTime || 0);
        rProfit = nextProfit - (user.enhProfit || 0);

    user.tempEnh = { limit: rLimit, time: rTime, profit: rProfit };

    var curLimit = user.enhLimit || 0;
        var limitStr = "📦 적재: " + curLimit + " + (" + (rLimit >= 0 ? "+" : "") + rLimit + ") ➔ " + nextLimit + "칸" + (nextLimit >= 260 ? " (MAX)" : "");

        var curTime = user.enhTime || 0;
        var timeStr = "🕒 시간: " + curTime + " + (" + (rTime >= 0 ? "+" : "") + rTime + ") ➔ " + nextTime + "초" + (nextTime <= -1050 ? " (MAX)" : "");

        var curProfit = user.enhProfit || 0;
        var profitStr = "💰 수익: " + curProfit + " + (" + (rProfit >= 0 ? "+" : "") + rProfit + ") ➔ " + nextProfit + "%" + (nextProfit >= 300 ? " (MAX)" : "");

        var body = "🎲 초월 강화 결과가 도출되었습니다!\n\n" +
                   "[항목] : [현재] + [강화값] ➔ [최종 예상]\n" +
                   limitStr + "\n" +
                   timeStr + "\n" +
                   profitStr + "\n\n" +
                   "⚠️ 새로운 수치를 누적하시겠습니까?\n" +
                   "(1번 선택 시 현재 수치에 즉시 더해집니다)\n\n" +
                   "1. 예 (누적 적용)\n" +
                   "2. 아니오 (취소/유지)";

    replier.reply(formatCommand("🏗️ 함선 초월 개조 결과", user, body, "번호를 입력하세요."));
    
    var logicRoom = (ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    data.rooms[logicRoom].features.states.menuWait[user.uid] = { type: 'trade_enh_confirm', time: Date.now(), originRoom: roomName, cost: cost };
    safeSaveData(data, false);
}

/**
 * [핵심 엔진] 무역 정산 및 재해 엔진 v1.5
 */
function _processTradeArrival(user, data, replier, roomName, targetUid) {
    // 0. [에러 방지] 변수 선언 및 데이터 존재 여부 최우선 검증
    if (!user || !user.voyage) return; // 항해 중이 아니면 즉시 종료
    if (!data.shipwrecks) data.shipwrecks = {};
    var v = user.voyage; 

    // 모든 참조 오류의 원인인 변수들을 최상단에 일괄 선언합니다.
    var isHomeReturn = (v.dest === "무역 지부");
    var isEldorado = (v.dest === ELDORADO_CONFIG.NAME);

    util_fastClean(user);
    if (v) util_fastClean(v);

    // 1. 기초 설정 및 정책 로드
    var isHomeReturn = (v.dest === "무역 지부");

    var economyRoomName = (roomName === "베릭방" || ALLOWED_ROOMS.indexOf(roomName) === -1) ? "내리다" : roomName;
    var economyRoomData = data.rooms[economyRoomName];
    var pol = util_getActivePolicy(economyRoomData);
    var cfg = SYSTEM_CONFIG.TRADE;

    var pDataTarget = (economyRoomData.features && economyRoomData.features.portData) ? economyRoomData.features.portData[v.dest] : null;

    var baseDisasterProb = cfg.EVENTS.PROB || 0.40;
    var finalDisasterProb = isHomeReturn ? 0 : (baseDisasterProb * (pol.disasterProbMult || 1.0));
    
    if (pDataTarget && pDataTarget.built && pDataTarget.built.lighthouse) {
        finalDisasterProb *= 0.9; // 10% 감소
    }
    var triggeredDisaster = null;

    if (!isHomeReturn && Math.random() < finalDisasterProb) {
        var eventKeys = ["STORM", "FIRE", "CORROSION", "SMOOTH", "FESTIVAL", "FLOTSAM", "MONSTER", "FOG", "SCURVY", "MERCHANT", "SHIPWRIGHT", "RESCUE"];
        triggeredDisaster = eventKeys[Math.floor(Math.random() * eventKeys.length)];

        // [안전 가드] 설정값(cfg)에 해당 키가 없으면 이벤트 취소 (Crash 방지)
        if (triggeredDisaster && (!cfg.EVENTS.LIST || !cfg.EVENTS.LIST[triggeredDisaster])) {
            Log.warn("⚠️ [Trade Warning] 설정(Sector 1)에 없는 이벤트 키가 추첨됨: " + triggeredDisaster);
            triggeredDisaster = null;
        }
     }

    // [v16.4] 해상왕 칭호 효과 개편: 디버프(재해) 발생 시 50% 확률로 가드 발동
        var seaKingTag = "";
        var debuffs = ["STORM", "FIRE", "CORROSION", "PIRACY", "MONSTER", "FOG", "SCURVY"];
        if (user.title === "해상왕" && triggeredDisaster && debuffs.indexOf(triggeredDisaster) !== -1) {
            if (Math.random() < 0.5) {
                triggeredDisaster = null; // 재해 무효화
                seaKingTag = " (✨해상왕 가드 발동!)";
            }
        }

    // 3. 정산용 변수 초기화
    var tRev = 0; var tCost = 0;
    var totalRevenue = 0; var totalCost = 0;
    var totalSpecRev = 0; var totalSpecCost = 0;
    var pBonusTotal = 0;
    var targetRev = 0; var targetCst = 0;
    var efficientMargin = 0;
    var taxAmount = 0;
    var finalNetProfit = 0;
    
    var isEldorado = (v.dest === ELDORADO_CONFIG.NAME);
    var isHomeReturn = (v.dest === "무역 지부");

    var soldLog = [];
    var disasterLog = "";

    if (isHomeReturn) {
            disasterLog += "🏠 무역 지부 본영에 안전하게 입항하였습니다.\n✨ 모든 품목이 시장 원가(100%) 기준으로 정산됩니다.\n";
        }

    var cargoSummary = [];
    var hasFavoriteSold = false; 
    var totalPointLoss = 0;
    var repairFee = 0; 
    var pillageLoss = 0;
    var loss = 0;

    // 1. [잠금 통합 관리]: 1분 이상 잠겨있으면 유령 잠금으로 판단하여 해제 후 진행
    if (v.isProcessing === true) {
        if (Date.now() - (v.arrival || 0) > 60000) {
            v.isProcessing = false; 
            Log.warn("🔓 [Trade] " + user.name + "의 정산 잠금을 강제 해제했습니다.");
        } else {
            return; // 1분 이내 중복 실행 차단 (도배 방지)
        }
    }
    
    v.isProcessing = true; 

    // 2. [잠금 실행]: 정산 프로세스 점유
    v.active = false; 
    user.currentLoc = v.dest;

    try { // 3. [보호막 시작]: 단 한 번의 try로 모든 로직을 감싸 문법 오류를 차단함

        // 순찰 임무는 무역 정산(수익/재해/세금) 로직을 전혀 타지 않도록 최상단에서 처리 후 즉시 종료
        if (v.isPatrol) {
            v.isProcessing = false;
            user.skipHealing = true;
            replier.reply(formatCommand("⚓ 해역 순찰 완료", user, "정해진 항로의 순찰 임무를 마치고 [" + v.dest + "]에 무사히 입항했습니다.\n(항해 중 조우한 해적들과의 교전 기록은 개별 보고되었습니다.)"));
            safeSaveData(data, true);
            return;
        }

        // [v17.3] 50% 확률: 단일 유저 유실물 100% 인양 프로세스 (try 내부로 안전하게 이동)
        var routeKey = (v.origin || "무역 지부") + "-" + v.dest;
        if (!isHomeReturn && data.shipwrecks[routeKey] && data.shipwrecks[routeKey].length > 0) {
            if (Math.random() < SCAVENGE_CONFIG.FIND_PROB) {
                var wreck = data.shipwrecks[routeKey].shift(); 
                var rewardMsg = "";
                
                if (wreck.type === "POINT") {
                    util_updatePoint(user, data.rooms["내리다"], wreck.amt, "난파선 유실금액 인양", "내리다");
                    rewardMsg = "💰 유실금액 인양: +" + fp(wreck.amt) + "P";
                } else {
                    var isSpec = false;
                    for (var n in TRADE_RELATION) { if (TRADE_RELATION[n].set === wreck.name) { isSpec = true; break; } }
                    if (isSpec) {
                        if (!user.warehouseSpec) user.warehouseSpec = {};
                        user.warehouseSpec[wreck.name] = (Number(user.warehouseSpec[wreck.name]) || 0) + wreck.amt;
                    } else {
                        if (!user.warehouse) user.warehouse = {};
                        if (!user.warehouseAvg) user.warehouseAvg = {};
                        var wQty = Number(user.warehouse[wreck.name] || 0);
                        var wAvg = Number(user.warehouseAvg[wreck.name] || 0);
                        var baseCost = (SYSTEM_CONFIG && SYSTEM_CONFIG.TRADE && SYSTEM_CONFIG.TRADE.GOODS_COST && SYSTEM_CONFIG.TRADE.GOODS_COST[wreck.name]) ? SYSTEM_CONFIG.TRADE.GOODS_COST[wreck.name] : 10000;
                        user.warehouseAvg[wreck.name] = Math.floor(((wAvg * wQty) + (baseCost * wreck.amt)) / (wQty + wreck.amt));
                        user.warehouse[wreck.name] = wQty + wreck.amt;
                    }
