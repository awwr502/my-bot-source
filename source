function _processPediaReward(user, data, replier, roomName) {
    if (!user.discoveredCreatures) user.discoveredCreatures = [];
    
    var collected = user.discoveredCreatures.length;
    var currentLevel = user.pediaRewardLevel || 0;
    var nextLevel = currentLevel + 1;
    
    // 보상 테이블 정의
    var rewards = {
        1: { count: 20, point: 100000, title: "해양 탐사대", buff: "🛠️ 수리비 5% 할인" },
        2: { count: 40, point: 300000, title: "해양 생물학자", buff: "🛡️ 내구도 감소 완화" },
        3: { count: 60, point: 700000, title: "대양의 지배자", buff: "📦 특산품 발견 +1개" },
